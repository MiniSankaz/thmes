# ╔════════════════════════════════════════════════════════════════════════╗
# ║ Frontmatter loader (agents + skills)                                  ║
# ╚════════════════════════════════════════════════════════════════════════╝
FM_RE = re.compile(r"^---\n(.*?)\n---\n(.*)", re.DOTALL)

def _parse_fm(text: str) -> tuple[dict, str]:
    m = FM_RE.match(text)
    if not m: return {}, text
    fm_text, body = m.group(1), m.group(2)
    fm = {}
    lines = fm_text.split("\n")
    i = 0
    while i < len(lines):
        line = lines[i]
        mm = re.match(r"^(\w[\w_-]*):\s*(.*)$", line)
        if mm:
            k, v = mm.group(1), mm.group(2).strip()
            if v in (">", "|"):
                blk = []; i += 1
                while i < len(lines) and not re.match(r"^\w[\w_-]*:", lines[i]):
                    blk.append(lines[i].strip()); i += 1
                fm[k] = " ".join(b for b in blk if b); continue
            fm[k] = v.strip("\"'")
        i += 1
    return fm, body

def load_agents() -> dict:
    """Load agents from ~/.thmes/agents/ (JSON identity files) with markdown fallback.

    Returns dict[name] = {
        description, system, role, capabilities, permissions,
        max_iterations, max_tokens, temperature, model_preference, source
    }
    """
    out = {}
    # Phase 1: prefer ~/.thmes/agents/<name>/*.json
    if THMES_AGENTS.exists():
        for adir in sorted(THMES_AGENTS.iterdir()):
            if not adir.is_dir(): continue
            try:
                identity = json.loads((adir / "identity.json").read_text())
                caps     = json.loads((adir / "capabilities.json").read_text())
                safeg    = json.loads((adir / "safeguards.json").read_text())
                cfg      = json.loads((adir / "config.json").read_text())
                prompt   = (adir / "system-prompt.txt").read_text()
            except (FileNotFoundError, json.JSONDecodeError):
                continue
            out[identity["name"]] = {
                "description":       identity.get("description", "")[:200],
                "system":            prompt.strip(),
                "role":              identity.get("role", "utility"),
                "capabilities":      caps.get("primary", []),
                "tool_preferences":  caps.get("tool_preferences", []),
                "delegates_to":      caps.get("delegates_to", []),
                "context_budget":    caps.get("context_budget_pct", 0.7),
                "permissions":       safeg.get("permission", {}),
                "hard_limits":       safeg.get("hard_limits", []),
                "max_iterations":    safeg.get("max_iterations", 5),
                "max_tool_calls":    safeg.get("max_tool_calls_per_turn", 8),
                "model_preference":  cfg.get("model_preference"),
                "temperature":       cfg.get("temperature", 0.4),
                "max_tokens":        cfg.get("max_tokens", DEFAULT_MAX_TOKENS),
                "auto_compact":      cfg.get("auto_compact", True),
                "source": "json",
            }
        if out: return out
    # Fallback: ~/.claude/agents/<name>.md
    for p in sorted(CLAUDE_AGENTS.glob("*.md")):
        if p.name.endswith(".bak"): continue
        fm, body = _parse_fm(p.read_text())
        out[p.stem] = {
            "description": fm.get("description", "")[:200],
            "system":      body.strip(),
            "role":        "utility",
            "capabilities":     [],
            "tool_preferences": [],
            "delegates_to":     [],
            "context_budget":   0.7,
            "permissions":      {},
            "hard_limits":      [],
            "max_iterations":   5,
            "max_tool_calls":   8,
            "model_preference": None,
            "temperature":      0.4,
            "max_tokens":       DEFAULT_MAX_TOKENS,
            "auto_compact":     True,
            "source": "markdown",
        }
    return out

def load_skills() -> dict:
    out = {}
    for p in sorted(CLAUDE_SKILLS.glob("*/SKILL.md")):
        fm, body = _parse_fm(p.read_text())
        out[p.parent.name] = {
            "description": fm.get("description", "")[:200],
            "body": body.strip(),
        }
    return out

_PHASE_RE = re.compile(
    r'^#{2,3}\s+Phase\s+[\d.]+:?\s*(.+)$', re.MULTILINE | re.IGNORECASE
)

def _parse_skill_phases(body: str) -> list[dict]:
    """Extract phases from SKILL.md body. Returns [] if no phase headers found."""
    matches = list(_PHASE_RE.finditer(body))
    if not matches:
        return []
    phases = []
    for i, m in enumerate(matches):
        start = m.end()
        end = matches[i + 1].start() if i + 1 < len(matches) else len(body)
        phases.append({"title": m.group(1).strip(), "content": body[start:end].strip()})
    return phases


def run_skill_agentic(skill_name: str, skill_data: dict, user_task: str,
                      history: list, store, session_id: str,
                      tools_on: bool, allow_dangerous: set, max_tokens: int) -> None:
    """Run a skill as a multi-phase agentic workflow using the local model.

    Each phase gets its own agent_turn with tools enabled.  Output of phase N
    is condensed and forwarded as context to phase N+1.
    """
    body = skill_data["body"]
    desc = skill_data["description"]
    phases = _parse_skill_phases(body)

    def _run_phase(phase_sys: str, phase_msg: str) -> tuple:
        ph = [{"role": "user", "content": phase_msg}]
        return with_esc_cancel(
            agent_turn, ph, system=phase_sys,
            image=None, audio=None, max_tokens=max_tokens,
            tools_on=tools_on, allow_dangerous=allow_dangerous, max_iters=6)

    if not phases:
        # No structured phases — run as single agentic turn with full skill body
        console.print(Panel("[dim]no phases found — running as single agentic turn[/]",
                            title=f"skill: {skill_name}", border_style="magenta"))
        sys_prompt = (
            tools_system_block(TOOLS if tools_on else {}, [], "",
                               profile=_detect_model_profile(mm)) + "\n\n"
            + f"[Skill: {skill_name}]\n{desc}\n\nInstructions:\n{body[:3000]}"
        )
        try:
            reply, stats = _run_phase(sys_prompt, user_task)
        except KeyboardInterrupt:
            console.print("[yellow]⚠ skill cancelled[/]")
            return
        clean = _strip_model_artifacts(TOOL_CALL_RE.sub("", reply)) or reply
        history += [{"role": "user", "content": f"[Skill: {skill_name}] {user_task}"},
                    {"role": "assistant", "content": clean}]
        store.add_message(session_id, "user", f"[Skill: {skill_name}] {user_task}")
        store.add_message(session_id, "assistant", clean[:5000])
        console.print(Rule(style="dim"))
        console.print(Markdown(clean))
        return

    # Multi-phase execution
    console.print(Panel(
        f"[dim]{desc}[/]\n[bold cyan]{len(phases)} phases[/] · {user_task[:80]}",
        title=f"skill: {skill_name}", border_style="magenta"))

    chain: list[str] = []
    total = {"iters": 0, "tool_calls": 0, "tokens": 0}

    for i, phase in enumerate(phases):
        console.print(Rule(
            f"[magenta]Phase {i+1}/{len(phases)}: {phase['title']}[/]",
            style="magenta"))
        prev_ctx = (
            "\n\nPREVIOUS PHASES:\n"
            + "\n---\n".join(f"Phase {j+1}: {c}" for j, c in enumerate(chain))
            if chain else ""
        )
        sys_prompt = (
            tools_system_block(TOOLS if tools_on else {}, [], "",
                               profile=_detect_model_profile(mm)) + "\n\n"
            + f"[Skill: {skill_name} — Phase {i+1}/{len(phases)}: {phase['title']}]\n"
            + f"Description: {desc}\n\n"
            + f"PHASE INSTRUCTIONS:\n{phase['content'][:2500]}"
            + prev_ctx
        )
        phase_msg = (
            f"Execute Phase {i+1}: {phase['title']}\n\n"
            f"USER TASK: {user_task}\n\n"
            "Use tools as needed. When done, briefly summarize what you accomplished."
        )
        try:
            reply, stats = _run_phase(sys_prompt, phase_msg)
        except KeyboardInterrupt:
            console.print(f"[yellow]⚠ skill cancelled at phase {i+1}/{len(phases)}[/]")
            break
        clean = _strip_model_artifacts(TOOL_CALL_RE.sub("", reply)) or reply
        chain.append(clean[:600])
        for k in ("iters", "tool_calls", "tokens"):
            total[k] += stats.get(k, 0)
        console.print(Markdown(clean))
        console.print(f"[dim]  phase {i+1} done · {stats.get('iters',0)} iters "
                      f"· {stats.get('tool_calls',0)} tool calls[/]")

    summary_user = f"[Skill: {skill_name}] {user_task}"
    summary_asst = "\n\n---\n\n".join(chain) if chain else "(no output)"
    history += [{"role": "user", "content": summary_user},
                {"role": "assistant", "content": summary_asst}]
    store.add_message(session_id, "user", summary_user)
    store.add_message(session_id, "assistant", summary_asst[:5000])
    console.print(Rule(style="magenta"))
    console.print(
        f"[magenta bold]✓ {skill_name}[/] complete · "
        f"{total['iters']} iters · {total['tool_calls']} tool calls · "
        f"{total['tokens']:,} tokens"
    )

# ╔════════════════════════════════════════════════════════════════════════╗
# ║ Tools — built-in callable actions                                     ║
# ╚════════════════════════════════════════════════════════════════════════╝
TOOL_RISK = {"read_file": "safe", "list_dir": "safe", "grep": "safe",
             "web_search": "safe", "web_fetch": "safe",
             "current_datetime": "safe", "current_directory": "safe",
             "ask_user": "safe", "tasklist": "safe", "make_report": "safe",
             "write_file": "ask", "edit_file": "ask", "delete_file": "ask", "bash": "ask",
             "python": "ask", "opencode": "ask",
             "install_dep": "ask"}

# Safe tools that are nonetheless INTERACTIVE — they read stdin via pt_prompt
# and must run on the main thread without a status spinner active. Excluded
# from parallel batches and from the spinner wrapper in agent_turn.
_INTERACTIVE_TOOLS = {"ask_user"}

# Fine-grained risk tier for approval UX (drives panel color + warning text).
# "ask"-level tools still all require approval, but the visual urgency differs.
TOOL_RISK_TIER = {
    "write_file":   "low",    # fs write — undoable, no exec
    "edit_file":    "low",    # targeted patch — undoable, no exec
    "delete_file":  "medium", # permanent deletion — not undoable
    "python":       "medium", # sandboxed exec, 10s timeout
    "bash":         "high",   # arbitrary shell, can touch anything
    "opencode":     "high",   # delegates to a stronger external agent
    "install_dep":  "high",   # installs software — modifies system state
}
_RISK_STYLE = {
    "low":    {"color": "blue",   "icon": "📝", "label": "LOW"},
    "medium": {"color": "yellow", "icon": "⚙",  "label": "MEDIUM"},
    "high":   {"color": "red",    "icon": "⚠",  "label": "HIGH"},
}

# Pattern flag for genuinely dangerous bash invocations. Matching one of these
# escalates the panel border to red regardless of tier and prepends a warning.
_DANGEROUS_BASH_RE = re.compile(
    r"\b(rm\s+-rf?|sudo\b|chmod\s+(?:-R\s+)?7[7-9][0-9]|mkfs\b|"
    r"dd\s+if=|>\s*/dev/sd[a-z]|curl\s+[^|]*\|\s*(?:sh|bash)|"
    r":\(\)\{\s*:\|:&\s*\};:)",
    re.IGNORECASE,
)

def _truncate(s: str, n: int = 4000) -> str:
    return s if len(s) <= n else s[:n] + f"\n…[truncated {len(s)-n} chars]"


# ╔════════════════════════════════════════════════════════════════════════╗
# ║ Date/Time awareness — core function                                    ║
# ║                                                                        ║
# ║ Small local models have a training-time knowledge cutoff and no idea  ║
# ║ what "today" or "now" is at runtime. Without grounding they invent    ║
# ║ dates (often years in the past) which corrupts any time-sensitive    ║
# ║ reasoning ("วันนี้", "ล่าสุด", "this week"). Two-layer fix:            ║
# ║   1. Always-on context block prepended to every system prompt         ║
# ║   2. `current_datetime` tool the model can call when it needs to     ║
# ║      verify or compute relative dates mid-turn                        ║
# ║ Disable layer 1 with THMES_DATETIME_AWARE=0 (e.g. for determinism ║
# ║ in test runs).                                                        ║
# ╚════════════════════════════════════════════════════════════════════════╝
DATETIME_AWARE = _env("THMES_DATETIME_AWARE", "1").lower() in ("1","true","yes","on")
_TH_MONTHS = ["", "มกราคม","กุมภาพันธ์","มีนาคม","เมษายน","พฤษภาคม","มิถุนายน",
              "กรกฎาคม","สิงหาคม","กันยายน","ตุลาคม","พฤศจิกายน","ธันวาคม"]
_TH_DAYS = ["จันทร์","อังคาร","พุธ","พฤหัสบดี","ศุกร์","เสาร์","อาทิตย์"]


def current_datetime_snapshot() -> dict:
    """Single source of truth for 'now'. Returns ISO + components + Thai locale."""
    now_local = datetime.now().astimezone()
    now_utc = datetime.now(timezone.utc)
    offset = now_local.utcoffset() or timezone.utc.utcoffset(None)
    off_seconds = int(offset.total_seconds()) if offset else 0
    sign = "+" if off_seconds >= 0 else "-"
    off_hh, off_mm = divmod(abs(off_seconds) // 60, 60)
    return {
        "iso_local":  now_local.isoformat(timespec="seconds"),
        "iso_utc":    now_utc.isoformat(timespec="seconds"),
        "date":       now_local.strftime("%Y-%m-%d"),
        "time":       now_local.strftime("%H:%M:%S"),
        "weekday_en": now_local.strftime("%A"),
        "weekday_th": _TH_DAYS[now_local.weekday()],
        "month_en":   now_local.strftime("%B"),
        "month_th":   _TH_MONTHS[now_local.month],
        "year":       now_local.year,
        "year_be":    now_local.year + 543,    # Buddhist Era (Thai default)
        "tz_name":    now_local.tzname() or "UTC",
        "tz_offset":  f"UTC{sign}{off_hh:02d}:{off_mm:02d}",
        "unix":       int(time.time()),
    }


def current_datetime_context() -> str:
    """Pre-formatted block to prepend to system prompts. Always-fresh per call."""
    s = current_datetime_snapshot()
    return (
        "[Current Date/Time — use this for any 'now', 'today', 'current', "
        "'ล่าสุด', 'วันนี้' reasoning. Do NOT assume a stale date.]\n"
        f"  Today        : {s['weekday_en']}, {s['date']}  "
        f"(วัน{s['weekday_th']}ที่ {datetime.now().day} {s['month_th']} {s['year_be']})\n"
        f"  Local time   : {s['time']}  ({s['tz_name']}, {s['tz_offset']})\n"
        f"  ISO local    : {s['iso_local']}\n"
        f"  ISO UTC      : {s['iso_utc']}\n"
        f"  Unix epoch   : {s['unix']}"
    )


def tool_current_datetime(format: str = "default") -> str:
    """Return the current date/time. Useful when the model needs to verify
    or compute relative dates mid-conversation.

    Args:
      format: 'default' | 'iso' | 'unix' | 'thai'
    """
    s = current_datetime_snapshot()
    fmt = (format or "default").lower()
    if fmt == "iso":
        return s["iso_local"]
    if fmt == "unix":
        return str(s["unix"])
    if fmt == "thai":
        return f"วัน{s['weekday_th']}ที่ {datetime.now().day} {s['month_th']} {s['year_be']} เวลา {s['time']} ({s['tz_name']})"
    # default — comprehensive
    return (
        f"{s['weekday_en']}, {s['date']} {s['time']} ({s['tz_name']}, {s['tz_offset']})\n"
        f"ISO: {s['iso_local']}  |  UTC: {s['iso_utc']}  |  Unix: {s['unix']}\n"
        f"ภาษาไทย: วัน{s['weekday_th']}ที่ {datetime.now().day} {s['month_th']} พ.ศ. {s['year_be']}"
    )


# ╔════════════════════════════════════════════════════════════════════════╗
# ║ Filesystem awareness — core function (sibling to datetime awareness)  ║
# ║                                                                        ║
# ║ Models trained on public corpora memorize specific usernames (often   ║
# ║ /Users/<original-dev>/) and will write to those paths verbatim even   ║
# ║ when running on a machine where that user does NOT exist. We've seen  ║
# ║ models attempt `/Users/semini/Desktop/...` on a machine whose user is ║
# ║ `sem4pro`. Two-layer fix mirroring the datetime pattern:              ║
# ║   1. Always-on context block listing the real cwd/home/Desktop paths  ║
# ║   2. `current_directory` tool for mid-turn lookup                     ║
# ║   3. Defensive guard in tool_write_file rejecting other-user homes   ║
# ║ Disable layer 1 with THMES_PATH_AWARE=0.                          ║
# ╚════════════════════════════════════════════════════════════════════════╝
PATH_AWARE = _env("THMES_PATH_AWARE", "1").lower() in ("1","true","yes","on")


def current_path_snapshot() -> dict:
    """Single source of truth for filesystem context."""
    home = Path.home()
    return {
        "cwd":       os.getcwd(),
        "home":      str(home),
        "user":      os.environ.get("USER", "") or home.name,
        "shell":     os.environ.get("SHELL", ""),
        "desktop":   str(home / "Desktop"),
        "downloads": str(home / "Downloads"),
        "documents": str(home / "Documents"),
        "tmp":       "/tmp",
    }


def current_path_context() -> str:
    """Pre-formatted block to prepend to system prompts. Anchors the model
    to REAL filesystem paths instead of hallucinated /Users/<traindata>/."""
    s = current_path_snapshot()
    return (
        "[Filesystem context — use ONLY these real paths. Never write to "
        "`/Users/<other-name>/...` invented from training data — those paths "
        "do not exist on this machine.]\n"
        f"  Current dir  : {s['cwd']}\n"
        f"  Home (~)     : {s['home']}  (user: {s['user']})\n"
        f"  Desktop      : {s['desktop']}\n"
        f"  Downloads    : {s['downloads']}\n"
        f"  Documents    : {s['documents']}\n"
        f"  Scratch      : {s['tmp']}\n"
        f"Prefer `~/...` (auto-expands) or absolute paths under {s['home']}."
    )


def tool_current_directory(format: str = "default") -> str:
    """Return the current filesystem context (cwd / home / common paths).
    Useful mid-turn if the model needs to verify or compute a path."""
    s = current_path_snapshot()
    fmt = (format or "default").lower()
    if fmt == "cwd":
        return s["cwd"]
    if fmt == "home":
        return s["home"]
    if fmt == "json":
        return json.dumps(s, ensure_ascii=False, indent=2)
    return (
        f"cwd       : {s['cwd']}\n"
        f"home (~)  : {s['home']}\n"
        f"user      : {s['user']}\n"
        f"desktop   : {s['desktop']}\n"
        f"downloads : {s['downloads']}\n"
        f"documents : {s['documents']}\n"
        f"tmp       : {s['tmp']}"
    )


def tool_ask_user(question: str) -> str:
    """Ask the user ONE clarifying question and return their typed answer.

    Interactive — must run on the main thread without a spinner active, so it
    is listed in _INTERACTIVE_TOOLS to exclude it from parallel batches and
    from the status-spinner wrapper.
    """
    console.print(Panel(
        f"[bold yellow]{question}[/]",
        title="❓ assistant needs clarification",
        title_align="left",
        border_style="yellow"))
    with pause_esc_watcher():
        try:
            answer = pt_prompt(
                HTML('<ansiyellow>your answer ›</ansiyellow> ')).strip()
        except (EOFError, KeyboardInterrupt):
            return "[user did not answer — proceed with your best judgment]"
    if not answer:
        return "[user gave an empty answer — proceed with your best judgment]"
    return answer


def _validate_user_path(p: Path) -> Optional[str]:
    """Reject paths that look like another user's home directory — those are
    almost always hallucinated from training data. Returns error message or None."""
    s = str(p)
    home = str(Path.home())
    if s.startswith("/Users/") and not s.startswith(home + "/") and s != home:
        # `/Users/something/...` but not OUR /Users/<me>/...
        return (f"refusing to write to {p} — that path is under a different "
                f"user's home. This machine's home is {home}. "
                f"Use ~/... or {home}/... instead.")
    if s.startswith("/home/") and not s.startswith(home + "/"):
        return (f"refusing to write to {p} — `/home/...` is a Linux convention; "
                f"on macOS use {home}/... or ~/...")
    return None


def tool_read_file(path: str) -> str:
    p = Path(path).expanduser()
    return _truncate(p.read_text())

def tool_write_file(path: str, content: str, mode: str = "w") -> str:
    """Write or append to a file.  mode='w' overwrites (default); mode='a' appends.
    Use mode='a' to build large files in chunks — call write_file multiple times."""
    p = Path(path).expanduser()
    err = _validate_user_path(p)
    if err:
        return f"Error: {err}"
    p.parent.mkdir(parents=True, exist_ok=True)
    if mode == "a":
        with open(p, "a", encoding="utf-8") as f:
            f.write(content)
        total = p.stat().st_size
        return f"appended {len(content)} bytes to {p} (file now {total} bytes)"
    p.write_text(content, encoding="utf-8")
    return f"wrote {len(content)} bytes to {p}"

def tool_edit_file(path: str, old_str: str, new_str: str) -> str:
    """Replace the FIRST occurrence of old_str with new_str in a file.
    Read the file first to get exact text; the match is literal (not regex).
    Use write_file when rewriting large sections; use edit_file for small targeted changes."""
    p = Path(path).expanduser()
    err = _validate_user_path(p)
    if err:
        return f"Error: {err}"
    if not p.exists():
        return f"Error: {p} does not exist"
    text = p.read_text(encoding="utf-8")
    if old_str not in text:
        # Helpful hint: show nearby context if the string is close
        return (f"Error: old_str not found verbatim in {p}. "
                f"Use read_file to confirm exact whitespace/indentation first.")
    count = text.count(old_str)
    new_text = text.replace(old_str, new_str, 1)
    p.write_text(new_text, encoding="utf-8")
    note = f" ({count} occurrences total — replaced first)" if count > 1 else ""
    return f"edited {p}{note}"

def tool_delete_file(path: str) -> str:
    """Delete a single file. Refuses directories (use bash for recursive removal)."""
    p = Path(path).expanduser()
    err = _validate_user_path(p)
    if err:
        return f"Error: {err}"
    if p.is_dir():
        return (f"Error: {p} is a directory — delete_file only removes single files. "
                f"Use bash with 'rm -r' for directories (requires explicit approval).")
    if not p.exists():
        return f"Error: {p} does not exist"
    size = p.stat().st_size
    p.unlink()
    return f"deleted {p} ({size:,} bytes)"

def tool_list_dir(path: str = ".") -> str:
    p = Path(path).expanduser()
    items = []
    for e in sorted(p.iterdir()):
        items.append(f"{'d' if e.is_dir() else 'f'} {e.name}")
    return "\n".join(items)

def tool_grep(pattern: str, path: str = ".") -> str:
    p = Path(path).expanduser()
    results = []
    for f in p.rglob("*") if p.is_dir() else [p]:
        if not f.is_file(): continue
        try:
            for i, line in enumerate(f.read_text(errors="ignore").splitlines(), 1):
                if re.search(pattern, line):
                    results.append(f"{f}:{i}:{line}")
                    if len(results) >= 50: break
        except: pass
        if len(results) >= 50: break
    return "\n".join(results) or "(no matches)"

def tool_bash(command: str) -> str:
    # Backgrounded command (trailing '&') — typically starting a long-running
    # server. subprocess.run(capture_output=True) would BLOCK on the inherited
    # stdout pipe for the whole 30s timeout, because the detached child keeps
    # that pipe open. Detach it with DEVNULL fds and return immediately so the
    # agent can move on to probing the server.
    if command.rstrip().endswith("&"):
        try:
            subprocess.Popen(command, shell=True,
                             stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                             stdin=subprocess.DEVNULL, start_new_session=True)
        except Exception as e:
            return f"[bash error] {type(e).__name__}: {e}\n[exit 1]"
        time.sleep(1.0)   # let it spin up before the next step probes it
        return ("[started in background — detached. Its stdout/stderr are NOT "
                "captured here; redirect inside the command (e.g. '> server.log "
                "2>&1') and read that file to inspect it.]\n[exit 0]")
    try:
        r = subprocess.run(command, shell=True, capture_output=True,
                           text=True, timeout=30)
    except subprocess.TimeoutExpired as e:
        partial = (e.stdout or "") + (e.stderr or "")
        if isinstance(partial, bytes):
            partial = partial.decode("utf-8", "replace")
        return (_truncate(partial) +
                "\n[bash timed out after 30s — for a long-running process "
                "(server, watcher, REPL) append ' &' to run it in the "
                "background instead]\n[exit 124]")
    out = r.stdout + (("\n[stderr]\n" + r.stderr) if r.stderr else "")
    result = _truncate(out) + f"\n[exit {r.returncode}]"
    if r.returncode != 0:
        hint = _suggest_install_hint(r.stdout + r.stderr)
        if hint:
            result += f"\n\n{hint}"
    return result

# Patterns that indicate a missing tool/package
_MISSING_RE = re.compile(
    r"command not found[:\s]+(\S+)"
    r"|(\S+):\s*command not found"
    r"|No module named ['\"]([^'\"]+)['\"]"
    r"|ModuleNotFoundError.*['\"]([^'\"]+)['\"]"
    r"|Cannot find module ['\"]([^'\"]+)['\"]"
    r"|(\S+): not found"
    r"|which:\s*no (\S+) in",
    re.IGNORECASE,
)

def _suggest_install_hint(output: str) -> str:
    """Return an install_dep hint if the output indicates a missing tool/package."""
    m = _MISSING_RE.search(output)
    if not m:
        return ""
    pkg = next((g for g in m.groups() if g), None)
    if not pkg:
        return ""
    # Guess manager from package name
    if "." in pkg and not pkg.startswith("."):
        manager = "pip"   # looks like a Python dotted module
    elif pkg.startswith("@") or "/" in pkg:
        manager = "npm"
    else:
        manager = "auto"
    return (
        f'[hint] Missing tool/package detected: "{pkg}"\n'
        f'  → Call install_dep(package="{pkg}", manager="{manager}") to install it.'
    )

# PEP 508 version specs: allow < > only when followed by = or a digit/*.
# Multiple constraints (numpy>=1.24,<3) are supported via the inner repeat.
# Blocks shell redirections (>file, <file) because 'file' starts with a letter.
_PKG_SAFE_RE = re.compile(
    r'^[\w@./:\[\],!~^*-]+'                              # package name (no < > in this set)
    r'(?:(?:>=|<=|!=|==|~=|>|<)[\d.*][0-9a-zA-Z.*]*'   # first version specifier
    r'(?:,(?:>=|<=|!=|==|~=|>|<)[\d.*][0-9a-zA-Z.*]*)*' # additional comma-sep specifiers
    r')?$'
)

def tool_install_dep(package: str, manager: str = "auto", reason: str = "") -> str:
    """Install a missing package/tool. User approval is required (handled by TOOL_RISK).

    Supports managers: pip, brew, npm, cargo, auto (default — auto-detects).
    Already-installed packages are detected and skipped without running install.
    """
    import shutil as _shutil

    package = package.strip()
    if not package:
        return "[error] package name is required"

    # Reject names with shell metacharacters — prevents command injection
    if not _PKG_SAFE_RE.match(package):
        bad = [c for c in package if not _PKG_SAFE_RE.match(c)]
        return f"[error] unsafe package name '{package}' — rejected chars: {bad}"

    # Auto-detect manager from name shape
    if manager == "auto":
        if package.startswith("@") or ("/" in package and not package.startswith(".")):
            manager = "npm"
        elif package.startswith("crate:"):
            package = package[6:]
            manager = "cargo"
        elif _shutil.which("pip3") or _shutil.which("pip"):
            # Default to pip unless the name looks clearly like a system CLI
            # (system CLIs tend to have no underscores/dots and are short lowercased words)
            is_python_shaped = "_" in package or "." in package or package[0].isupper()
            manager = "pip" if is_python_shaped or _shutil.which("brew") is None else "brew"
        else:
            manager = "brew" if _shutil.which("brew") else "pip"

    if manager not in ("pip", "brew", "npm", "cargo"):
        return f"[error] unknown manager '{manager}'. Choose: pip, brew, npm, cargo, auto"

    venv_pip = Path.home() / ".thmes-env" / "bin" / "pip"
    pip_bin = str(venv_pip) if venv_pip.exists() else ("pip3" if _shutil.which("pip3") else "pip")

    def _run_list(args: list, *, timeout: int = 30) -> subprocess.CompletedProcess:
        return subprocess.run(args, capture_output=True, text=True, timeout=timeout)

    # Check already installed — list form, no shell interpolation
    already = False
    if manager == "pip":
        already = _run_list([pip_bin, "show", package]).returncode == 0
    elif manager == "brew":
        already = (
            _run_list(["brew", "list", "--formula", package]).returncode == 0
            or _run_list(["brew", "list", "--cask", package]).returncode == 0
        )
    elif manager == "npm":
        r_chk = _run_list(["npm", "list", "-g", "--depth=0", package])
        already = package in r_chk.stdout
    elif manager == "cargo":
        r_chk = _run_list(["cargo", "install", "--list"])
        already = any(line.startswith(package + " ") or line.startswith(package + "v")
                      for line in r_chk.stdout.splitlines())

    if already:
        return f"✓ {package} is already installed via {manager} — no action needed."

    # Install — list form, no shell interpolation
    console.print(f"[cyan]→ Installing {package} via {manager} …[/]")
    if manager == "pip":
        install_cmd = [pip_bin, "install", package]
    elif manager == "brew":
        install_cmd = ["brew", "install", package]
    elif manager == "npm":
        install_cmd = ["npm", "install", "-g", package]
    else:  # cargo
        install_cmd = ["cargo", "install", package]

    r = subprocess.run(install_cmd, capture_output=True, text=True, timeout=180)
    out = r.stdout + (("\n[stderr]\n" + r.stderr) if r.stderr else "")
    if r.returncode == 0:
        return f"✓ Installed {package} via {manager}\n{_truncate(out, 600)}"
    return f"✗ Install failed (exit {r.returncode})\n{_truncate(out, 1000)}"

def _pre_strip_html(html: str) -> str:
    """Pre-strip noise BEFORE passing to extractors.

    Removes:
      <script>...</script>   (including JSON-LD application/ld+json)
      <style>...</style>
      <noscript>...</noscript>
      <template>...</template>
      <svg>...</svg>
      <iframe>...</iframe>
      <!-- HTML comments -->
    """
    patterns = [
        r"<script\b[^>]*>.*?</script>",
        r"<style\b[^>]*>.*?</style>",
        r"<noscript\b[^>]*>.*?</noscript>",
        r"<template\b[^>]*>.*?</template>",
        r"<svg\b[^>]*>.*?</svg>",
        r"<iframe\b[^>]*>.*?</iframe>",
        r"<!--.*?-->",
    ]
    for pat in patterns:
        html = re.sub(pat, "", html, flags=re.DOTALL | re.IGNORECASE)
    return html


def _extract_with_trafilatura(html: str, url: str) -> str:
    try:
        import trafilatura
        text = trafilatura.extract(
            html, url=url,
            include_comments=False, include_tables=True,
            include_links=False, no_fallback=False,
            output_format="markdown",
            favor_recall=False,  # precision — less JSON/script noise
        ) or ""
        return text
    except Exception:
        return ""


def _extract_with_bs4(html: str) -> str:
    try:
        from bs4 import BeautifulSoup
        soup = BeautifulSoup(html, "lxml")
        # Remove obviously non-content tags (script removes both JS + JSON-LD)
        for tag in soup(["script", "style", "noscript", "template",
                         "iframe", "svg", "meta", "link"]):
            tag.decompose()
        # Try preference: <main>/<article> > entire body
        scope = soup.find("main") or soup.find("article") or soup.body or soup
        title = ""
        if soup.title and soup.title.string:
            title = soup.title.string.strip()
        # Extract tables specifically (price grids, schedules) — trafilatura sometimes misses
        tables_text = []
        for tbl in scope.find_all("table"):
            rows = []
            for tr in tbl.find_all("tr"):
                cells = [td.get_text(strip=True) for td in tr.find_all(["th","td"])]
                if any(cells):
                    rows.append(" | ".join(cells))
            if rows:
                tables_text.append("\n".join(rows))
        # Main body text
        text = scope.get_text(separator="\n", strip=True)
        text = re.sub(r"\n{3,}", "\n\n", text)
        parts = []
        if title: parts.append(f"# {title}")
        if tables_text:
            parts.append("## Tables\n\n" + "\n\n".join(tables_text))
        if text: parts.append(text)
        return "\n\n".join(parts)
    except Exception:
        return ""


def _extract_regex(html: str) -> str:
    return re.sub(r"\s+", " ", re.sub(r"<[^>]+>", " ", html)).strip()


def _looks_like_garbage(text: str) -> bool:
    """Heuristic: does extracted text look like JSON / code / minified gibberish?"""
    if not text or len(text) < 80: return True
    # High ratio of {} :; "" characters → JSON / object literal
    punct = sum(text.count(c) for c in '{}:";,')
    alpha = sum(1 for c in text if c.isalpha())
    if alpha == 0: return True
    if punct / alpha > 0.4: return True
    # If majority is "@context", "@type", "schema.org" → JSON-LD bleed
    if text.count("@context") + text.count("@type") > 3: return True
    # Long sequence without spaces → minified code
    longest_no_space = max((len(s) for s in re.split(r"\s+", text)), default=0)
    if longest_no_space > 200: return True
    return False


def _clean_web_html(html: str, url: str = "") -> str:
    """Multi-stage extractor: pre-strip → trafilatura + bs4 → pick best.

    Returns plain markdown-ish text. If extraction quality is poor (looks like
    JSON garbage), tries harder or falls back to a clearer error message.
    """
    # Pre-strip noise (script/style/JSON-LD/comments) BEFORE either parser
    cleaned_html = _pre_strip_html(html)

    traf = _extract_with_trafilatura(cleaned_html, url)
    bs4_text = _extract_with_bs4(cleaned_html)

    # Score: longer + more diverse words wins; penalize garbage
    def _score(t: str) -> int:
        if not t: return 0
        if _looks_like_garbage(t): return 0
        words = set(re.findall(r"\w{3,}", t.lower()))
        return len(t) + len(words) * 5

    candidates = [(t, _score(t)) for t in (traf, bs4_text) if t]
    candidates.sort(key=lambda x: -x[1])
    if candidates and candidates[0][1] >= 200:
        return candidates[0][0]

    # All quality candidates failed — return best-effort with warning
    fallback = _extract_regex(cleaned_html)
    if _looks_like_garbage(fallback):
        return (f"[web_fetch warning] This page appears to be JS-rendered or "
                f"primarily contains structured data (JSON-LD/schema.org). "
                f"Try web_search for a direct article instead.\n\n"
                f"Raw extracted ({len(fallback)} chars):\n{fallback[:500]}")
    return fallback


def tool_web_fetch(url: str, max_chars: int = 6000) -> str:
    # Refuse hallucinated/placeholder URLs
    if not url.startswith(("http://", "https://")):
        return f"Invalid URL: {url!r}. Must start with http:// or https://"
    from urllib.parse import urlparse
    parsed = urlparse(url)
    host = (parsed.hostname or "").lower()
    BLOCKED_DOMAINS = {"example.com", "example.org", "example.net", "test.com"}
    if host in BLOCKED_DOMAINS:
        return (f"Refused: {host} is a placeholder domain. "
                f"Use web_search first to find a real URL.")

    headers = {
        "User-Agent": ("Mozilla/5.0 (Macintosh; Apple Silicon Mac OS X 14_0) "
                       "AppleWebKit/605.1.15 (KHTML, like Gecko) "
                       "Version/17.0 Safari/605.1.15"),
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
        "Accept-Language": "th,en-US;q=0.9,en;q=0.8",
        "Accept-Encoding": "gzip, deflate",
    }
    req = Request(url, headers=headers)
    try:
        import gzip, zlib
        with urlopen(req, timeout=20) as r:
            raw = r.read(500_000)
            encoding = r.headers.get("Content-Encoding", "").lower()
            if encoding == "gzip":
                raw = gzip.decompress(raw)
            elif encoding == "deflate":
                raw = zlib.decompress(raw)
            # Detect charset from Content-Type or fall back to utf-8
            ctype = r.headers.get("Content-Type", "")
            charset = "utf-8"
            m = re.search(r"charset=([^\s;]+)", ctype, re.IGNORECASE)
            if m: charset = m.group(1).strip('"\'')
            try:
                html = raw.decode(charset, errors="replace")
            except LookupError:
                html = raw.decode("utf-8", errors="replace")
    except Exception as e:
        return f"web_fetch failed: {type(e).__name__}: {e}"

    text = _clean_web_html(html, url=url)
    # Annotate output with source so model knows context
    header = f"[web_fetch] {url}\n{'=' * 60}\n"
    body = text[:max_chars]
    if len(text) > max_chars:
        body += f"\n\n[... truncated, {len(text)-max_chars:,} more chars]"
    return header + body


# ── web_search cache (5-min TTL) ──────────────────────────────────────────
# Same query within 5 minutes returns cached result instead of re-hitting
# DuckDuckGo. DDG rate-limits aggressively and small models often repeat
# queries verbatim across iterations. Keyed by (mode, query, timelimit, region).
_WEB_CACHE: dict[tuple, tuple[float, str]] = {}
_WEB_CACHE_TTL = 300.0
_WEB_CACHE_MAX = 64


def _domain_of(url: str) -> str:
    try:
        from urllib.parse import urlparse
        return (urlparse(url).hostname or "").lower().lstrip("www.")
    except Exception:
        return ""


_THAI_RE = re.compile(r"[฀-๿]")

# Any http(s) URL embedded in tool output — used by the research controller to
# count unique source domains gathered so far (coverage measurement).
_URL_IN_TEXT_RE = re.compile(r'https?://[^\s<>"\')\]]+', re.IGNORECASE)


def _extract_domains(text: str) -> set:
    """Pull unique source domains out of accumulated search/fetch output.

    Lets the research controller measure coverage deterministically (how many
    distinct sources do we have?) without trusting the model to self-report."""
    out: set = set()
    for u in _URL_IN_TEXT_RE.findall(text or ""):
        d = _domain_of(u.rstrip(".,);]"))
        if d and "." in d:
            out.add(d.lower())
    return out


def _auto_region(query: str, override: Optional[str]) -> str:
    """Pick region: explicit override → use it. Otherwise detect Thai script."""
    if override:
        return override
    return "th-th" if _THAI_RE.search(query) else "wt-wt"


def tool_web_search(query: str, max_results: int = 5,
                    *, mode: str = "text", timelimit: Optional[str] = None,
                    region: Optional[str] = None, auto_fetch: bool = False) -> str:
    """Web search via DuckDuckGo with multi-mode + time filter + auto-fetch.

    Args:
      query:       search terms (required)
      max_results: 1-10 (default 5)
      mode:        'text' | 'news' | 'images'
      timelimit:   'd' (day) | 'w' (week) | 'm' (month) | 'y' (year) | None
                   — use for "ล่าสุด / latest / วันนี้" queries.
      region:      'th-th' (Thailand), 'us-en', 'wt-wt' (worldwide). Auto-
                   detects Thai script in query when not specified.
      auto_fetch:  if True, fetches + cleans content of the top result and
                   includes it inline (combines search + fetch → one tool call,
                   one iter — useful for `ค้น X แล้วบอก content` patterns).

    Returns:
      Numbered list of results. Each line shows title, URL, domain, snippet,
      and (for news mode) the publish date. Use the URL with `web_fetch` if
      you need the full article text.
    """
    try:
        from ddgs import DDGS
    except ImportError:
        # ddgs is a required dependency — auto-install silently into the active env
        console.print("[yellow]⚙ web_search: ddgs not found — installing automatically…[/]")
        r = subprocess.run(
            [sys.executable, "-m", "pip", "install", "ddgs", "-q"],
            capture_output=True, text=True, timeout=60)
        if r.returncode != 0:
            return (f"web_search unavailable: ddgs install failed.\n{r.stderr[:400]}\n"
                    "Try: install_dep(package=\"ddgs\", manager=\"pip\")")
        console.print("[green]✓ ddgs installed — retrying search[/]")
        try:
            from ddgs import DDGS
        except ImportError:
            return "web_search unavailable: ddgs installed but import still failed. Restart thmes."
    if not query.strip():
        return "Empty query"
    mode = (mode or "text").lower()
    if mode not in ("text", "news", "images"):
        return f"Invalid mode {mode!r}. Use 'text' | 'news' | 'images'."
    if timelimit and timelimit not in ("d", "w", "m", "y"):
        return f"Invalid timelimit {timelimit!r}. Use 'd' | 'w' | 'm' | 'y' or omit."
    region = _auto_region(query, region)
    n = max(1, min(int(max_results), 10))

    # Cache check (skip cache when auto_fetch=True since result includes
    # potentially-changing fetched content)
    cache_key = (mode, query, timelimit, region, n)
    now = time.time()
    if not auto_fetch:
        if cache_key in _WEB_CACHE:
            ts, cached = _WEB_CACHE[cache_key]
            if now - ts < _WEB_CACHE_TTL:
                return cached + f"\n[cached, {int(now - ts)}s old]"
        if len(_WEB_CACHE) > _WEB_CACHE_MAX:
            # Drop oldest entries
            for k in sorted(_WEB_CACHE, key=lambda x: _WEB_CACHE[x][0])[:16]:
                _WEB_CACHE.pop(k, None)

    fallback_note = ""
    try:
        ddg = DDGS()
        kw = {"region": region}
        if timelimit:
            kw["timelimit"] = timelimit
        if mode == "news":
            try:
                raw = list(ddg.news(query, max_results=n, **kw))
            except Exception:
                raw = []
            # Auto-fallback: news empty or errored → retry as text (broader coverage)
            if not raw:
                raw = list(ddg.text(query, max_results=n, **{"region": region}))
                fallback_note = " [news→text fallback]"
        elif mode == "images":
            raw = list(ddg.images(query, max_results=n, **kw))
        else:
            raw = list(ddg.text(query, max_results=n, **kw))
    except Exception as e:
        msg = f"web_search failed ({mode}): {type(e).__name__}: {e}"
        if "Ratelimit" in str(e) or "202" in str(e):
            msg += "\n[hint: DuckDuckGo is rate-limiting. Wait 30s or refine query.]"
        return msg

    if not raw:
        return f"(no results for {query!r}; mode={mode}, region={region})"

    out_lines = [f"[mode={mode}{fallback_note}, region={region}"
                 + (f", time={timelimit}" if timelimit else "")
                 + f", {len(raw)} results]"]
    top_url = None
    for i, r in enumerate(raw, 1):
        if mode == "images":
            title = (r.get("title") or "")[:120]
            url = r.get("image") or r.get("url", "")
            src = _domain_of(r.get("source") or url)
            extra = f"  ({r.get('width','?')}×{r.get('height','?')}, source: {src})"
            out_lines.append(f"{i}. {title}\n   {url}{extra}")
        elif mode == "news":
            title = (r.get("title") or "")[:120]
            url = r.get("url") or r.get("href", "")
            date = r.get("date", "")[:16]
            src = r.get("source") or _domain_of(url)
            snippet = (r.get("body") or "")[:240]
            out_lines.append(f"{i}. [{date}] {title}  ({src})\n   {url}\n   {snippet}")
            if i == 1: top_url = url
        else:  # text
            title = (r.get("title") or "")[:120]
            url = r.get("href") or r.get("url", "")
            snippet = (r.get("body") or "")[:240]
            dom = _domain_of(url)
            out_lines.append(f"{i}. {title}  ({dom})\n   {url}\n   {snippet}")
            if i == 1: top_url = url

    result = "\n\n".join(out_lines)

    if auto_fetch and top_url:
        result += "\n\n" + "═" * 60 + "\n"
        result += f"[auto_fetch top result: {top_url}]\n"
        fetched = tool_web_fetch(top_url, max_chars=3000)
        # Strip the duplicate URL header from web_fetch output
        if "\n" in fetched:
            _, _, body = fetched.partition("\n")
            result += body.lstrip("=").lstrip("\n").strip()
        else:
            result += fetched

    if not auto_fetch:
        _WEB_CACHE[cache_key] = (now, result)
    return result

_PY_SAFE_MODULES = {
    "math", "json", "re", "datetime", "statistics", "random", "itertools",
    "functools", "collections", "string", "decimal", "fractions", "hashlib",
    "base64", "textwrap", "html",
}
_PY_BLOCKED_BUILTINS = {
    "open", "exec", "eval", "compile", "__import__", "input",
    "breakpoint", "exit", "quit",
}
_PY_TIMEOUT_S = 10.0


def _sandbox_import(name, *args, **kwargs):
    """__import__ replacement: only allow whitelisted modules + their submodules."""
    root = name.split(".")[0]
    if root in _PY_SAFE_MODULES:
        return __import__(name, *args, **kwargs)
    raise ImportError(
        f"module {name!r} is blocked by sandbox. Allowed: {sorted(_PY_SAFE_MODULES)}"
    )


def tool_python(code: str) -> str:
    """Execute Python in a restricted sandbox:
      • 10s wall-clock timeout (runs in a daemon thread)
      • Whitelisted imports only (math/json/re/datetime/…)
      • Builtins like open/exec/eval/__import__ blocked
    """
    import io, contextlib, threading

    # Build a restricted builtins dict
    import builtins as _b
    safe_builtins = {
        k: getattr(_b, k) for k in dir(_b)
        if not k.startswith("_") and k not in _PY_BLOCKED_BUILTINS
    }
    safe_builtins["__import__"] = _sandbox_import
    sandbox_globals = {
        "__name__": "__sandbox__",
        "__builtins__": safe_builtins,
    }

    buf = io.StringIO()
    result_box = {"err": None}

    def _run():
        try:
            with contextlib.redirect_stdout(buf):
                exec(code, sandbox_globals)
        except BaseException as e:
            result_box["err"] = f"{type(e).__name__}: {e}"

    t = threading.Thread(target=_run, daemon=True)
    t.start()
    t.join(timeout=_PY_TIMEOUT_S)
    if t.is_alive():
        return (f"Error: python timeout after {_PY_TIMEOUT_S:.0f}s "
                f"(infinite loop or long-running code blocked)")
    if result_box["err"]:
        err_str = f"Error: {result_box['err']}"
        hint = _suggest_install_hint(result_box["err"])
        return err_str + (f"\n\n{hint}" if hint else "")
    return buf.getvalue() or "(no stdout)"


# opencode agent model:
#   PRIMARY agents (entry points):  build, plan
#   SUBAGENTS (delegated by primary): general, explore, analyst, architect, etc.
OPENCODE_PRIMARY = {"build", "plan"}
OPENCODE_SUBAGENTS = {
    "general", "explore", "summary", "title", "compaction",
    "analyst", "architect", "backend-dev", "ctx-manager", "data-engineer",
    "debugger", "doc-writer", "financial", "frontend-dev", "git-ops",
    "ops", "research", "reviewer", "tester",
}

# Default subagent→primary mapping for sensible routing
SUBAGENT_PRIMARY_MAP = {
    "frontend-dev": "build", "backend-dev": "build", "ops": "build",
    "data-engineer": "build", "doc-writer": "build", "tester": "build",
    "debugger": "build", "analyst": "plan", "architect": "plan",
    "research": "plan", "reviewer": "plan", "financial": "plan",
    "git-ops": "build", "ctx-manager": "plan",
}

OPENCODE_BIN = str(Path.home() / ".opencode/bin/opencode")

ANSI_ESCAPE_RE = re.compile(r"\x1b\[[0-9;?]*[A-Za-z]|\x1b\][^\x07]*\x07|\x1b[=>]")
# Stray control chars left after escape strip (carriage return, etc.)
CTRL_LEFTOVER_RE = re.compile(r"[\x00-\x08\x0b-\x1f\x7f]")

def _strip_ansi(s: str) -> str:
    """Remove ANSI escape sequences + stray control characters."""
    s = ANSI_ESCAPE_RE.sub("", s)
    s = CTRL_LEFTOVER_RE.sub("", s)
    # collapse carriage-return overwrites: keep only text after last \r per line
    if "\r" in s:
        s = s.split("\r")[-1]
    return s


def tool_opencode(prompt: str, agent: str = "build", cwd: str = ".") -> str:
    """Delegate a complex task to opencode CLI with live streaming + cancel + idle detect."""
    import select  # for non-blocking reads
    import signal

    work_dir = Path(cwd).expanduser()
    if not work_dir.exists():
        work_dir = Path.cwd()

    if agent in OPENCODE_SUBAGENTS:
        primary = SUBAGENT_PRIMARY_MAP.get(agent, "build")
        prompt = f"Delegate this to the @{agent} subagent.\n\n{prompt}"
        agent = primary
    elif agent not in OPENCODE_PRIMARY:
        agent = "build"

    # Force colorless + non-interactive: NO_COLOR + dumb terminal
    env = {**os.environ,
           "NO_COLOR": "1",
           "TERM": "dumb",
           "CI": "1",          # many CLIs disable progress bars under CI=1
           "FORCE_COLOR": "0"}

    cmd = [OPENCODE_BIN, "run", "--agent", agent, prompt]
    console.print(Panel(
        f"[bold cyan]🚀 opencode delegation[/]  [dim](Ctrl+C to cancel)[/]\n"
        f"[dim]agent:[/] [yellow]{agent}[/]   [dim]cwd:[/] {work_dir}\n"
        f"[dim]prompt:[/] {prompt[:150]}{'…' if len(prompt)>150 else ''}",
        border_style="cyan", title="↳ opencode starting"))

    try:
        p = subprocess.Popen(
            cmd, cwd=str(work_dir),
            stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
            text=True, bufsize=1, env=env,
            preexec_fn=os.setsid,   # own process group → easy to kill subtree
        )
    except FileNotFoundError:
        return f"[opencode] CLI not found at {OPENCODE_BIN}"

    output_lines: list[str] = []
    start = time.time()
    HARD_TIMEOUT = 300       # absolute max
    IDLE_TIMEOUT = 90        # warn if no output for this long
    last_output_at = start
    cancelled = False
    idle_warned = False

    fd = p.stdout.fileno()

    try:
        while True:
            # Wait up to 1s for new output (non-blocking poll)
            rlist, _, _ = select.select([fd], [], [], 1.0)

            if rlist:
                line = p.stdout.readline()
                if not line:
                    break  # EOF
                clean = _strip_ansi(line).rstrip("\n").rstrip()
                output_lines.append(clean)
                last_output_at = time.time()
                idle_warned = False
                if clean.strip():
                    elapsed = time.time() - start
                    trim = clean[:140] + ("…" if len(clean) > 140 else "")
                    console.print(f"  [dim cyan]│ {elapsed:5.1f}s[/] [dim]{trim}[/]")

            now = time.time()
            # Check if process is done
            if p.poll() is not None and not rlist:
                break
            # Hard timeout
            if now - start > HARD_TIMEOUT:
                console.print(f"[red]  ⏱ hard timeout {HARD_TIMEOUT}s — killing opencode…[/]")
                os.killpg(os.getpgid(p.pid), signal.SIGTERM)
                break
            # Idle warning
            if now - last_output_at > IDLE_TIMEOUT and not idle_warned:
                console.print(f"[yellow]  ⏸ idle for {IDLE_TIMEOUT}s — opencode may be stuck "
                              f"(Ctrl+C to cancel)[/]")
                idle_warned = True

        # Drain any remaining output
        try:
            for tail in p.stdout:
                clean = _strip_ansi(tail).rstrip()
                if clean: output_lines.append(clean)
        except Exception: pass
        p.wait(timeout=5)

    except KeyboardInterrupt:
        cancelled = True
        console.print("[yellow]  ⚠ Ctrl+C — killing opencode process tree…[/]")
        try: os.killpg(os.getpgid(p.pid), signal.SIGTERM)
        except Exception: pass
        try: p.wait(timeout=3)
        except subprocess.TimeoutExpired:
            try: os.killpg(os.getpgid(p.pid), signal.SIGKILL)
            except Exception: pass

    elapsed = time.time() - start
    rc = p.returncode if p.returncode is not None else -1
    status = "cancelled" if cancelled else ("ok" if rc == 0 else f"exit {rc}")
    border = "yellow" if cancelled else ("green" if rc == 0 else "red")
    console.print(Panel(
        f"[dim]{len(output_lines)} lines · {elapsed:.1f}s · {status}[/]",
        title="↳ opencode done", border_style=border))

    out = "\n".join(l for l in output_lines if l.strip()).strip()
    if cancelled:
        out += "\n[cancelled by user via Ctrl+C]"
    elif rc != 0:
        out += f"\n[opencode exit {rc}]"
    return _truncate(out, 6000) or "(opencode produced no output)"


# ╔════════════════════════════════════════════════════════════════════════╗
# ║ TaskStore — per-session task list (model-driven + user-managed)       ║
# ╚════════════════════════════════════════════════════════════════════════╝
TASKS_DB = THMES_HOME / "data" / "tasks.db"
_TASK_STATUSES = ("pending", "in_progress", "done", "cancelled")


class TaskStore:
    """SQLite-backed task list, scoped per session. Both the model (via the
    `tasklist` tool) and the user (via `/task`) read/write the same rows."""
    SCHEMA = """
    CREATE TABLE IF NOT EXISTS tasks (
      id          INTEGER PRIMARY KEY AUTOINCREMENT,
      session_id  TEXT NOT NULL,
      text        TEXT NOT NULL,
      status      TEXT NOT NULL DEFAULT 'pending',
      ord         INTEGER DEFAULT 0,
      created_at  TEXT NOT NULL,
      updated_at  TEXT NOT NULL
    );
    CREATE INDEX IF NOT EXISTS idx_tasks_session ON tasks(session_id, ord, id);
    """

    def __init__(self, db_path: Path = TASKS_DB):
        self.db_path = db_path
        db_path.parent.mkdir(parents=True, exist_ok=True)
        self.conn = sqlite3.connect(str(db_path), check_same_thread=False)
        self.conn.row_factory = sqlite3.Row
        self.conn.executescript("PRAGMA journal_mode=WAL;")
        self.conn.executescript(self.SCHEMA)
        self.conn.commit()

    def add(self, session_id: str, text: str) -> int:
        now = datetime.now(timezone.utc).isoformat(timespec="seconds")
        nxt = self.conn.execute(
            "SELECT COALESCE(MAX(ord), 0) + 1 FROM tasks WHERE session_id=?",
            (session_id,)).fetchone()[0]
        cur = self.conn.execute(
            "INSERT INTO tasks(session_id,text,status,ord,created_at,updated_at) "
            "VALUES(?,?,?,?,?,?)",
            (session_id, text.strip()[:300], "pending", nxt, now, now))
        self.conn.commit()
        return cur.lastrowid

    def add_many(self, session_id: str, texts: list) -> list:
        return [self.add(session_id, t) for t in texts if t.strip()]

    def set_status(self, session_id: str, task_id: int, status: str) -> bool:
        if status not in _TASK_STATUSES:
            return False
        now = datetime.now(timezone.utc).isoformat(timespec="seconds")
        cur = self.conn.execute(
            "UPDATE tasks SET status=?, updated_at=? WHERE id=? AND session_id=?",
            (status, now, task_id, session_id))
        self.conn.commit()
        return cur.rowcount > 0

    def list(self, session_id: str, include_done: bool = True) -> list:
        q = "SELECT id,text,status,ord FROM tasks WHERE session_id=?"
        if not include_done:
            q += " AND status NOT IN ('done','cancelled')"
        q += " ORDER BY ord ASC, id ASC"
        return [dict(r) for r in self.conn.execute(q, (session_id,)).fetchall()]

    def clear(self, session_id: str) -> int:
        cur = self.conn.execute("DELETE FROM tasks WHERE session_id=?", (session_id,))
        self.conn.commit()
        return cur.rowcount

    def counts(self, session_id: str) -> dict:
        rows = self.conn.execute(
            "SELECT status, COUNT(*) AS n FROM tasks WHERE session_id=? "
            "GROUP BY status", (session_id,)).fetchall()
        out = {s: 0 for s in _TASK_STATUSES}
        for r in rows:
            out[r["status"]] = r["n"]
        return out

    def close(self):
        try: self.conn.close()
        except: pass


# Module-global so the stateless `tasklist` tool can reach the session-scoped
# store. main() instantiates the store and keeps session_id current.
_TASK_CTX: dict = {"store": None, "session_id": None}

_TASK_STATUS_ICON = {
    "pending": "[dim]○[/]", "in_progress": "[yellow]◐[/]",
    "done": "[green]✓[/]", "cancelled": "[red]✗[/]",
}


def render_tasklist(quiet_if_empty: bool = True) -> None:
    """Print the current session's task list as a panel."""
    store = _TASK_CTX.get("store")
    sid = _TASK_CTX.get("session_id")
    if not store or not sid:
        return
    tasks = store.list(sid)
    if not tasks:
        if not quiet_if_empty:
            console.print("[dim]task list is empty[/]")
        return
    c = store.counts(sid)
    t = Table(show_header=False, box=None, padding=(0, 1))
    t.add_column(style="dim", no_wrap=True)   # id
    t.add_column(no_wrap=True)                # icon
    t.add_column()                            # text
    for tk in tasks:
        icon = _TASK_STATUS_ICON.get(tk["status"], "○")
        style = "strike dim" if tk["status"] in ("done", "cancelled") else ""
        txt = f"[{style}]{tk['text']}[/]" if style else tk["text"]
        t.add_row(f"#{tk['id']}", icon, txt)
    title = (f"📋 tasks  [dim]({c['done']}/{len(tasks)} done"
             + (f" · {c['in_progress']} active" if c['in_progress'] else "")
             + ")[/]")
    console.print(Panel(t, title=title, title_align="left", border_style="blue"))


def tool_tasklist(action: str, items: str = "", id: int = 0,
                  status: str = "") -> str:
    """Manage the session task list. Actions:
      add    — items="step 1\\nstep 2"   create one task per line
      update — id=2 status="done"        set a task's status
      list   — show current tasks
      clear  — remove all tasks for this session
    """
    store = _TASK_CTX.get("store")
    sid = _TASK_CTX.get("session_id")
    if not store or not sid:
        return "tasklist unavailable (no active session)"
    act = (action or "").lower().strip()
    if act == "add":
        lines = [ln.strip("-*0123456789. \t") for ln in (items or "").splitlines()]
        lines = [ln for ln in lines if ln]
        if not lines:
            return "tasklist add: no items given (pass items='step 1\\nstep 2')"
        ids = store.add_many(sid, lines)
        render_tasklist()
        return f"Added {len(ids)} task(s): #{', #'.join(map(str, ids))}"
    if act == "update":
        if not id or not status:
            return "tasklist update: need both id and status " \
                   "(pending|in_progress|done|cancelled)"
        ok = store.set_status(sid, int(id), status.lower().strip())
        if not ok:
            return f"tasklist update: task #{id} not found or bad status {status!r}"
        render_tasklist()
        return f"Task #{id} → {status}"
    if act == "clear":
        n = store.clear(sid)
        return f"Cleared {n} task(s)"
    # default: list
    tasks = store.list(sid)
    render_tasklist()
    if not tasks:
        return "Task list is empty."
    return "\n".join(
        f"#{t['id']} [{t['status']}] {t['text']}" for t in tasks)


# ── Built-in report generator ──────────────────────────────────────────────
# Turns Markdown into a polished, SELF-CONTAINED HTML report (stdlib only — no
# Pillow/pandoc/markdown package needed, so it works on every synced host).
# Open it in a browser and ⌘P → "Save as PDF" for a print-quality PDF.
_REPORT_CSS = """
:root{--navy:#0f2740;--teal:#178a8a;--green:#1c8a3a;--grey:#5b6b7a;--red:#b23a3a;
 --line:#e3e8ee;--codebg:#11151a;--codefg:#d6dee6;}
*{box-sizing:border-box}
body{margin:0;background:#eef1f4;color:#23323f;
 font-family:-apple-system,"Helvetica Neue","Sukhumvit Set","Thonburi",Arial,sans-serif;
 line-height:1.55;-webkit-print-color-adjust:exact;print-color-adjust:exact}
.report{max-width:880px;margin:24px auto;background:#fff;border-radius:14px;overflow:hidden;
 box-shadow:0 2px 18px rgba(20,40,60,.10)}
.rhead{background:var(--navy);color:#fff;padding:30px 40px}
.rtitle{margin:0;font-size:26px;font-weight:800;letter-spacing:.2px;color:#fff;border:none;padding:0}
.rdate{color:#9fb6c9;font-size:13px;margin-top:6px}
main{padding:26px 40px 10px}
h1,h2,h3{color:var(--navy);line-height:1.25}
h1{font-size:23px;border-bottom:3px solid var(--teal);padding-bottom:6px;margin-top:30px}
h2{font-size:19px;margin-top:26px}
h3{font-size:15.5px;color:var(--teal);margin-top:20px}
p{margin:10px 0}
code{background:#eef2f6;color:#0a3d62;padding:1px 6px;border-radius:5px;
 font-family:Menlo,Consolas,monospace;font-size:.9em}
pre.term{background:var(--codebg);color:var(--codefg);padding:16px 18px;border-radius:10px;
 overflow-x:auto;font-family:Menlo,Consolas,monospace;font-size:13px;line-height:1.5}
pre.term code{background:none;color:inherit;padding:0}
table{border-collapse:collapse;width:100%;margin:14px 0;font-size:14px}
th{background:var(--navy);color:#fff;text-align:left;padding:9px 12px;font-weight:700}
td{padding:8px 12px;border-bottom:1px solid var(--line)}
tbody tr:nth-child(even){background:#f5f8fb}
blockquote{margin:14px 0;padding:12px 16px;background:#f1f7f7;border-left:4px solid var(--teal);
 border-radius:0 8px 8px 0;color:#214444}
ul,ol{margin:10px 0;padding-left:24px}
li{margin:4px 0}
hr{border:none;border-top:1px solid var(--line);margin:22px 0}
strong{color:#15314a}
.rfoot{padding:14px 40px 26px;color:var(--grey);font-size:12px;text-align:center}
@media print{body{background:#fff}.report{box-shadow:none;margin:0;border-radius:0}}
"""

_REPORT_HTML = ("<!DOCTYPE html><html lang=\"th\"><head><meta charset=\"utf-8\">"
    "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">"
    "<title>{title}</title><style>{css}</style></head><body><div class=\"report\">"
    "<header class=\"rhead\"><h1 class=\"rtitle\">{title}</h1>"
    "<div class=\"rdate\">{date}</div></header><main>{body}</main>"
    "<footer class=\"rfoot\">Generated by THMES · make_report</footer></div></body></html>")


def _md_inline(s: str) -> str:
    """Inline Markdown → HTML: `code`, **bold**, *italic* (HTML-escaped)."""
    from html import escape
    out = []
    for part in re.split(r"(`[^`]+`)", s):
        if len(part) >= 2 and part.startswith("`") and part.endswith("`"):
            out.append(f"<code>{escape(part[1:-1])}</code>")
        else:
            e = escape(part)
            e = re.sub(r"\*\*(.+?)\*\*", r"<strong>\1</strong>", e)
            e = re.sub(r"(?<!\*)\*(?!\s)(.+?)(?<!\s)\*(?!\*)", r"<em>\1</em>", e)
            out.append(e)
    return "".join(out)


def _md_to_html(md: str) -> str:
    """Minimal Markdown → HTML (stdlib only): headings, fenced code, tables,
    lists, blockquotes, hr, paragraphs + inline formatting."""
    from html import escape
    lines = (md or "").split("\n")
    out: list[str] = []
    cur_list = None  # "ul" | "ol" | None

    def close_list():
        nonlocal cur_list
        if cur_list:
            out.append(f"</{cur_list}>")
            cur_list = None

    i, n = 0, len(lines)
    while i < n:
        ln = lines[i]
        if ln.strip().startswith("```"):                      # fenced code
            close_list(); i += 1; buf = []
            while i < n and not lines[i].strip().startswith("```"):
                buf.append(lines[i]); i += 1
            i += 1
            out.append(f"<pre class='term'><code>{escape(chr(10).join(buf))}</code></pre>")
            continue
        if (ln.strip().startswith("|") and i + 1 < n
                and re.match(r"^\s*\|[\s:\-|]+\|\s*$", lines[i + 1])):   # table
            close_list()
            hdr = [c.strip() for c in ln.strip().strip("|").split("|")]
            i += 2; rows = []
            while i < n and lines[i].strip().startswith("|"):
                rows.append([c.strip() for c in lines[i].strip().strip("|").split("|")]); i += 1
            th = "".join(f"<th>{_md_inline(h)}</th>" for h in hdr)
            body = "".join("<tr>" + "".join(f"<td>{_md_inline(c)}</td>" for c in r) + "</tr>"
                           for r in rows)
            out.append(f"<table><thead><tr>{th}</tr></thead><tbody>{body}</tbody></table>")
            continue
        mh = re.match(r"^(#{1,4})\s+(.*)", ln)
        if mh:
            close_list(); lvl = min(len(mh.group(1)), 3)
            out.append(f"<h{lvl}>{_md_inline(mh.group(2))}</h{lvl}>"); i += 1; continue
        if re.match(r"^\s*---+\s*$", ln):
            close_list(); out.append("<hr>"); i += 1; continue
        if ln.strip().startswith(">"):
            close_list(); out.append(f"<blockquote>{_md_inline(ln.strip().lstrip('>').strip())}</blockquote>")
            i += 1; continue
        mb = re.match(r"^\s*[-*]\s+(.*)", ln)
        mo = re.match(r"^\s*\d+\.\s+(.*)", ln)
        if mb:
            if cur_list != "ul": close_list(); out.append("<ul>"); cur_list = "ul"
            out.append(f"<li>{_md_inline(mb.group(1))}</li>"); i += 1; continue
        if mo:
            if cur_list != "ol": close_list(); out.append("<ol>"); cur_list = "ol"
            out.append(f"<li>{_md_inline(mo.group(1))}</li>"); i += 1; continue
        if not ln.strip():
            close_list(); i += 1; continue
        close_list(); out.append(f"<p>{_md_inline(ln)}</p>"); i += 1
    close_list()
    return "\n".join(out)


def tool_make_report(title: str, content: str, format: str = "html") -> str:
    """Render `content` (Markdown) into a polished report file under the reports
    folder. format='html' (default) is self-contained & print-to-PDF ready;
    format='md' writes raw Markdown."""
    from html import escape
    fmt = (format or "html").strip().lower()
    reports = THMES_HOME / "reports"
    reports.mkdir(parents=True, exist_ok=True)
    ts = datetime.now().strftime("%Y%m%d-%H%M%S")
    slug = re.sub(r"[^0-9A-Za-z฀-๿]+", "-",
                  (title or "report").strip()).strip("-").lower()[:50] or "report"
    if fmt in ("md", "markdown"):
        path = reports / f"{slug}-{ts}.md"
        path.write_text(f"# {title}\n\n{content}\n", encoding="utf-8")
        return f"report written → {path}"
    body = _md_to_html(content or "")
    doc = _REPORT_HTML.format(css=_REPORT_CSS, title=escape(title or "Report"),
                              date=datetime.now().strftime("%Y-%m-%d %H:%M"), body=body)
    path = reports / f"{slug}-{ts}.html"
    path.write_text(doc, encoding="utf-8")
    return (f"report written → {path}\n"
            f"[open in a browser to view; ⌘P → “Save as PDF” for a polished PDF]")


