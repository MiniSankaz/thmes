# ── Multi-model profile: family-aware tool formatting + chunking ─────────────
from dataclasses import dataclass as _dataclass

@_dataclass
class ModelProfile:
    family: str           # gemma|qwen|llama|mistral|deepseek|command-r|phi|generic
    size_b: float         # parameter count in billions (0.0 = unknown)
    fmt: str              # xml|mistral|deepseek|command-r|pythontag
    max_chunk_chars: int  # safe single write_file payload size
    source: str           # "ollama-meta"|"name-heuristic"|"default"


def _family_from_string(name: str) -> tuple[str, str]:
    """Return (family, fmt) from a model name string."""
    n = name.lower()
    if "gemma"   in n: return "gemma",     "xml"
    if "qwen"    in n: return "qwen",      "xml"
    if "llama"   in n: return "llama",     "pythontag"
    if "phi"     in n: return "phi",       "xml"
    if "mistral" in n or "mixtral" in n: return "mistral", "mistral"
    if "deepseek" in n: return "deepseek", "deepseek"
    if "command-r" in n or "command_r" in n: return "command-r", "command-r"
    return "generic", "xml"


def _parse_param_size(name: str) -> float:
    """Extract parameter size in billions from model name (e.g. '7b' → 7.0)."""
    # Negative lookbehind for e/q (quantization suffixes like e4b, q4b, q8_0)
    m = re.search(r"(?<![eEqQ])(\d+(?:\.\d+)?)\s*[bB]", name)
    return float(m.group(1)) if m else 0.0


def _chunk_chars_for_size(size_b: float) -> int:
    if size_b <= 0:   return 1200
    if size_b < 8:    return 800
    if size_b < 30:   return 1500
    return 3000


def _detect_model_profile(mm) -> ModelProfile:
    """Build a ModelProfile from a live ModelManager instance.

    Tool-call format MUST follow the model's real architecture family, not its
    (often custom) display name — e.g. Ollama's `mistral:7b` is actually a
    llama-arch model, and many fine-tunes carry arbitrary names. Ollama reports
    the true architecture in `details.family`, captured in `ollama_meta`, so we
    trust that first and only fall back to a name guess when it's absent (MLX)."""
    # mm.name is the string tag (e.g. "ol:gemma4:e4b"); mm.model is the MLX object
    name = getattr(mm, "name", None) or ""
    if not isinstance(name, str):
        name = ""
    meta_family = ""
    if getattr(mm, "backend", "") == "ollama":
        meta_family = ((getattr(mm, "ollama_meta", None) or {}).get("family") or "").strip()
    if meta_family:
        family, fmt = _family_from_string(meta_family)
        source = "ollama-meta"
    else:
        family, fmt = _family_from_string(name)
        source = "name-heuristic"
    size_b = _parse_param_size(name)
    chunk = _chunk_chars_for_size(size_b)
    return ModelProfile(family=family, size_b=size_b, fmt=fmt,
                        max_chunk_chars=chunk, source=source)

# Runtime feature flags (mutable — toggleable via slash commands)
_FLAGS = {
    "opencode_enabled": _env("THMES_OPENCODE", "0").lower() in ("1","true","yes","on"),
    "verbose_tools":    _env("THMES_VERBOSE", "0").lower() in ("1","true","yes","on"),
    # Auto-inject a multi-source research hint when a factual/current-info
    # query is detected (prices, news, "ล่าสุด", comparisons). Toggle via
    # `/research auto on|off`. Distinct from the explicit `/research` command
    # which also auto-approves web tools and raises the iter limit.
    "research_auto":    _env("THMES_RESEARCH_AUTO", "1").lower() in ("1","true","yes","on"),
    # Detect whether a new user message continues the prior topic. If it's a
    # clear new topic → auto archive+new session (don't drag stale context).
    # If unsure → ask the user. Toggle via `/continuity on|off`.
    "continuity_check": _env("THMES_CONTINUITY", "1").lower() in ("1","true","yes","on"),
    # Offer to draft a plan before executing clearly multi-step tasks.
    # Toggle via `/plan auto on|off`. The explicit `/plan TASK` always works.
    "plan_auto":        _env("THMES_PLAN_AUTO", "1").lower() in ("1","true","yes","on"),
    # ── Deterministic research controller (multi-dimensional iterative search) ──
    # Target number of unique source domains a research turn should gather.
    "research_depth":   int(_env("THMES_RESEARCH_DEPTH", "3") or 3),
    # Max search ROUNDS before synthesizing (each round = a batch of queries;
    # if coverage is still thin the controller expands related keywords).
    "research_rounds":  int(_env("THMES_RESEARCH_ROUNDS", "3") or 3),
    # Use the model to propose RELATED keywords between rounds (semantic
    # expansion). Off → pure heuristic expansion (faster, fully deterministic).
    "research_kw_llm":  _env("THMES_RESEARCH_KW_LLM", "1").lower() in ("1","true","yes","on"),
    # Warm an Ollama model (1-token gen at our num_ctx) when it's selected, so the
    # user's first message doesn't pay the cold-load and risk a timeout. Also pins
    # the model at our ctx to avoid reload churn. Off → lazy load on first message.
    "ollama_warmup":    _env("THMES_OLLAMA_WARMUP", "1").lower() in ("1","true","yes","on"),
    # ── Privacy relay (mask → cloud → unmask) ──────────────────────────────
    # When on, each turn is masked locally, reasoned by a cloud model that sees
    # only placeholders, then unmasked locally. Entered via `/relay on` (which
    # smoke-tests the cloud first). `relay_mode` never persists across sessions.
    "relay_mode":          False,
    "relay_reason_tokens": int(_env("THMES_RELAY_REASON_TOKENS", "3072") or 3072),
    "relay_show_values":   _env("THMES_RELAY_SHOW_VALUES", "0").lower() in ("1","true","yes","on"),
    # Agentic relay (opt-in sub-mode of relay): when relay_mode AND relay_tools are
    # both on, the CLOUD drives a ReAct tool loop — it decides the tool calls (seeing
    # only __PII_*__ placeholders), the LOCAL machine executes them and re-masks each
    # result before it returns to the cloud. Cloud = brain, local = hands. Tool args
    # are unmasked just-in-time so exec uses real values (and the approval prompt
    # shows the real action). Toggle: /relay tools on|off.
    "relay_tools":         _env("THMES_RELAY_TOOLS", "0").lower() in ("1","true","yes","on"),
    "relay_max_iters":     int(_env("THMES_RELAY_MAX_ITERS", "6") or 6),
    # Self-heal: after the agentic loop, run this verify command; on failure the LOCAL
    # model triages the raw error and the (masked) error+diagnosis is fed back to the
    # cloud to fix — looping up to relay_heal_attempts. verify_cmd is task-specific and
    # session-only (never persisted). Set via `/relay verify <cmd>`.
    "relay_verify_cmd":    _env("THMES_RELAY_VERIFY", "") or "",
    "relay_heal_attempts": int(_env("THMES_RELAY_HEAL_ATTEMPTS", "3") or 3),
}

