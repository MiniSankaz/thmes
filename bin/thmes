def ask_yn(question: str, default: str = "n",
           allow_always: bool = False, allow_help: bool = False,
           allow_turn: bool = False) -> str:
    """Y/N/always/turn/help prompt. Returns 'y' | 'n' | 'always' | 'turn' | 'help'.

    - 'turn'  = approve all future calls of THIS tool until next user prompt
                (resets on new turn, narrower than session-wide 'always')
    - Empty input is NOT accepted — re-prompts. EOF/Ctrl+C → default.
    """
    opts = ["y", "n"]
    if allow_always: opts.append("a")
    if allow_turn:   opts.append("t")
    if allow_help:   opts.append("?")
    suffix = f"[{'/'.join(opts)}]"
    label = HTML(f'<ansiyellow>{question}</ansiyellow> '
                 f'<ansigray>{suffix}</ansigray> ')
    valid_hint = "y, n"
    if allow_always: valid_hint += ", a (always)"
    if allow_turn:   valid_hint += ", t (this turn)"
    if allow_help:   valid_hint += ", ? (more info)"
    with pause_esc_watcher():
        while True:
            try:
                ans = pt_prompt(label).strip().lower()
            except (EOFError, KeyboardInterrupt):
                return default
            if not ans:
                console.print(
                    f"[yellow]please answer {valid_hint} — Enter alone is not accepted[/]")
                continue
            if allow_help and ans.startswith("?"): return "help"
            if allow_always and ans.startswith("a"): return "always"
            if allow_turn and ans.startswith("t"): return "turn"
            if ans.startswith("y"): return "y"
            if ans.startswith("n"): return "n"
            console.print(f"[yellow]unrecognized: {ans!r} — type {valid_hint}[/]")

