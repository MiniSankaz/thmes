# Per-family tool format instructions — each key matches ModelProfile.fmt
_TOOL_PROMPT_TAIL = """
WEB ACCESS DISCIPLINE:
  • To FIND something online → call web_search with a QUERY. Never invent URLs.
  • Only call web_fetch when you ALREADY have a specific real URL
    (from web_search results or the user's message).
  • placeholder domains (example.com, test.com) are blocked and will fail.

Available tools:
{tools_json}
"""

TOOL_PROMPT_BY_FAMILY: dict[str, str] = {
    "xml": (
        "You have tools available. To call a tool, output one block per call:\n\n"
        "<tool_call>\n"
        '{{"name": "tool_name", "arguments": {{"key": "value"}}}}\n'
        "</tool_call>\n\n"
        "For parallel/independent calls, repeat the block — each runs concurrently:\n\n"
        "<tool_call>\n"
        '{{"name": "web_search", "arguments": {{"query": "search A"}}}}\n'
        "</tool_call>\n"
        "<tool_call>\n"
        '{{"name": "web_search", "arguments": {{"query": "search B"}}}}\n'
        "</tool_call>\n\n"
        "RULES (critical — ignoring these causes failure):\n"
        "  1. Wrap the JSON in <tool_call>…</tool_call> tags — exact spelling.\n"
        "  2. The JSON must be valid: double-quoted keys/strings, no trailing commas.\n"
        "  3. Use the literal keys \"name\" and \"arguments\" — not \"function\" / \"args\" / \"params\".\n"
        "  4. For INDEPENDENT operations (e.g. parallel searches), emit multiple\n"
        "     <tool_call> blocks in ONE response — they run concurrently. For\n"
        "     DEPENDENT operations (B needs A's result), emit one at a time.\n"
        "     After seeing ALL <tool_result>s, decide: call again OR write the final answer.\n"
        "  5. Do NOT add ```json fences. Do NOT use call:ns:name{{…}} syntax. Do NOT use functionName(…) syntax.\n"
        "  6. NEVER emit the same tool_call twice in one response — duplicates are\n"
        "     skipped. If the previous result was incomplete, wait for the next turn.\n"
        "  7. If the request is ambiguous or missing an essential detail (which file?\n"
        "     what format? which target?), call the ask_user tool with ONE specific\n"
        "     question instead of guessing. Don't ask about things you can discover\n"
        "     yourself with read_file / list_dir / current_directory.\n"
        "  8. SILENT RULE — do NOT write any text in the same response as a tool_call.\n"
        "     Output EITHER a <tool_call> block OR a final answer — never both.\n"
        "     No 'I will now…', 'Let me search…', 'I should wait…', 'I'm going to…'\n"
        "     narration. If you need tools, output ONLY the tool_call block(s), nothing\n"
        "     else. Prose goes in the FINAL answer after all tool results are back.\n\n"
        "CORRECT:\n"
        "<tool_call>\n"
        '{{"name": "read_file", "arguments": {{"path": "/tmp/foo.txt"}}}}\n'
        "</tool_call>\n\n"
        "WRONG (these will all fail):\n"
        "  call:tool:read_file{{path:\"foo\"}}            ← Gemma syntax — broken\n"
        "  read_file({{\"path\": \"foo\"}})                   ← function-call style — broken\n"
        "  ```json\\n{{\"name\":\"read_file\",...}}\\n```        ← markdown fence — broken\n"
        "  {{\"function\": \"read_file\", \"args\": {{...}}}}     ← wrong key names — broken\n"
    ),
    "mistral": (
        "You have tools available. To call one, output EXACTLY:\n\n"
        '[TOOL_CALLS] [{{"name": "tool_name", "arguments": {{"key": "value"}}}}]\n\n'
        "RULES:\n"
        "  1. Use [TOOL_CALLS] prefix followed by a JSON array.\n"
        "  2. Keys must be \"name\" and \"arguments\" — no alternatives.\n"
        "  3. For INDEPENDENT tasks, include multiple objects in the array — they run\n"
        "     concurrently. After <tool_result>s decide: call again or answer.\n"
        "  4. Never emit the same call twice in one response.\n"
        "  5. SILENT RULE — output EITHER a [TOOL_CALLS] block OR a final answer.\n"
        "     No narration ('I will now…', 'Let me…') before or after tool calls.\n"
    ),
    "deepseek": (
        "You have tools available. To call one, output EXACTLY:\n\n"
        "<｜tool▁sep｜>tool_name\n"
        "```json\n"
        '{{"key": "value"}}\n'
        "```\n"
        "<｜tool▁call▁end｜>\n\n"
        "RULES:\n"
        "  1. Use the exact Unicode delimiters shown above.\n"
        "  2. The JSON block contains only the arguments (no \"name\" key needed there).\n"
        "  3. For INDEPENDENT operations, emit multiple call blocks in one response —\n"
        "     they run concurrently. After all <tool_result>s decide: call again or answer.\n"
        "  4. SILENT RULE — output EITHER tool call block(s) OR a final answer, never both.\n"
        "     No 'I will now…', 'Let me…' narration before or after tool calls.\n"
    ),
    "command-r": (
        "You have tools available. To call one, output EXACTLY:\n\n"
        "Action: tool_name\n"
        'Action Input: {{"key": "value"}}\n\n'
        "RULES:\n"
        "  1. \"Action:\" on its own line, then \"Action Input:\" on the next line.\n"
        "  2. Arguments as a single JSON object on the Action Input line.\n"
        "  3. For INDEPENDENT tasks, emit multiple Action/Action Input pairs — they run\n"
        "     concurrently. After Observation(s) decide: action again or answer.\n"
        "  4. SILENT RULE — output EITHER Action block(s) OR a final answer, never both.\n"
        "     No 'I will now…', 'Let me…' narration before or after the action block.\n"
    ),
    "pythontag": (
        # Llama 3.1+ prefers <|python_tag|> but also accepts XML tool_call
        "You have tools available. To call ONE, output EXACTLY one block:\n\n"
        "<tool_call>\n"
        '{{"name": "tool_name", "arguments": {{"key": "value"}}}}\n'
        "</tool_call>\n\n"
        "Alternatively you may use:\n"
        '<|python_tag|>{{"name": "tool_name", "arguments": {{"key": "value"}}}}<|eom_id|>\n\n'
        "RULES:\n"
        "  1. Prefer the <tool_call> format — it is always recognized.\n"
        "  2. JSON must be valid: double-quoted keys, no trailing commas.\n"
        "  3. For INDEPENDENT operations, emit multiple <tool_call> blocks in one\n"
        "     response — they run concurrently. After all <tool_result>s decide.\n"
        "  4. Never emit the same call twice.\n"
        "  5. SILENT RULE — output EITHER tool_call block(s) OR a final answer, never both.\n"
        "     No 'I will now…', 'Let me…' narration before or after tool calls.\n"
    ),
}

# Fallback (old name kept for any external reference)
TOOL_PROMPT_TEMPLATE = TOOL_PROMPT_BY_FAMILY["xml"]

_LANG_RULE = (
    "[Language rule — MANDATORY]\n"
    "Detect the language of the user's latest message and reply in that SAME language.\n"
    "  • User writes Thai   → reply in Thai  (ภาษาไทย)\n"
    "  • User writes English → reply in English\n"
    "  • Mixed / unclear    → match the dominant script\n"
    "Never switch language unless the user explicitly asks you to."
)

# ═══════════════════════════════════════════════════════════════════════════════
# ── Feature: Prompt Analysis (intent/domain/search-angle classification) ──────
# ═══════════════════════════════════════════════════════════════════════════════

_PA_FINANCE_RE = re.compile(
    r"ราคา|price|cost|มูลค่า|หุ้น|stock|ดัชนี|\bindex\b|bitcoin|btc|"
    r"crypto|คริปโต|ทองคำ|ทอง|\bgold\b|forex|อัตราแลกเปลี่ยน|exchange.?rate|"
    r"ดอกเบี้ย|interest|กำไร|profit|ขาดทุน|loss|ลงทุน|invest|fund|"
    r"ethereum|eth|nasdaq|dow jones|s&p|น้ำมัน|\boil\b|crude|silver|เงิน",
    re.IGNORECASE,
)
_PA_TECH_RE = re.compile(
    r"\bcode\b|โค้ด|\bfunction\b|\bbug\b|\berror\b|ติดตั้ง|install|api|"
    r"database|server|python|javascript|typescript|\bscript\b|ระบบ|software|"
    r"hardware|\bapp\b|application|programming|debug|deploy|git|docker|"
    r"framework|library|module|endpoint|backend|frontend",
    re.IGNORECASE,
)
_PA_NEWS_RE = re.compile(
    r"ข่าว|news|headline|เหตุการณ์|event|รายงาน|report|ล่าสุด|latest|"
    r"เกิด|happen|ผลการ|result|election|เลือกตั้ง|สงคราม|war|"
    r"อุบัติเหตุ|accident|ประกาศ|announced|passed|approved",
    re.IGNORECASE,
)
_PA_HEALTH_RE = re.compile(
    r"โรค|disease|อาการ|symptom|ยา|medicine|drug|รักษา|treat|"
    r"สุขภาพ|health|hospital|โรงพยาบาล|หมอ|doctor|วิตามิน|"
    r"ออกกำลัง|exercise|diet|calorie|nutrition",
    re.IGNORECASE,
)
_PA_FACTUAL_RE = re.compile(
    r"เท่าไหร่|เท่าไร|กี่บาท|กี่.{0,8}ดอลลาร์|how much|what is|what's the|"
    r"ปัจจุบัน|current|วันนี้|today|ตอนนี้|ขณะนี้|ล่าสุด|latest|"
    r"อยู่ที่|stand at|is it now|มีค่า|worth|ราคา",
    re.IGNORECASE,
)
_PA_COMPARE_RE = re.compile(
    r"เปรียบเทียบ|เทียบ|compare|versus|\bvs\b|ดีกว่า|better than|"
    r"แตกต่าง|different|ต่างกัน|ไหนดีกว่า|which is better|"
    r"ข้อดีข้อเสีย|pros.{0,5}cons",
    re.IGNORECASE,
)
_PA_EXPLAIN_RE = re.compile(
    r"คืออะไร|อธิบาย|explain|how does|ทำงาน(ยังไง|อย่างไร)|"
    r"what is\b|define|หมายถึง|mean|ทำไม|why is|why does|"
    r"กลไก|mechanism|วิธีการ|หลักการ|principle",
    re.IGNORECASE,
)
_PA_OPINION_RE = re.compile(
    r"คิดว่า|think|ความเห็น|opinion|ดีไหม|should i|แนะนำ|recommend|"
    r"ควร|น่าจะ|assess|evaluate|ประเมิน|ความคิดเห็น|วิเคราะห์|analyze",
    re.IGNORECASE,
)
# Forward-looking / forecast markers — distinct from "factual current value".
# When this fires on a finance query, the search angles trade two spot-price
# queries for analyst-outlook queries so synthesis can actually reason about
# direction, not just report today's number.
_FORECAST_RE = re.compile(
    r"แนวโน้ม|คาดการณ์|พยากรณ์|มีโอกาส|อนาคต|ทิศทาง|ฟื้นตัว|จะขึ้น|จะลง|"
    r"น่าลงทุน|ควรซื้อ|ควรขาย|ลงทุนดี|"
    r"forecast|outlook|predict|prediction|future|prospect|price\s+target|"
    r"will\s+\w+\s+(rise|fall|drop|recover)|should\s+i\s+(buy|sell)",
    re.IGNORECASE,
)
_PA_TASK_RE = re.compile(
    r"^(ช่วย|help|please|สร้าง|create|เขียน|write|แก้|fix|"
    r"build|make|generate|ทำ|add|insert|update|delete)",
    re.IGNORECASE,
)
_PA_CHAT_RE = re.compile(
    r"^(สวัสดี|หวัดดี|ดีครับ|ดีค่ะ|hello|hi\b|hey\b|yo\b|"
    r"ขอบคุณ|thanks|thank you|ok\b|okay|ครับ$|ค่ะ$|นะ$|จ้า$)",
    re.IGNORECASE,
)
_PA_TH_SCRIPT_RE = re.compile(r"[ก-ฮ]")

# Known financial entities → (TH name, EN name, technical ticker/term)
_FINANCE_ENTITY_MAP = [
    (re.compile(r"bitcoin|btc|บิตคอยน์|บิทคอยน์", re.I), "Bitcoin", "bitcoin", "BTC/USD"),
    (re.compile(r"ethereum|eth|อีเธอเรียม", re.I),         "Ethereum","ethereum","ETH/USD"),
    (re.compile(r"ทองคำ|ทอง|gold|xau",         re.I),       "ทองคำ",   "gold",  "XAU/USD spot"),
    (re.compile(r"น้ำมัน|crude.?oil|brent|wti", re.I),      "น้ำมัน",  "crude oil","WTI/Brent crude"),
    (re.compile(r"silver|เงิน\b|xag",           re.I),       "เงิน",    "silver","XAG/USD"),
    (re.compile(r"set|ดัชนี.*?ตลาด|หุ้นไทย",   re.I),       "หุ้นไทย SET","SET index","SET Thailand"),
    (re.compile(r"nasdaq",                       re.I),       "Nasdaq",  "nasdaq","NASDAQ composite"),
    (re.compile(r"s&p\s*500|s&p500",            re.I),       "S&P 500", "S&P 500","SPX index"),
    (re.compile(r"ดอลลาร์|dollar|usd(?!/)",     re.I),       "ดอลลาร์", "US dollar","USD/THB"),
    (re.compile(r"เยน|yen|jpy",                  re.I),       "เยน",     "Japanese yen","JPY/USD"),
    (re.compile(r"euro?|ยูโร",                   re.I),       "ยูโร",    "Euro","EUR/USD"),
]


@_dataclass
class PromptAnalysis:
    domain: str           # finance|tech|news|health|code|chat|general
    intent: str           # factual|compare|explain|opinion|task|chat|code
    language: str         # th|en|mixed
    topic_words: list     # main entities/nouns extracted
    search_angles: list   # 3-4 ready-to-use query strings
    needs_structure: bool # True → inject 3-part response format
    time_sensitive: bool  # True → user wants live/today data


def _extract_finance_entity(msg: str) -> tuple[str, str, str] | None:
    """Return (th_name, en_name, technical_term) for first known finance entity."""
    for pat, th, en, tech in _FINANCE_ENTITY_MAP:
        if pat.search(msg):
            return th, en, tech
    return None


def _analyze_prompt(msg: str) -> "PromptAnalysis":
    """Fast heuristic prompt analysis — no LLM call, runs in <1 ms."""
    # Language
    th_chars = len(_PA_TH_SCRIPT_RE.findall(msg))
    en_chars  = len(re.findall(r"[a-zA-Z]", msg))
    if th_chars > en_chars * 0.5:
        lang = "th"
    elif en_chars > th_chars * 2:
        lang = "en"
    else:
        lang = "mixed"

    # Domain (order matters — more specific first)
    if _PA_TECH_RE.search(msg):
        domain = "tech"
    elif _PA_FINANCE_RE.search(msg):
        domain = "finance"
    elif _PA_NEWS_RE.search(msg):
        domain = "news"
    elif _PA_HEALTH_RE.search(msg):
        domain = "health"
    elif _PA_CHAT_RE.search(msg.strip()):
        domain = "chat"
    else:
        domain = "general"

    # Intent
    if _PA_CHAT_RE.search(msg.strip()):
        intent = "chat"
    elif domain == "tech" and _PA_TASK_RE.search(msg):
        intent = "code"
    elif _PA_TASK_RE.search(msg) and domain != "finance":
        intent = "task"
    elif _PA_COMPARE_RE.search(msg):
        intent = "compare"
    elif _PA_EXPLAIN_RE.search(msg):
        intent = "explain"
    elif _PA_OPINION_RE.search(msg):
        intent = "opinion"
    elif _PA_FACTUAL_RE.search(msg):
        intent = "factual"
    else:
        intent = "general"

    time_sensitive = bool(_PA_FACTUAL_RE.search(msg) and
                          re.search(r"วันนี้|today|ตอนนี้|current|ล่าสุด|latest|ขณะนี้|now|"
                                    r"ช่วงนี้|เดี๋ยวนี้|ตอนนี้|เป็นยังไง|เป็นอย่างไร|ตอนช่วง", msg, re.I))

    # Topic words — simple extraction
    topic_words: list[str] = []
    entity = _extract_finance_entity(msg) if domain == "finance" else None
    if entity:
        topic_words = [entity[0], entity[1]]

    # Search angles
    search_angles = _build_search_angles(msg, domain, intent, lang, entity)

    # Needs structured 3-part response
    needs_structure = (
        intent in ("factual", "compare", "explain", "opinion")
        and domain not in ("chat", "code")
        and len(msg) > 15
    )

    return PromptAnalysis(
        domain=domain, intent=intent, language=lang,
        topic_words=topic_words, search_angles=search_angles,
        needs_structure=needs_structure, time_sensitive=time_sensitive,
    )


def _build_search_angles(msg: str, domain: str, intent: str, lang: str,
                          entity: tuple | None) -> list[str]:
    """Generate 3-4 diverse search query strings from prompt analysis."""
    angles: list[str] = []

    forecast = bool(_FORECAST_RE.search(msg))
    if domain == "finance" and entity:
        th_name, en_name, tech = entity
        if forecast:
            # Forecast question → 2 spot + 2 forward-looking, so the synthesis
            # corpus carries analyst outlooks and trend calls, not only prices.
            angles = [
                f"ราคา {th_name} วันนี้",
                f"{en_name} price today",
                f"แนวโน้มราคา {th_name}",
                f"{en_name} price forecast",
            ]
        else:
            angles = [
                f"ราคา {th_name} วันนี้",
                f"{en_name} price today",
                f"{tech} live",
                f"ราคา {th_name} ล่าสุด",
            ]
    elif domain == "finance":
        # Generic finance — use original message + EN + broad
        clean = re.sub(r"[ช่วงนี้|วันนี้|ตอนนี้|เป็นยังไง|เป็นอย่างไร|บ้าง|ครับ|ค่ะ]", "", msg).strip()
        angles = ([clean, clean + " forecast", clean + " outlook 2026"]
                  if forecast else
                  [clean, clean + " today", clean + " latest news"])
    elif domain == "news":
        clean = re.sub(r"ข่าว|news|บ้าง|ครับ|ค่ะ|ล่าสุด", "", msg).strip()
        angles = [
            f"ข่าว {clean} ล่าสุด",
            f"{clean} news today",
            f"{clean} latest update",
        ]
    elif domain == "health":
        clean = msg.strip()
        angles = [
            clean,
            re.sub(r"[ก-ฮ]+", "", clean).strip() or clean,  # EN only fallback
            clean + " symptoms treatment",
        ]
    else:
        # General: original + English rephrase + broader
        angles = [msg.strip()]
        if lang == "th":
            angles.append(re.sub(r"[ก-ฮ\s]+", " ", msg).strip() or msg)
        angles.append(msg.strip() + " explained")

    return [a for a in angles if a.strip()][:4]


# ═══════════════════════════════════════════════════════════════════════════════
# ── Feature: 3-part response format injection ─────────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════

def _format_instruction_block(analysis: "PromptAnalysis") -> str:
    """Return a response-format instruction when the query benefits from structure.
    Returns empty string for chat/task/code queries."""
    if not analysis.needs_structure:
        return ""
    if analysis.language == "th":
        return (
            "[รูปแบบการตอบ — MANDATORY]\n"
            "ตอบแบบ \"ฟันธงก่อน อธิบายทีหลัง\" แบ่งเป็น 3 ส่วน:\n\n"
            "## ภาพรวม\n"
            "ฟันธงคำตอบของคำถามใน 1-2 ประโยคแรกทันที — ถ้าเป็นคำถามใช่/ไม่ใช่ "
            "หรือ \"จะ...ไหม\" ให้เลือกจุดยืนที่หลักฐานหนุนมากที่สุด; ถ้าเป็น "
            "การคาดการณ์ ให้บอกมุมมองที่ดีที่สุดแล้วกำกับว่าเป็นการประเมิน "
            "ห้ามเปิดด้วยการบอกว่าข้อมูลไม่พอ/ระบุไม่ได้\n\n"
            "## เนื้อหา\n"
            "เหตุผลสนับสนุน แต่ละจุดต้องอิงข้อเท็จจริงที่จับต้องได้จากผลของ "
            "tool ที่เรียกมา (ตัวเลข วันที่ เทรนด์ โค้ด หรือคำพูดผู้เชี่ยวชาญ) "
            "ถ้าได้มาจากการค้นเว็บ/อ่านไฟล์ ให้อ้างแหล่งสั้นๆ เช่น [domain] "
            "หรือ ชื่อไฟล์:บรรทัด ใช้ bullet/ตาราง/ตัวเลขตามเหมาะสม "
            "อย่าบรรยายว่า \"ข้อมูลที่ได้มามีอะไรบ้าง\" — ให้ใช้มันสรุปเป็นคำตอบ\n\n"
            "## ความเห็น\n"
            "สั้นๆ 1-2 บรรทัด: ระดับความมั่นใจ + สิ่งที่ควรจับตาต่อ หรือข้อควร "
            "ระวังสำคัญ ถ้าข้อมูลมีช่องโหว่จริงพูดถึงตรงนี้แบบรวบรัด "
            "ไม่ใช่ทำให้เป็นหัวเรื่องของคำตอบ\n"
        )
    return (
        "[Response Format — MANDATORY]\n"
        "Answer bottom-line-first, in exactly 3 sections:\n\n"
        "## Overview\n"
        "Open with the direct answer in 1-2 sentences. For a yes/no or "
        "'will X happen' question, commit to the best-supported position; "
        "for a forecast, give your best-supported view and label it a "
        "projection. Never open by saying the data is insufficient.\n\n"
        "## Details\n"
        "Supporting points, each anchored to a CONCRETE fact from the tools "
        "you called (a number, date, trend, code, or expert view). Cite "
        "web/file sources inline — [domain] or file:line. Use bullets, "
        "tables, or ### sub-headings where useful. Do NOT describe 'what the "
        "sources contain' — use them to build the answer.\n\n"
        "## Assessment\n"
        "1-2 lines: confidence level + what to watch next or the key caveat. "
        "If there's a real gap, note it briefly here — never make it the "
        "headline.\n"
    )


# ═══════════════════════════════════════════════════════════════════════════════
# ── Feature: Pre-output quality check ─────────────────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════

def _quality_check(user_msg: str, reply: str,
                   analysis: "PromptAnalysis") -> tuple[bool, list[str], bool]:
    """Check reply quality. Returns (passed, issues, should_retry)."""
    issues: list[str] = []
    should_retry = False

    clean = _strip_model_artifacts(TOOL_CALL_RE.sub("", reply)).strip()

    # 1. Language match
    th_in  = len(_PA_TH_SCRIPT_RE.findall(user_msg))
    th_out = len(_PA_TH_SCRIPT_RE.findall(clean))
    en_in  = len(re.findall(r"[a-zA-Z]", user_msg))
    user_is_thai = th_in > en_in * 0.3
    reply_is_thai = th_out > 50  # at least 50 Thai chars in reply
    if user_is_thai and not reply_is_thai and len(clean) > 80:
        issues.append("ภาษาไม่ตรง: user พิมพ์ไทย แต่คำตอบเป็น EN")
        should_retry = True

    # 2. Finance queries should have numbers
    if analysis.domain == "finance" and analysis.intent == "factual":
        has_nums = bool(re.search(r"\d[\d,. ]*(?:บาท|฿|\$|USD|THB|%|B\b)", clean) or
                        re.search(r"(?:฿|\$|USD|THB)\s*[\d,]+", clean) or
                        re.search(r"\b\d{4,}\b", clean))  # 4+ digit number
        if not has_nums:
            issues.append("คำถามการเงินแต่ไม่มีตัวเลขในคำตอบ — อาจตอบจาก memory")

    # 3. Structure check (soft — don't retry, just warn)
    if analysis.needs_structure and len(clean) > 200:
        has_sections = bool(re.search(r"^#{1,3}\s", clean, re.MULTILINE) or
                             re.search(r"ภาพรวม|Overview|เนื้อหา|Details|ความเห็น|Assessment",
                                       clean, re.IGNORECASE))
        if not has_sections:
            issues.append("ขาด 3-part structure (ภาพรวม/เนื้อหา/ความเห็น)")

    # 4. Too short for non-chat
    if analysis.intent not in ("chat", "task") and len(clean) < 80:
        issues.append("คำตอบสั้นเกินไป — อาจตัดทอน")

    return len(issues) == 0, issues, should_retry


def tools_system_block(enabled: dict, skills_index: list[str], agent_desc: str = "",
                       profile: "ModelProfile | None" = None) -> str:
    parts = []
    # Always-on temporal grounding (controls hallucinated dates on small models).
    # Captured fresh per call — for a single agent_turn, the system prompt is
    # built once before the loop, so all iterations see the same timestamp.
    if DATETIME_AWARE:
        parts.append(current_datetime_context())
    # Filesystem grounding — anchors writes to the REAL home dir, blocks the
    # `/Users/<traindata-name>/` hallucination class.
    if PATH_AWARE:
        parts.append(current_path_context())
    # Language mirroring — prevents small models from defaulting to English
    parts.append(_LANG_RULE)
    if agent_desc:
        parts.append(agent_desc + "\n")
    # Filter out opencode unless explicitly enabled
    if not _FLAGS["opencode_enabled"]:
        enabled = {k: v for k, v in enabled.items() if k != "opencode"}
    if enabled:
        tools_json = json.dumps([{
            "name": k, "description": v["desc"], "parameters": v["params"],
        } for k, v in enabled.items()], ensure_ascii=False, indent=2)
        fmt = profile.fmt if profile else "xml"
        tmpl = TOOL_PROMPT_BY_FAMILY.get(fmt, TOOL_PROMPT_BY_FAMILY["xml"])
        parts.append((tmpl + _TOOL_PROMPT_TAIL).format(tools_json=tools_json))
    if skills_index:
        parts.append(
            "\nAvailable skills (workflows the user can invoke via /skill NAME):\n"
            + "\n".join(f"  - {s}" for s in sorted(skills_index)[:30])
            + ("\n  …" if len(skills_index) > 30 else "")
        )
    return "\n".join(parts).strip()


# ── Tolerant parser ─────────────────────────────────────────────────────────
# Strategy order matters: most-specific patterns first.
TOOL_CALL_RE = re.compile(r"<tool_call>\s*(\{.*?\})\s*</tool_call>", re.DOTALL)
JSON_FENCE_RE = re.compile(r"```(?:json|tool|function)?\s*(\{.*?\})\s*```", re.DOTALL)
XML_FUNC_RE  = re.compile(r"<(?:function_call|invoke)\s+name=\"([^\"]+)\"\s*>\s*(\{.*?\})\s*</(?:function_call|invoke)>", re.DOTALL)
GEMMA_CALL_RE = re.compile(r"call:[\w.\-]+:([\w\-]+)\s*\{(.*?)\}", re.DOTALL)
PY_CALL_RE   = re.compile(r"\b([a-z_][a-z0-9_]*)\s*\(\s*(\{.*?\})\s*\)", re.DOTALL | re.IGNORECASE)
KV_PAIR_RE   = re.compile(r"([\w\-]+)\s*[:=]\s*(?:(?:<\|\"\|>)|[\"'])?([^\"',}<]+?)(?:(?:<\|\"\|>)|[\"'])?(?=\s*[,}]|$)")

# ── Extra parser regexes for non-XML model families ─────────────────────────
MISTRAL_RE = re.compile(r"\[TOOL_CALLS\]\s*(\[.*?\]|\{.*?\})", re.DOTALL)
DEEPSEEK_RE = re.compile(
    r"<｜tool▁sep｜>\s*([\w.\-]+)\s*"
    r"(?:```(?:json)?\s*)?(\{.*?\})"
    r"\s*(?:```)?\s*<｜tool▁call▁end｜>",
    re.DOTALL,
)
COMMAND_R_RE = re.compile(
    r"Action:\s*([\w.\-]+)\s*\n\s*Action\s*Input:\s*(\{.*?\})",
    re.DOTALL | re.IGNORECASE,
)

# ── Model artifact / thinking-token cleanup ──────────────────────────────────
# Strips special tokens that small models leak into visible output:
#   <|channel>thought … (Gemma 4 extended-thinking prefix — no closing tag)
#   <think>…</think>    (Qwen3 / DeepSeek-R1 reasoning block)
#   <|python_tag|>…<|eom_id|>  (Llama tool-call tokens used outside tool context)
#   <|...|>             (generic special-token fence leaked into text)
_THINK_BLOCK_RE    = re.compile(r"<think>.*?</think>", re.DOTALL | re.IGNORECASE)
# Gemma 4: <|channel>thought ...thinking... <channel>ACTUAL_ANSWER
# Strip the entire thought block up to and including the closing <channel> tag.
_CHANNEL_BLOCK_RE  = re.compile(r"<\|channel\>thought.*?<channel>", re.DOTALL | re.IGNORECASE)
# Fallback: strip any remaining lone <|channel>... line (no closing tag found)
_CHANNEL_TAG_RE    = re.compile(r"<\|channel\>[^\n]*\n?", re.IGNORECASE)
# Lone <channel> left over after other stripping
_CHANNEL_LONE_RE   = re.compile(r"<channel>", re.IGNORECASE)
_PYTAG_FENCE_RE    = re.compile(r"<\|python_tag\|>.*?(<\|eom_id\|>|$)", re.DOTALL)
_SPECIAL_TOK_RE    = re.compile(r"<\|[^|>]{1,40}\|>")

def _strip_model_artifacts(text: str) -> str:
    """Remove thinking blocks and leaked special tokens from model output."""
    text = _THINK_BLOCK_RE.sub("", text)
    text = _CHANNEL_BLOCK_RE.sub("", text)   # Gemma: strip whole thought block
    text = _CHANNEL_TAG_RE.sub("", text)     # fallback: lone opening tag
    text = _CHANNEL_LONE_RE.sub("", text)    # stray closing tag
    text = _PYTAG_FENCE_RE.sub("", text)
    text = _SPECIAL_TOK_RE.sub("", text)
    return text.strip()

def _coerce_keys(d: dict) -> dict:
    """Normalize alternative key names like {function,args} → {name,arguments}."""
    if "name" not in d:
        for k in ("function", "tool", "tool_name"):
            if k in d: d["name"] = d.pop(k); break
    if "arguments" not in d:
        for k in ("args", "params", "input", "parameters"):
            if k in d: d["arguments"] = d.pop(k); break
    return d

def _try_json(s: str) -> Optional[dict]:
    # Tolerate trailing commas + smart quotes
    s = s.replace("“", '"').replace("”", '"').replace("‘", "'").replace("’", "'")
    s = re.sub(r",(\s*[}\]])", r"\1", s)  # strip trailing commas
    try:
        d = json.loads(s)
        if isinstance(d, dict): return _coerce_keys(d)
    except json.JSONDecodeError:
        pass
    return None

def parse_tool_calls(text: str, known_tools: set[str] | None = None) -> tuple[list[dict], list[str]]:
    """Returns (parsed_calls, format_notes_for_telemetry)."""
    calls: list[dict] = []
    notes: list[str] = []
    consumed_spans: list[tuple[int, int]] = []

    def _claim(span):  # avoid double-counting overlapping matches
        for s, e in consumed_spans:
            if not (span[1] <= s or span[0] >= e): return False
        consumed_spans.append(span); return True

    # 1) Canonical: <tool_call>{...}</tool_call>
    for m in TOOL_CALL_RE.finditer(text):
        d = _try_json(m.group(1))
        if d and "name" in d:
            calls.append(d); _claim(m.span()); notes.append("canonical")

    # 2) Markdown JSON fence with valid tool shape
    for m in JSON_FENCE_RE.finditer(text):
        if not _claim(m.span()): continue
        d = _try_json(m.group(1))
        if d and "name" in d:
            calls.append(d); notes.append("md-fence")

    # 3) XML-style <function_call name="..."> or <invoke name="...">
    for m in XML_FUNC_RE.finditer(text):
        if not _claim(m.span()): continue
        d = _try_json(m.group(2)) or {}
        calls.append({"name": m.group(1), "arguments": d.get("arguments", d)})
        notes.append("xml-func")

    # 4) Gemma syntax: call:ns:name{key:"val",...}
    for m in GEMMA_CALL_RE.finditer(text):
        if not _claim(m.span()): continue
        name = m.group(1).replace("-", "_")
        body = m.group(2).replace("<|\"|>", '"').replace("<|'|>", "'")
        args = {}
        for pm in KV_PAIR_RE.finditer(body):
            v = pm.group(2).strip()
            # Try to coerce numbers/bools
            if v.lower() == "true": v = True
            elif v.lower() == "false": v = False
            elif v.lstrip("-").isdigit(): v = int(v)
            else:
                try: v = float(v)
                except ValueError: pass
            args[pm.group(1)] = v
        calls.append({"name": name, "arguments": args}); notes.append("gemma")

    # 5) Python-style: tool_name({"k":"v"})  — only if name matches known tool
    if known_tools:
        for m in PY_CALL_RE.finditer(text):
            if not _claim(m.span()): continue
            name = m.group(1)
            if name not in known_tools: continue
            d = _try_json(m.group(2))
            if d:
                calls.append({"name": name, "arguments": d}); notes.append("py-call")

    # 6) Mistral / Mixtral: [TOOL_CALLS] [{...}]
    if not calls:
        m = MISTRAL_RE.search(text)
        if m:
            raw = m.group(1).strip()
            if raw.startswith("{"):
                raw = "[" + raw + "]"
            try:
                items = json.loads(raw)
                if not isinstance(items, list): items = [items]
                for item in items:
                    d = _coerce_keys(item)
                    if "name" in d:
                        calls.append(d); notes.append("mistral")
            except json.JSONDecodeError:
                pass

    # 7) DeepSeek: <｜tool▁sep｜>name\n{...}<｜tool▁call▁end｜>
    if not calls:
        for m in DEEPSEEK_RE.finditer(text):
            if not _claim(m.span()): continue
            d = _try_json(m.group(2)) or {}
            calls.append({"name": m.group(1), "arguments": d.get("arguments", d)})
            notes.append("deepseek")

    # 8) Command-R: Action: name\nAction Input: {...}
    if not calls:
        for m in COMMAND_R_RE.finditer(text):
            if not _claim(m.span()): continue
            d = _try_json(m.group(2)) or {}
            calls.append({"name": m.group(1), "arguments": d.get("arguments", d)})
            notes.append("command-r")

    # 9) Bare top-level JSON object — scan with raw_decode to handle nesting
    if not calls:
        dec = json.JSONDecoder()
        for i, ch in enumerate(text):
            if ch != "{": continue
            try:
                obj, _ = dec.raw_decode(text[i:])
            except json.JSONDecodeError:
                continue
            if isinstance(obj, dict):
                d = _coerce_keys(obj)
                if "name" in d and "arguments" in d:
                    calls.append(d); notes.append("bare-json")
                    break

    return calls, notes


# ── Salvage: extract code/HTML even when tool_call breaks (JSON escape issues) ──
HEREDOC_RE = re.compile(
    r"cat\s*>\s*(\S+?\.\w+)\s+<<\s*['\"]?(\w+)['\"]?\s*\n(.*?)\n\s*\2\b",
    re.DOTALL,
)
CODEBLOCK_RE = re.compile(r"```(?:(\w+))?[ \t]*([^\n]*)\n(.*?)\n```", re.DOTALL)
FILEPATH_HINT_RE = re.compile(
    r"(?:~|/|\.{1,2}/)[\w./\-]+\.(?:html?|css|js|py|json|md|txt|sh|ya?ml|xml|csv|tsx?|jsx?)",
    re.IGNORECASE,
)

# Broken-JSON heredoc inside corrupted tool_call (Gemma's typical failure mode).
# Allow the EOF terminator to be absent (truncated JSON) via |$ so we recover
# as much as possible even when the model's output was cut off.
BROKEN_HEREDOC_RE = re.compile(
    r"cat\s*>\s*(\S+?\.\w+)\s+<<\s*['\"]?(\w+)['\"]?\\?n(.*?)(?:(?:\\n)?\2|$)",
    re.DOTALL,
)
# Extracts the value of "command" key from a broken bash tool-call JSON string.
# After extraction, _unescape_json_str converts \n → real newlines so that
# HEREDOC_RE can find clean heredoc syntax inside the command text.
_CMD_JSON_RE = re.compile(r'"command"\s*:\s*"(.*?)(?:"\s*\}|$)', re.DOTALL)
# write_file with content extractable from broken JSON
BROKEN_WRITE_RE = re.compile(
    r'"path"\s*:\s*"([^"]+\.\w+)"\s*,\s*"content"\s*:\s*"(.+?)(?:"\s*\}|$)',
    re.DOTALL,
)

def _unescape_json_str(s: str) -> str:
    """Best-effort unescape of a string that was inside a JSON string."""
    return (s.replace("\\n", "\n")
             .replace("\\t", "\t")
             .replace('\\"', '"')
             .replace("\\'", "'")
             .replace("\\\\", "\\"))


def salvage_file_writes(reply: str, user_task: str) -> list[tuple[str, str, str]]:
    """Find file-writable artifacts in model reply when tool_call failed.

    Returns list of (path, content, source_label).
    Tries 4 strategies in order of reliability.
    """
    out = []

    # 1) Clean heredoc: cat > PATH << EOF\n...\nEOF
    for m in HEREDOC_RE.finditer(reply):
        out.append((m.group(1), m.group(3), "heredoc"))
    if out: return out

    # 2) Heredoc inside broken JSON string (cat > x << 'EOF'\nCONTENT\nEOF)
    for m in BROKEN_HEREDOC_RE.finditer(reply):
        path = m.group(1)
        content = _unescape_json_str(m.group(3)).rstrip("\\n").rstrip()
        if len(content) > 100:
            out.append((path, content, "broken-heredoc"))
    if out: return out

    # 3) write_file args salvageable: "path":"...","content":"..."
    for m in BROKEN_WRITE_RE.finditer(reply):
        path = m.group(1)
        content = _unescape_json_str(m.group(2)).rstrip("\\")
        if len(content) > 100:
            out.append((path, content, "broken-write_file"))
    if out: return out

    # 4) Markdown code block + path hint in user task
    task_paths = FILEPATH_HINT_RE.findall(user_task)
    if task_paths:
        for m in CODEBLOCK_RE.finditer(reply):
            lang, header, code = m.group(1) or "", m.group(2).strip(), m.group(3)
            path = header if FILEPATH_HINT_RE.match(header) else task_paths[0]
            if len(code) > 200:
                out.append((path, code, f"codeblock-{lang or 'plain'}"))
                break

    # 5) Bash tool-call with heredoc in broken JSON: unescape "command" value,
    #    then run HEREDOC_RE on the real (unescaped) command string.
    #    This recovers large HTML/code written via cat > path << 'EOF' ... EOF
    #    even when the surrounding JSON has unescaped quotes that broke parsing.
    if not out:
        cm = _CMD_JSON_RE.search(reply)
        if cm:
            cmd = _unescape_json_str(cm.group(1))
            for hm in HEREDOC_RE.finditer(cmd):
                content = hm.group(3).strip()
                if len(content) > 200:
                    out.append((hm.group(1), content, "bash-heredoc-unescape"))
                    break

    return out


def has_suspicious_tool_attempt(text: str) -> Optional[str]:
    """Detect when model tried to call a tool but couldn't be parsed — for feedback."""
    suspects = [
        ("call:" in text and "{" in text, "call:ns:name{...} (Gemma syntax)"),
        ("```json" in text and "name" in text, "```json fence"),
        ("function_call" in text or "invoke" in text, "XML function_call"),
        (re.search(r"\b\w+\s*\(\s*\{", text), "name({...}) function-call style"),
    ]
    for cond, label in suspects:
        if cond: return label
    return None

# ╔════════════════════════════════════════════════════════════════════════╗
# ║ Smart context router — model picks its own tools/agent/skills         ║
# ╚════════════════════════════════════════════════════════════════════════╝
ROUTER_PROMPT = """You are picking which RESOURCES to load for a task.

Task: {task}

AVAILABLE TOOLS (pick those you'll actually use):
{tools}

AVAILABLE AGENTS (pick AT MOST 1 persona, or "null"):
{agents}

AVAILABLE SKILLS (pick 0-2 workflow guides):
{skills}

Output EXACTLY this JSON, nothing else:
{{"tools":["name",...], "agent":"name_or_null", "skills":["name",...]}}

Examples:
  Task "list files in /tmp" → {{"tools":["list_dir"], "agent":null, "skills":[]}}
  Task "read /etc/hosts" → {{"tools":["read_file"], "agent":null, "skills":[]}}
  Task "อ่านรูปนี้" → {{"tools":[], "agent":null, "skills":[]}}
  Task "ค้นหาข่าว AI ล่าสุด" → {{"tools":["web_search"], "agent":null, "skills":[]}}
  Task "fetch https://github.com/X/Y/README" → {{"tools":["web_fetch"], "agent":null, "skills":[]}}
  Task "what is the price of bitcoin today" → {{"tools":["web_search"], "agent":null, "skills":[]}}
  Task "สร้าง HTML แสดง infographic" → {{"tools":["opencode"], "agent":"frontend-dev", "skills":["implement"]}}
  Task "implement REST API for users" → {{"tools":["opencode"], "agent":"backend-dev", "skills":["implement"]}}
  Task "fix bug in src/app.py" → {{"tools":["opencode","read_file"], "agent":"debugger", "skills":["debug"]}}

RULES:
  1. For long file content (HTML/code/scripts) → PREFER "opencode" tool.
  2. To find info on the web → use "web_search" FIRST (DO NOT guess URLs).
  3. "web_fetch" only when a SPECIFIC URL is already known.
"""

ROUTER_JSON_RE = re.compile(r'\{[^{}]*"tools"\s*:.*?\}', re.DOTALL)

def _compact_index(items: dict, max_desc: int = 60) -> str:
    return "\n".join(
        f"  - {k}: {(v.get('description') or v.get('desc') or '')[:max_desc].strip()}"
        for k, v in items.items()
    )

# Factual / current-info queries → auto-inject a multi-source research hint.
# Broad on purpose: the hint itself is conditional ("if this needs external
# facts…"), so a false-positive just adds a nudge the model can ignore.
_RESEARCH_TRIGGER_RE = re.compile(
    r"(ราคา|price|cost|มูลค่า|ค่าใช้จ่าย"
    r"|ล่าสุด|latest|recent|ปัจจุบัน|วันนี้|today|ตอนนี้|ขณะนี้|เมื่อไหร่|when is"
    r"|ข่าว|news|headline|รายงาน"
    r"|เปรียบเทียบ|เทียบ|compare|comparison|versus|\bvs\b|ดีกว่า|better than"
    r"|หุ้น|stock|ดัชนี|\bindex\b|อัตรา\s*(แลกเปลี่ยน|ดอกเบี้ย)?|exchange\s*rate"
    r"|ค่าเงิน|forex|crypto|bitcoin|คริปโต|ทองคำ|gold price"
    r"|อากาศ|weather|พยากรณ์|forecast|อุณหภูมิ|temperature"
    r"|สถิติ|statistics|ผลการแข่ง|ผลบอล|score|standings"
    r"|trend|แนวโน้ม|outlook|review|รีวิว)",
    re.IGNORECASE,
)

# Knowledge-gap / low-confidence markers in a DRAFT answer. When the model
# answers a factual question but hedges like this, it means "I don't really
# know" → the research controller should search the web and answer again.
# Model-agnostic on purpose (TH + EN); kept to CLEAR gap signals so it doesn't
# fire on ordinary hedging ("it depends", "generally"). Each alternative is a
# distinct way local models admit they lack current/specific information.
_UNCERTAINTY_RE = re.compile(
    r"(ไม่แน่ใจ|ไม่ทราบ|ไม่มีข้อมูล|ไม่มีรายละเอียด|ไม่สามารถยืนยัน"
    r"|ไม่สามารถ(ให้|บอก|เข้าถึง)|ไม่ได้อัปเดต|ยังไม่มีข้อมูล"
    r"|เท่าที่(ทราบ|รู้)|อาจ(จะ)?(ไม่ถูกต้อง|คลาดเคลื่อน|ล้าสมัย|ไม่เป็นปัจจุบัน)"
    r"|ข้อมูล(ของฉัน|นี้)?(อาจ)?(ไม่เป็นปัจจุบัน|ล้าสมัย|เก่า)"
    r"|ควร(ตรวจสอบ|เช็ค)(เพิ่มเติม|อีกครั้ง|จากแหล่ง)?|โปรดตรวจสอบ|แนะนำให้ตรวจสอบ"
    r"|i(?:'m| am) not (?:sure|certain)|i(?:'m| am) unsure"
    r"|i (?:do not|don'?t) (?:know|have (?:access|information|data|the latest|current|real-?time))"
    r"|i (?:can'?t|cannot|am unable to) (?:verify|confirm|provide|access)"
    r"|(?:as of|up to) my (?:last |latest )?(?:knowledge|training|update|data)"
    r"|my (?:training|knowledge) (?:data|cut-?off)"
    r"|(?:may|might|could) (?:be|not be) (?:out ?of ?date|outdated|current|up[- ]to[- ]date|accurate)"
    r"|please (?:verify|double[- ]check|check) (?:with|the|current|a)"
    r"|i(?:'d| would) recommend (?:checking|verifying|confirming)"
    r"|don'?t have (?:real-?time|current|live|up[- ]to[- ]date) (?:data|information|access))",
    re.IGNORECASE,
)


def _detect_uncertainty(reply: str):
    """Return the matched uncertainty phrase if a DRAFT answer admits a
    knowledge gap (model 'doesn't know' / data may be stale), else None.

    Drives the auto research path: draft → if uncertain → search → answer
    again. Strips tool-call/artifact noise first so it judges real prose."""
    if not reply:
        return None
    clean = _strip_model_artifacts(TOOL_CALL_RE.sub("", reply))
    m = _UNCERTAINTY_RE.search(clean)
    return m.group(0).strip() if m else None

# ── Context-continuity heuristics ─────────────────────────────────────────
# Decide whether a new user message continues the previous topic. Strong
# continuation signals = back-references / follow-up words. Strong new-topic
# signals = greetings / explicit topic-shift phrases. When neither matches,
# the caller falls back to a tiny LLM classification call.
# NOTE: \b word-boundaries do NOT work for Thai — Thai has no inter-word
# spaces so every Thai char is a "word char" with no boundary between words.
# Thai continuation cues are therefore bare substrings (slight over-matching
# is fine: it biases toward "continue", the safe non-destructive default).
# \b is kept only for the English alternatives where it works correctly.
_CONTINUE_RE = re.compile(
    r"(มัน|อันนั้น|อันนี้|ตัวนั้น|ตัวนี้|ที่ว่า|เมื่อกี้|ข้างบน|ก่อนหน้า"
    r"|ที่แล้ว|ที่ทำ|ที่เพิ่ง|ที่คุย|ดังกล่าว|จากเดิม|จากนั้น|เข้าไป|ข้างต้น"
    r"|ทำต่อ|ต่อเลย|ต่อจาก|ต่อด้วย|แก้ไข|แก้ตรง|แก้ให้|ปรับ|เพิ่ม|อีกอัน"
    r"|อีกหน่อย|อีกนิด|ด้วยนะ|ด้วยครับ|ด้วยค่ะ|เปลี่ยน(?!เรื่อง)"
    r"|\bit\b|\bthat\b|\bthis\b|\bthose\b|the above|previous|earlier"
    r"|continue|keep going|also|and then|\bnext\b|one more|\bsame\b)",
    re.IGNORECASE,
)
_NEW_TOPIC_RE = re.compile(
    r"(^สวัสดี|^หวัดดี|^ดีครับ|^ดีค่ะ|^hello\b|^hi\b|^hey\b|^yo\b"
    r"|เปลี่ยนเรื่อง|เรื่องใหม่|อีกเรื่อง|คนละเรื่อง|เรื่องอื่น|ขอถามอีก"
    r"|new (question|topic|thing)|different (topic|question|thing)"
    r"|something (different|new|else)|unrelated"
    r"|change (the )?(subject|topic)|(let'?s|let us)\s+(us\s+)?talk about)",
    re.IGNORECASE,
)


def _detect_continuity(user_msg: str, history: list) -> str:
    """Return 'continue' | 'new' | 'unsure' for whether user_msg continues the
    prior topic. Heuristic first; LLM fallback only when heuristic is uncertain.
    """
    # Not enough history to break from — always continue
    real_msgs = [h for h in history
                 if not h.get("content", "").startswith(("<tool_result", "[stay-on-task"))]
    if len(real_msgs) < 4:
        return "continue"

    msg = user_msg.strip()
    if _NEW_TOPIC_RE.search(msg):
        return "new"
    if _CONTINUE_RE.search(msg):
        return "continue"
    # Tiny messages without signals usually continue ("ok", "ทำต่อ", "yes").
    # Use char-length, not word count — Thai has no inter-word spaces so
    # split() badly undercounts; a 47-char Thai question must still reach
    # the LLM fallback rather than being short-circuited.
    if len(msg) < 25:
        return "continue"

    # ── LLM fallback ──────────────────────────────────────────────────────
    last_assistant = next(
        (h["content"] for h in reversed(history) if h.get("role") == "assistant"),
        "")[:400]
    probe = (
        "Decide if the NEW message continues the SAME topic as the previous "
        "assistant reply, or starts an UNRELATED new topic.\n\n"
        f"Previous assistant reply:\n{last_assistant}\n\n"
        f"New user message:\n{msg[:400]}\n\n"
        "Answer with EXACTLY one word: CONTINUE | NEW | UNSURE"
    )
    try:
        with console.status("[dim]checking topic continuity…", spinner="line"):
            reply, _ = generate_reply(
                [{"role": "user", "content": probe}], system="", max_tokens=8)
    except Exception:
        return "continue"   # fail-safe: don't disrupt on probe failure
    up = reply.strip().upper()
    # A small local model is unreliable here — never let it SILENTLY archive a
    # session. Only the explicit _NEW_TOPIC_RE above may return a hard "new"
    # (which auto-creates a session). An LLM "NEW" is downgraded to "unsure"
    # so the user is always asked before context is dropped.
    if "CONTINUE" in up:
        return "continue"
    if "NEW" in up:
        return "unsure"
    return "unsure"


# Keyword → tools mapping (safety net: router on small model often misses obvious tools)
TASK_KEYWORD_TOOLS = [
    # Report / document export → built-in make_report tool
    (re.compile(r"(ออกรายงาน|ทำรายงาน|ทำเอกสาร|สรุปเป็น(รายงาน|เอกสาร|pdf)|"
                r"เอกสารรายงาน|รายงานพร้อม|export.{0,12}(report|pdf)|"
                r"make.{0,6}report|generate.{0,6}report|write.{0,6}(a )?report|"
                r"report.{0,12}(pdf|document|file)|as (a )?pdf)", re.IGNORECASE),
     ["make_report"]),
    # Complex code/feature build → delegate to opencode (better tool calling than Gemma)
    (re.compile(r"(สร้าง|เขียน|save|write|create|generate|ทำ|ออก|build|develop|implement|refactor|fix)"
                r".{0,40}(ไฟล์|file|html|css|js|code|script|page|website|component|infographic|"
                r"feature|module|api|endpoint|class|function|component|รายงาน|report|ระบบ|"
                r"bug|error|issue|problem|ปัญหา|บัค|ผิดพลาด)",
                re.IGNORECASE),
     ["opencode", "write_file", "bash"]),
    # Debug/fix bug pattern
    (re.compile(r"(debug|fix|แก้|แก้ไข|repair).{0,30}(bug|error|issue|crash|"
                r"exception|test|failing|ปัญหา|บัค|ผิดพลาด|พัง)", re.IGNORECASE),
     ["opencode", "read_file", "bash"]),
    # Edit/patch existing file (targeted change — prefer edit_file over full rewrite)
    (re.compile(r"(แก้ไข|เปลี่ยน|อัปเดต|update|modify|patch|replace|edit|rename)"
                r".{0,40}(ไฟล์|file|content|เนื้อหา|บรรทัด|line|ข้อความ|text|ฟังก์ชัน|function|class)",
                re.IGNORECASE),
     ["edit_file", "read_file"]),
    # Delete file
    (re.compile(r"(ลบ|delete|remove|rm|unlink|ทิ้ง)"
                r".{0,20}(ไฟล์|file)", re.IGNORECASE),
     ["delete_file"]),
    # Read file
    (re.compile(r"(อ่าน|read|view|cat|show|ดู)"
                r".{0,20}(ไฟล์|file|content|เนื้อหา)", re.IGNORECASE),
     ["read_file"]),
    # Search
    (re.compile(r"(ค้น|search|grep|find|หา)"
                r".{0,30}(pattern|text|file|ไฟล์|คำว่า|ข้อความ)", re.IGNORECASE),
     ["grep", "list_dir"]),
    # List dir
    (re.compile(r"(list|ls|dir|ดู|รายการ).{0,20}(directory|folder|โฟลเดอร์|ไดเรกทอรี)", re.IGNORECASE),
     ["list_dir"]),
    # Run command / exec
    (re.compile(r"(รัน|run|execute|exec).{0,20}(command|script|คำสั่ง|bash|shell)", re.IGNORECASE),
     ["bash"]),
    # Web search (no specific URL → search first)
    (re.compile(r"(ค้น|หา|search|google|look up|find).{0,30}"
                r"(เว็บ|web|google|info|ข้อมูล|ข่าว|news|article)", re.IGNORECASE),
     ["web_search"]),
    (re.compile(r"(latest|recent|ล่าสุด|ปัจจุบัน|วันนี้|today|news|ข่าว|ราคา|price|"
                r"weather|อากาศ|update|review|รีวิว|เปรียบเทียบ|compare)", re.IGNORECASE),
     ["web_search"]),
    # Web fetch — only when a real URL is present in the task
    (re.compile(r"(fetch|download|ดาวน์โหลด|ดึง|โหลด|scrape).{0,30}"
                r"(https?://)", re.IGNORECASE),
     ["web_fetch"]),
    (re.compile(r"https?://[a-z0-9][a-z0-9.\-]+\.[a-z]{2,}", re.IGNORECASE),
     ["web_fetch"]),
    # Python
    (re.compile(r"(python|พายธอน|คำนวณ|calculate|compute|eval)", re.IGNORECASE),
     ["python"]),
    # Date/time direct queries (kept narrow: must mention 'date' or 'time' as a noun,
    # not just 'today' which already collides with web_search keywords above)
    (re.compile(
        r"(วันที่.*?(เท่าไหร่|อะไร|วันไหน)"
        r"|กี่โมง"
        r"|เวลา.*?(เท่าไหร่|ตอนนี้)"
        r"|what(\s+is\s+the)?\s+(date|time)"
        r"|current\s+(date|time|datetime|timestamp)"
        r"|today'?s\s+date"
        r"|วันนี้.*?วันที่.*?เท่าไหร่)",
        re.IGNORECASE),
     ["current_datetime"]),
]

def _keyword_augment(task: str, current: list[str]) -> tuple[list[str], list[str]]:
    """Returns (augmented_list, added_tools). Respects opencode flag."""
    out = list(current)
    added = []
    for rx, tools in TASK_KEYWORD_TOOLS:
        if rx.search(task):
            for t in tools:
                if t == "opencode" and not _FLAGS["opencode_enabled"]:
                    continue
                if t not in out and t in TOOLS:
                    out.append(t); added.append(t)
    return out, added


def smart_route(task: str, agents: dict, skills: dict) -> Optional[dict]:
    """Pre-pass: pick relevant tools/agent/skills.

    Fast path: if the keyword regex matcher already finds suitable tools and
    the task is short/simple (no agent/skill hint needed), skip the LLM call —
    on small local models the LLM router can take 8-10s per turn, while the
    regex pass is sub-millisecond.

    Falls through to the LLM router for: long prompts, tasks that may benefit
    from a persona, and anything the keyword pass couldn't classify.

    Returns dict {tools, agent, skills, added_by_keyword, fast_path} or None.
    """
    # ── Fast path: keyword-only routing ──────────────────────────────────
    kw_tools, _ = _keyword_augment(task, [])
    AGENT_HINT_RE = re.compile(
        r"\b(architect|design|spec|debug|refactor|implement|review|"
        r"frontend|backend|deploy|test|migrate|security|"
        r"ออกแบบ|พัฒนา|ตรวจสอบ|ทดสอบ|วิเคราะห์|รีวิว)\b",
        re.IGNORECASE,
    )
    short_query = len(task) < 200 and len(task.split()) < 30
    needs_persona = bool(AGENT_HINT_RE.search(task))
    if kw_tools and short_query and not needs_persona:
        # Honor the opencode-disabled flag exactly like the LLM path does
        if not _FLAGS["opencode_enabled"]:
            kw_tools = [t for t in kw_tools if t != "opencode"]
        return {
            "tools": kw_tools,
            "agent": None,
            "skills": [],
            "added_by_keyword": kw_tools,
            "fast_path": True,
        }

    # ── LLM router (slow path) ───────────────────────────────────────────
    tools_idx = _compact_index({k: {"desc": v["desc"]} for k, v in TOOLS.items()})
    agents_idx = _compact_index(agents)
    skills_idx = _compact_index(skills)
    router_msg = ROUTER_PROMPT.format(
        task=task, tools=tools_idx, agents=agents_idx, skills=skills_idx)
    try:
        with console.status("[dim]routing…", spinner="line"):
            reply, _ = generate_reply(
                [{"role": "user", "content": router_msg}],
                system="", max_tokens=200)
    except Exception:
        return None

    # Find JSON object containing "tools"
    sel = None
    m = ROUTER_JSON_RE.search(reply)
    if m:
        sel = _try_json(m.group(0))
    if not sel:
        dec = json.JSONDecoder()
        for i, ch in enumerate(reply):
            if ch != "{": continue
            try:
                obj, _ = dec.raw_decode(reply[i:])
                if isinstance(obj, dict) and "tools" in obj:
                    sel = obj; break
            except json.JSONDecodeError: continue
    if not sel:
        sel = {"tools": [], "agent": None, "skills": []}

    raw_tools = [t for t in (sel.get("tools") or []) if t in TOOLS]
    augmented, added = _keyword_augment(task, raw_tools)
    agent = sel.get("agent") if sel.get("agent") in agents else None
    skills_chosen = [s for s in (sel.get("skills") or []) if s in skills][:2]

    # Bias rules (only when opencode is enabled — otherwise let model use direct tools)
    if _FLAGS["opencode_enabled"]:
        EXECUTOR_AGENTS = {"frontend-dev", "backend-dev", "data-engineer", "ops",
                           "doc-writer", "tester", "debugger", "git-ops"}
        if agent in EXECUTOR_AGENTS and not augmented:
            augmented = ["opencode"]
            added.append("opencode<-agent-bias")
        ACTION_SKILLS = {"implement", "deploy", "debug", "debug-chain", "refactor",
                         "migrate", "performance", "security-audit"}
        if any(s in ACTION_SKILLS for s in skills_chosen) and not augmented:
            augmented = ["opencode"]
            added.append("opencode<-skill-bias")
    else:
        # opencode disabled → ensure no stray opencode from router LLM output
        augmented = [t for t in augmented if t != "opencode"]

    return {
        "tools": augmented,
        "agent": agent,
        "skills": skills_chosen,
        "added_by_keyword": added,
        "fast_path": False,
    }


# ╔════════════════════════════════════════════════════════════════════════╗
# ║ Session Store — SQLite-backed persistent conversations                ║
# ╚════════════════════════════════════════════════════════════════════════╝
import sqlite3
import uuid


class SessionStore:
    """Persist conversations across restarts. Resumable, searchable."""
    SCHEMA = """
    CREATE TABLE IF NOT EXISTS sessions (
      id            TEXT PRIMARY KEY,
      title         TEXT,
      model         TEXT,
      agent         TEXT,
      created_at    TEXT NOT NULL,
      updated_at    TEXT NOT NULL,
      message_count INTEGER DEFAULT 0,
      total_tokens  INTEGER DEFAULT 0,
      status        TEXT DEFAULT 'active'
    );
    CREATE TABLE IF NOT EXISTS messages (
      id            INTEGER PRIMARY KEY AUTOINCREMENT,
      session_id    TEXT NOT NULL,
      role          TEXT NOT NULL,
      content       TEXT,
      tool_call     TEXT,
      tool_result   TEXT,
      tokens        INTEGER,
      is_compacted  INTEGER DEFAULT 0,
      created_at    TEXT NOT NULL,
      FOREIGN KEY (session_id) REFERENCES sessions(id)
    );
    CREATE INDEX IF NOT EXISTS idx_msg_session ON messages(session_id, created_at);
    CREATE INDEX IF NOT EXISTS idx_sess_updated ON sessions(updated_at DESC);
    """

    def __init__(self, db_path: Path):
        self.db_path = db_path
        db_path.parent.mkdir(parents=True, exist_ok=True)
        self.conn = sqlite3.connect(str(db_path), check_same_thread=False)
        self.conn.row_factory = sqlite3.Row
        self.conn.executescript("PRAGMA journal_mode=WAL; PRAGMA foreign_keys=ON;")
        self.conn.executescript(self.SCHEMA)
        self.conn.commit()

    # ── Sessions ─────────────────────────────────────────────────────────
    def create_session(self, model: str, agent: str | None = None, title: str = "") -> str:
        sid = uuid.uuid4().hex[:12]
        now = datetime.now(timezone.utc).isoformat(timespec="seconds")
        self.conn.execute(
            "INSERT INTO sessions(id,title,model,agent,created_at,updated_at) VALUES(?,?,?,?,?,?)",
            (sid, title or "(untitled)", model, agent, now, now))
        self.conn.commit()
        return sid

    def list_sessions(self, limit: int = 20) -> list[dict]:
        rows = self.conn.execute(
            "SELECT id, title, model, agent, message_count, total_tokens, updated_at, status "
            "FROM sessions WHERE status='active' ORDER BY updated_at DESC LIMIT ?",
            (limit,)).fetchall()
        return [dict(r) for r in rows]

    def update_title(self, sid: str, title: str):
        self.conn.execute("UPDATE sessions SET title=?, updated_at=? WHERE id=?",
                          (title[:120], datetime.now(timezone.utc).isoformat(timespec="seconds"), sid))
        self.conn.commit()

    def archive(self, sid: str):
        self.conn.execute("UPDATE sessions SET status='archived' WHERE id=?", (sid,))
        self.conn.commit()

    # ── Messages ─────────────────────────────────────────────────────────
    def add_message(self, sid: str, role: str, content: str = "",
                    tool_call: dict | None = None, tool_result: str | None = None,
                    tokens: int = 0):
        now = datetime.now(timezone.utc).isoformat(timespec="seconds")
        self.conn.execute(
            "INSERT INTO messages(session_id,role,content,tool_call,tool_result,tokens,created_at) "
            "VALUES(?,?,?,?,?,?,?)",
            (sid, role, content,
             json.dumps(tool_call, ensure_ascii=False) if tool_call else None,
             tool_result, tokens, now))
        self.conn.execute(
            "UPDATE sessions SET updated_at=?, message_count=message_count+1, "
            "total_tokens=total_tokens+? WHERE id=?",
            (now, tokens, sid))
        self.conn.commit()

    def load_messages(self, sid: str, include_compacted: bool = False) -> list[dict]:
        q = "SELECT role, content, tool_call, tool_result, tokens, is_compacted FROM messages WHERE session_id=?"
        if not include_compacted:
            q += " AND is_compacted=0"
        q += " ORDER BY created_at ASC, id ASC"
        rows = self.conn.execute(q, (sid,)).fetchall()
        out = []
        for r in rows:
            d = {"role": r["role"], "content": r["content"] or ""}
            if r["tool_call"]: d["tool_call"] = json.loads(r["tool_call"])
            if r["tool_result"] is not None: d["tool_result"] = r["tool_result"]
            out.append(d)
        return out

    def get_session(self, sid: str) -> dict | None:
        r = self.conn.execute("SELECT * FROM sessions WHERE id=?", (sid,)).fetchone()
        return dict(r) if r else None

    def stats(self) -> dict:
        n_sess = self.conn.execute("SELECT COUNT(*) FROM sessions").fetchone()[0]
        n_msg  = self.conn.execute("SELECT COUNT(*) FROM messages").fetchone()[0]
        return {"sessions": n_sess, "messages": n_msg, "db_path": str(self.db_path)}

    def close(self):
        try: self.conn.close()
        except: pass


# ╔════════════════════════════════════════════════════════════════════════╗
# ║ Circuit Breaker — fail-fast for repeatedly-failing tools              ║
# ╚════════════════════════════════════════════════════════════════════════╝
class CircuitBreaker:
    """Per-tool failure tracker. Opens after N consecutive fails within window.

    States:
      closed   = healthy, allow calls
      open     = recently failed, reject for cooldown_s
      half_open= probe with 1 call, if ok → closed, if fail → open
    """
    def __init__(self, threshold: int = 3, cooldown_s: float = 15.0):
        self.threshold = threshold
        self.cooldown_s = cooldown_s
        self._state: dict[str, dict] = {}

    def _slot(self, name: str) -> dict:
        return self._state.setdefault(name, {
            "state": "closed", "fails": 0, "opened_at": 0.0,
            "total_calls": 0, "total_fails": 0,
        })

    def can_call(self, name: str) -> tuple[bool, str]:
        s = self._slot(name)
        if s["state"] == "open":
            since = time.time() - s["opened_at"]
            if since >= self.cooldown_s:
                s["state"] = "half_open"
                return True, "half_open"
            remain = self.cooldown_s - since
            return False, f"open (retry in {remain:.0f}s)"
        return True, s["state"]

    def record_success(self, name: str):
        s = self._slot(name)
        s["total_calls"] += 1
        s["fails"] = 0
        if s["state"] != "closed":
            s["state"] = "closed"

    def record_failure(self, name: str):
        s = self._slot(name)
        s["total_calls"] += 1
        s["total_fails"] += 1
        s["fails"] += 1
        if s["state"] == "half_open":
            s["state"] = "open"; s["opened_at"] = time.time()
        elif s["fails"] >= self.threshold:
            s["state"] = "open"; s["opened_at"] = time.time()

    def snapshot(self) -> dict:
        out = {}
        now = time.time()
        for name, s in self._state.items():
            cool = max(0, self.cooldown_s - (now - s["opened_at"])) if s["state"] == "open" else 0
            out[name] = {
                "state":         s["state"],
                "fails_in_row":  s["fails"],
                "total_calls":   s["total_calls"],
                "total_fails":   s["total_fails"],
                "cooldown_left": int(cool),
            }
        return out

    def reset(self, name: str | None = None):
        if name: self._state.pop(name, None)
        else:    self._state.clear()


# Global breaker (per-process)
_BREAKER = CircuitBreaker()


# Tools allowed for the remainder of the current turn (cleared at each new
# user prompt). Distinct from `allow_dangerous` which is session-wide.
_TURN_ALLOWED_TOOLS: set = set()


def _tool_needs_approval(call: dict, allow_dangerous: set) -> bool:
    """Quick check: will execute_tool block on a y/n prompt?"""
    name = call.get("name")
    if name not in TOOLS:
        return False
    if name == "opencode" and not _FLAGS["opencode_enabled"]:
        return False
    if name in allow_dangerous:
        return False
    if name in _TURN_ALLOWED_TOOLS:
        return False
    return TOOL_RISK.get(name, "ask") == "ask"


def _summarize_args_for_approval(args: dict, *, max_value_chars: int = 160) -> str:
    """Pretty-print tool args but collapse long string values to a tagged preview."""
    pretty = {}
    for k, v in args.items():
        if isinstance(v, str) and len(v) > max_value_chars:
            preview = v[:max_value_chars].replace("\n", "\\n")
            pretty[k] = f"<{len(v):,} chars, {v.count(chr(10))+1} lines> {preview}…"
        else:
            pretty[k] = v
    return json.dumps(pretty, ensure_ascii=False, indent=2)


def _action_summary(name: str, args: dict) -> str:
    """One-line plain-language description of what the tool is about to do.
    Surfaces the most relevant arg per tool so users don't have to parse JSON."""
    if name == "edit_file":
        path = args.get("path", "?")
        old = (args.get("old_str") or "")[:60].replace("\n", "\\n")
        new = (args.get("new_str") or "")[:60].replace("\n", "\\n")
        return f"Edit [cyan]{path}[/]\n  [dim]replace:[/] {old!r}\n  [dim]with:[/]    {new!r}"
    if name == "delete_file":
        path = args.get("path", "?")
        return f"[bold red]Delete[/] [cyan]{path}[/]  [dim](permanent — cannot be undone)[/]"
    if name == "write_file":
        path = args.get("path", "?")
        content = args.get("content", "")
        size = len(content) if isinstance(content, str) else 0
        lines = content.count("\n") + 1 if content else 0
        return f"Write [cyan]{path}[/]  [dim]({size:,} bytes, {lines} lines)[/]"
    if name == "bash":
        cmd = args.get("command", "?")
        oneline = cmd.replace("\n", " ⏎ ")
        if len(oneline) > 200:
            oneline = oneline[:200] + "…"
        return f"Run shell command:\n  [bold white]$ {oneline}[/]"
    if name == "python":
        code = args.get("code", "?")
        first_lines = "\n".join(code.split("\n")[:5])
        more = code.count("\n") - 4
        suffix = f"\n  [dim]… +{more} more lines[/]" if more > 0 else ""
        return f"Run Python (sandboxed, 10s timeout):\n[white]{first_lines}[/]{suffix}"
    if name == "opencode":
        prompt = (args.get("prompt") or "")[:120]
        agent = args.get("agent", "?")
        return f"Delegate to opencode [magenta]{agent}[/]:  [dim]{prompt}…[/]"
    return f"Run [cyan]{name}[/] with args:\n{_summarize_args_for_approval(args)}"


def _detect_extra_risk(name: str, args: dict) -> Optional[str]:
    """Return a one-line warning string if the call looks especially dangerous
    (and should be displayed in red regardless of base tier)."""
    if name == "bash":
        cmd = args.get("command", "") or ""
        if _DANGEROUS_BASH_RE.search(cmd):
            return "⛔ DANGEROUS PATTERN: command matches rm -rf / sudo / chmod 777 / fork-bomb / pipe-to-shell"
    if name in ("write_file", "delete_file"):
        path = str(args.get("path", ""))
        if any(path.startswith(p) for p in ("/etc/", "/usr/", "/bin/", "/sbin/", "/System/")):
            action = "writing to" if name == "write_file" else "deleting"
            return f"⛔ SYSTEM PATH: {action} {path} could break the OS"
    return None


def _call_fingerprint(call: dict) -> str:
    """8-char hash of (name, args) for visual comparison across approval panels.
    Same hash on two panels = identical call (dedupe bug). Different hash =
    args genuinely differ (e.g. trailing newline in content, case difference)."""
    import hashlib
    try:
        payload = (call.get("name", "") + "|" +
                   json.dumps(call.get("arguments", {}), sort_keys=True,
                              ensure_ascii=False))
    except (TypeError, ValueError):
        payload = repr(call)
    return hashlib.sha1(payload.encode("utf-8", errors="replace")).hexdigest()[:8]


def request_tool_approval(call: dict, allow_dangerous: set) -> bool:
    """Risk-tiered approval panel with action-oriented summary + extended option
    menu. Mutates `allow_dangerous` on 'always'. Returns True if approved.

    UX layers (top to bottom on the user's screen):
      1. Title with risk icon + tier label + 8-char fingerprint  [⚠ HIGH RISK #a4f3b2]
      2. One-line plain action summary       Run shell command:  $ ls -la /tmp
      3. Optional danger warning             ⛔ DANGEROUS PATTERN…
      4. Footer hint                         Type y / n / a (always) / ? (full args)

    Fingerprint helps when user sees seemingly-duplicate approvals: same hash
    = real dup (bug to file), different hash = args differ subtly.
    """
    name = call.get("name") or "?"
    args = call.get("arguments", {}) or {}
    tier = TOOL_RISK_TIER.get(name, "medium")
    style = _RISK_STYLE[tier]
    extra_warn = _detect_extra_risk(name, args)
    # Escalate visuals if danger pattern hit
    if extra_warn:
        style = _RISK_STYLE["high"]

    lines = [_action_summary(name, args)]
    if extra_warn:
        lines.append(f"\n[bold red]{extra_warn}[/]")

    fp = _call_fingerprint(call)
    console.print(Panel(
        "\n".join(lines),
        title=f"{style['icon']}  TOOL APPROVAL  [bold]{name}[/]  "
              f"[{style['color']}]\\[{style['label']} RISK][/]  "
              f"[dim]#{fp}[/]",
        title_align="left",
        border_style=style["color"],
        subtitle="[dim]y=yes  n=no  a=always(session)  t=this-turn  ?=show full args[/]",
        subtitle_align="right",
    ))

    while True:
        ans = ask_yn("approve?", default="n", allow_always=True,
                     allow_help=True, allow_turn=True)
        if ans == "always":
            allow_dangerous.add(name)
            console.print(f"  [dim]✓ '{name}' added to session allow-list[/]")
            return True
        if ans == "turn":
            _TURN_ALLOWED_TOOLS.add(name)
            console.print(f"  [dim]✓ '{name}' allowed for the rest of this turn "
                          f"(cleared at next user prompt)[/]")
            return True
        if ans == "y":
            return True
        if ans == "help":
            console.print(Panel(
                _summarize_args_for_approval(args, max_value_chars=10_000),
                title=f"full args — {name}  [dim]#{_call_fingerprint(call)}[/]",
                border_style="dim"))
            continue
        return False  # 'n'


def execute_tool(call: dict, allow_dangerous: set,
                 pre_approved: bool = False) -> tuple[str, bool]:
    """Run a tool. Approval is expected to have been granted upstream via
    `_tool_needs_approval` + `request_tool_approval`; the in-function check
    below is defense-in-depth for callers that didn't pre-flight.
    Pass pre_approved=True when agent_turn already handled approval to avoid
    showing the panel twice (once upstream + once here as defense-in-depth)."""
    name = call.get("name"); args = call.get("arguments", {}) or {}
    if name not in TOOLS:
        return f"Unknown tool: {name}", False
    if name == "opencode" and not _FLAGS["opencode_enabled"]:
        return ("opencode delegation is currently disabled. "
                "Use direct tools (write_file, bash, read_file) instead, "
                "or run `/opencode on` to enable."), False

    # Circuit breaker check
    ok, state = _BREAKER.can_call(name)
    if not ok:
        console.print(f"[red]⛔ circuit breaker {state} for [bold]{name}[/]:[/] "
                      f"[dim](too many recent failures; reset with /breakers reset {name})[/]")
        return f"[circuit-open] tool {name} disabled — {state}", False

    # Defense-in-depth approval check — skipped when pre_approved=True (caller
    # already ran request_tool_approval) or when tool is in allow_dangerous.
    risk = TOOL_RISK.get(name, "ask")
    if risk == "ask" and name not in allow_dangerous and not pre_approved:
        if not request_tool_approval(call, allow_dangerous):
            return "User denied execution", False
    try:
        result = str(TOOLS[name]["fn"](**args))
        # Heuristic: tool returned but content indicates failure
        if any(marker in result for marker in
               ("[opencode] timeout", "[opencode] CLI not found",
                "[opencode exit ", "[cancelled by user")):
            _BREAKER.record_failure(name)
            if state == "half_open":
                console.print(f"[red]  ↳ probe failed — circuit re-opened for {name}[/]")
        else:
            _BREAKER.record_success(name)
        return result, True
    except Exception as e:
        _BREAKER.record_failure(name)
        return f"Tool error: {type(e).__name__}: {e}", False

# ╔════════════════════════════════════════════════════════════════════════╗
# ║ Token counting + context inspection + compaction                      ║
# ╚════════════════════════════════════════════════════════════════════════╝
def _get_tokenizer(processor):
    """Best-effort: grab a tokenizer.encode() from MLX processor."""
    if hasattr(processor, "tokenizer"):
        tk = processor.tokenizer
        if hasattr(tk, "encode"): return tk.encode
    if hasattr(processor, "encode"):
        return processor.encode
    return None

def native_ctx() -> int:
    """Native context window of the currently-loaded model (MLX or Ollama)."""
    if mm.backend == "ollama":
        return int(mm.ollama_meta.get("ctx") or _OLLAMA_DEFAULT_CTX)
    return MODEL_CONTEXT.get(mm.name, 32_000)


def count_tokens(text: str, processor) -> int:
    enc = _get_tokenizer(processor)
    if enc:
        try: return len(enc(text))
        except Exception: pass
    return max(1, len(text) // 3)  # rough fallback

def measure_context(history: list[dict], system: str, processor) -> dict:
    sys_t = count_tokens(system, processor) if system else 0
    per_msg = [count_tokens(h.get("content", ""), processor) for h in history]
    hist_t = sum(per_msg)
    total_in = sys_t + hist_t
    return {
        "system_tokens":  sys_t,
        "history_tokens": hist_t,
        "history_msgs":   len(history),
        "per_msg":        per_msg,
        "total_in":       total_in,
    }

def compact_history(history: list[dict], processor, keep_recent: int = 4) -> tuple[list[dict], int]:
    """Summarize old turns using the active model, keep last N intact.

    Returns (new_history, num_compacted_msgs).
    """
    if len(history) <= keep_recent:
        return history, 0
    to_sum = history[:-keep_recent]
    recent = history[-keep_recent:]
    snippets = []
    for h in to_sum:
        role = h.get("role", "?")
        body = h.get("content", "")[:600]
        snippets.append(f"[{role}]\n{body}")
    summary_input = (
        "Summarize this prior conversation into a compact paragraph (200 words max). "
        "Preserve: user goals, decisions made, files created/read, key tool results, errors. "
        "Drop: small talk, repetitive content.\n\n"
        + "\n\n".join(snippets)
    )
    summary, _ = generate_reply(
        [{"role": "user", "content": summary_input}],
        system="", max_tokens=350,
    )
    new_hist = [
        {"role": "user", "content": f"[Summary of {len(to_sum)} earlier messages]\n{summary.strip()}"},
        {"role": "assistant", "content": "Got it — continuing from there."},
    ] + recent
    return new_hist, len(to_sum)


# ╔════════════════════════════════════════════════════════════════════════╗
# ║ Ollama discovery (optional — only if Ollama is running locally)       ║
# ╚════════════════════════════════════════════════════════════════════════╝
# Holds discovered Ollama models keyed by full alias (e.g. "ol:gemma4:e4b"):
#   {alias: {"model": <tag>, "ctx": <int>, "size_gb": float, "params": str}}
OLLAMA_MODELS: dict[str, dict] = {}


def _ensure_ollama(host: str = OLLAMA_HOST, start_wait: float = 5.0) -> bool:
    """Return True if Ollama is reachable, auto-starting it if not.

    Spawns `ollama serve` in the background (stdout/stderr suppressed) and
    waits up to *start_wait* seconds for the port to open.  If the binary is
    not on PATH or the port still does not respond, returns False silently so
    callers can fall back gracefully.
    """
    try:
        urlopen(Request(f"{host}/api/tags", headers=_ollama_headers()), timeout=2)
        return True
    except Exception:
        pass
    if not shutil.which("ollama"):
        return False
    console.print("[dim]🦙 Ollama not running — starting `ollama serve` …[/]")
    try:
        subprocess.Popen(
            ["ollama", "serve"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    except OSError:
        return False
    deadline = time.time() + start_wait
    while time.time() < deadline:
        time.sleep(0.5)
        try:
            urlopen(Request(f"{host}/api/tags", headers=_ollama_headers()), timeout=1)
            console.print("[green]✓[/] Ollama started")
            return True
        except Exception:
            pass
    console.print("[yellow]⚠ Ollama did not respond in time — continuing without it[/]")
    return False


def discover_ollama_models(host: str = OLLAMA_HOST, timeout: float = 2.0) -> dict[str, dict]:
    """Probe Ollama `/api/tags`. Returns map alias→metadata (empty on failure).

    Alias convention: `ol:<tag>` so user types `/model ol:gemma4:e4b` and there
    is zero ambiguity with the static MLX aliases (gemma/qwen-vl/qwen3).
    Context window is inferred from family heuristics — accurate enough for
    auto-compact decisions; users can override per-session by editing the
    MODEL_CONTEXT dict at runtime if needed.
    """
    _ensure_ollama(host)
    try:
        req = Request(f"{host}/api/tags", headers=_ollama_headers())
        with urlopen(req, timeout=timeout) as r:
            data = json.loads(r.read().decode("utf-8", errors="replace"))
    except Exception:
        return {}
    out: dict[str, dict] = {}
    for m in data.get("models", []):
        tag = m.get("name") or m.get("model")
        if not tag:
            continue
        family = (m.get("details") or {}).get("family", "")
        ctx = _OLLAMA_CTX_BY_FAMILY.get(family, _OLLAMA_DEFAULT_CTX)
        out[f"ol:{tag}"] = {
            "model":   tag,
            "ctx":     ctx,
            "size_gb": (m.get("size", 0) or 0) / 1e9,
            "params":  (m.get("details") or {}).get("parameter_size", ""),
            "family":  family,
        }
    return out


def _is_ollama_alias(name: str) -> bool:
    return name.startswith("ol:")


def _ollama_ps(host: str = OLLAMA_HOST, timeout: float = 2.0) -> dict:
    """Return {model_tag: context_length} for models currently resident in
    Ollama (via /api/ps). Empty dict on any failure — best-effort probe."""
    try:
        req = Request(f"{host}/api/ps", headers=_ollama_headers())
        with urlopen(req, timeout=timeout) as r:
            data = json.loads(r.read().decode("utf-8", errors="replace"))
    except Exception:
        return {}
    out: dict = {}
    for m in data.get("models", []):
        tag = m.get("model") or m.get("name")
        ctx = m.get("context_length")
        if tag and ctx:
            out[tag] = int(ctx)
    return out


def _ollama_resolve_ctx(meta: dict) -> int:
    """Choose the num_ctx to request for an Ollama model, adapting to reality so
    we don't force an expensive model RELOAD:

      1. explicit env override (THMES_OLLAMA_NUM_CTX) always wins
      2. else if the model is ALREADY resident → reuse its loaded context_length
         (requesting the same value keeps it loaded; a different value evicts +
         reloads the whole model, which on a multi-GB model can take minutes)
      3. else our family-heuristic ctx (meta['ctx'])

    Writes the result back to meta['ctx'] so native_ctx()/_ollama_chat stay
    consistent. Provider-agnostic in spirit: 'don't fight what's already loaded'."""
    if _OLLAMA_NUM_CTX_OVERRIDE:
        meta["ctx"] = _OLLAMA_NUM_CTX_OVERRIDE
        return _OLLAMA_NUM_CTX_OVERRIDE
    loaded = _ollama_ps().get(meta.get("model", ""))
    if loaded:
        if loaded != meta.get("ctx"):
            console.print(f"[dim]  ↳ {meta['model']} already resident at ctx "
                          f"{loaded:,} — reusing it (avoids a reload)[/]")
        meta["ctx"] = loaded
        return loaded
    return int(meta.get("ctx") or _OLLAMA_DEFAULT_CTX)


def _ollama_warmup(meta: dict, ctx: int) -> bool:
    """Fire a 1-token generation so the model loads NOW (at our num_ctx) rather
    than on the user's first real message. Uses the generous load timeout.
    Returns True if the server responded. Best-effort (never raises)."""
    try:
        payload = json.dumps({
            "model": meta["model"],
            "messages": [{"role": "user", "content": "hi"}],
            "stream": False,
            "options": {"num_predict": 1, "num_ctx": int(ctx)},
        }).encode("utf-8")
        req = Request(f"{OLLAMA_HOST}/api/chat", data=payload,
                      headers=_ollama_headers(), method="POST")
        with urlopen(req, timeout=OLLAMA_LOAD_TIMEOUT) as r:
            r.read()
        return True
    except Exception:
        return False


# ╔════════════════════════════════════════════════════════════════════════╗
# ║ Model manager                                                         ║
# ╚════════════════════════════════════════════════════════════════════════╝
class ModelManager:
    def __init__(self):
        self.name = None; self.model = None; self.processor = None
        self.is_vlm = True
        self.backend = "mlx-vlm"   # "mlx-vlm" | "mlx-lm" | "ollama"
        self.ollama_meta: dict = {}

    def unload(self, *, quiet: bool = False) -> None:
        """Free the currently-loaded model. Idempotent.

        MLX:    drop refs to model/processor, clear MLX metal cache, force gc.
                Python can't fully control Metal-backed allocations, but this
                releases the bulk of the working set and lets the next load
                avoid OOM on 16-32GB Macs.
        Ollama: POST /api/generate with keep_alive=0 to tell the server to
                evict the model from memory (best-effort, network may fail).
        """
        if self.name is None:
            return
        prev_name = self.name
        prev_backend = self.backend
        t0 = time.time()

        if prev_backend == "ollama" and self.ollama_meta.get("model"):
            try:
                payload = json.dumps({
                    "model": self.ollama_meta["model"],
                    "keep_alive": 0,
                }).encode("utf-8")
                req = Request(f"{OLLAMA_HOST}/api/generate", data=payload,
                              headers=_ollama_headers(), method="POST")
                urlopen(req, timeout=5).read()
            except Exception:
                pass   # best-effort — server may already have evicted

        if self.model is not None or self.processor is not None:
            self.model = None
            self.processor = None
            try:
                import mlx.core as mx
                if hasattr(mx, "metal") and hasattr(mx.metal, "clear_cache"):
                    mx.metal.clear_cache()
            except Exception:
                pass
            import gc
            gc.collect()

        self.name = None
        self.ollama_meta = {}
        if not quiet:
            console.print(f"[dim]🗑 unloaded {prev_name} ({prev_backend}) "
                          f"in {time.time()-t0:.1f}s[/]")

    def load(self, name: str):
        if self.name == name: return
        # Free the previous model before pulling in the next one — avoids
        # double-resident memory on small machines.
        if self.name is not None:
            self.unload(quiet=False)

        if _is_ollama_alias(name):
            # Ollama: no local model load — just verify reachability + remember tag
            meta = OLLAMA_MODELS.get(name)
            if not meta:
                # Allow on-demand selection of a tag we haven't discovered yet
                # (e.g. user typed an explicit "ol:newmodel:7b")
                tag = name[3:]
                meta = {"model": tag, "ctx": _OLLAMA_DEFAULT_CTX,
                        "size_gb": 0, "params": "", "family": ""}
            with console.status(f"[cyan]Selecting Ollama model {meta['model']} …", spinner="dots"):
                t = time.time()
                if not _ensure_ollama():
                    console.print(f"[red]✗ Ollama unreachable at {rich_escape(OLLAMA_HOST)}[/]  "
                                  f"[dim]Start with: ollama serve[/]")
                    return
            # Cloud models (':cloud' / '-cloud' tag) run on ollama.com and need auth.
            if _is_cloud_model(meta["model"]):
                authed = "via API key" if OLLAMA_API_KEY else "via `ollama signin`"
                console.print(f"[dim]  ☁ cloud model — requires Ollama auth "
                              f"({authed}); 401 means not signed in[/]")
            self.model = None; self.processor = None
            self.is_vlm = False
            self.backend = "ollama"
            self.ollama_meta = meta
            self.name = name
            # Adapt num_ctx to any already-resident instance (avoid reload churn)…
            ctx = _ollama_resolve_ctx(meta)
            # …then warm the model at that ctx so the first real message is fast
            # and doesn't risk a cold-load timeout.
            warm_note = ""
            if _FLAGS.get("ollama_warmup", True) and not _is_cloud_model(meta["model"]):
                with console.status(
                        f"[cyan]Warming {meta['model']} (ctx {ctx:,})…", spinner="dots"):
                    ok = _ollama_warmup(meta, ctx)
                if not ok:
                    warm_note = ("  [yellow](warmup timed out — first message may be "
                                 "slow; raise THMES_OLLAMA_LOAD_TIMEOUT)[/]")
            console.print(f"[green]✓[/] Selected [bold]{meta['model']}[/]  "
                          f"[dim]({meta.get('params','?')} · {meta.get('size_gb',0):.1f}GB · "
                          f"ctx {ctx:,})[/] in {time.time()-t:.1f}s{warm_note}")
            return
        # MLX path
        repo = MODELS[name]
        with console.status(f"[cyan]Loading {repo} …", spinner="dots"):
            t = time.time()
            try:
                if name == "qwen3":
                    from mlx_lm import load
                    self.model, self.processor = load(repo)
                    self.is_vlm = False
                    self.backend = "mlx-lm"
                else:
                    from mlx_vlm import load
                    self.model, self.processor = load(repo)
                    self.is_vlm = True
                    self.backend = "mlx-vlm"
            except ImportError as exc:
                pkg = "mlx_lm" if name == "qwen3" else "mlx_vlm"
                console.print(
                    f"[red]✗ MLX not available ({pkg}): {exc}[/]\n"
                    f"  This environment was set up for Ollama-only use.\n"
                    f"  Either re-run setup-mac.sh on a machine with Apple Silicon + MLX,\n"
                    f"  or pick an Ollama model ( ol:... ) at the model picker."
                )
                return
            self.ollama_meta = {}
            self.name = name
        console.print(f"[green]✓[/] Loaded [bold]{repo}[/] in {time.time()-t:.1f}s")

mm = ModelManager()


def _research_system_block(query: str, depth: int = 3) -> str:
    """System prompt override for /research turns.

    Instructs the model to search multiple sources (TH + EN), cross-validate
    conflicting claims, and cite every source with date. web_search and
    web_fetch are pre-approved by the /research handler so the model can
    call them freely without waiting for user approval.
    """
    dt = current_datetime_context()
    return (
        f"{dt}\n\n"
        f"[Research Mode — autonomous multi-source investigation]\n"
        f"Goal: answer \"{query}\" using ≥{depth} unique sources (TH + EN).\n\n"
        f"Strategy you MUST follow step by step:\n"
        f"1. PLAN: write 3-4 query angles for \"{query}\" before searching\n"
        f"   (Thai phrasing, English phrasing, abbreviation/alternate name, broader term)\n\n"
        f"2. SEARCH — run all of these (in parallel where possible):\n"
        f"   a) web_search(<th-query>,    region=\"th-th\", mode=\"news\", timelimit=\"w\")\n"
        f"   b) web_search(<en-query>,    region=\"us-en\", mode=\"news\", timelimit=\"w\", auto_fetch=True)\n"
        f"   c) web_search(<broad-query>, region=\"wt-wt\", mode=\"text\")\n"
        f"   If any search returns 0 results → retry with different phrasing or drop timelimit\n\n"
        f"3. FETCH: web_fetch(url, max_chars=4000) for the top 1-2 most relevant URLs found\n\n"
        f"4. CROSS-VALIDATE: compare TH vs EN sources — report BOTH if they disagree\n\n"
        f"5. Accept only content with a clear author or date — skip promotional/sponsored text\n\n"
        f"6. Keep going until you have ≥{depth} unique domains cited\n\n"
        f"7. Final answer (in the user's language):\n"
        f"   - Lead with key fact + date\n"
        f"   - Cite each claim: [domain.com] \"fact\" — Date\n"
        f"   - Note any TH/EN discrepancy\n\n"
        f"web_search and web_fetch are pre-approved — call them freely and immediately.\n"
        f"Do NOT ask the user for permission or clarification. Research and report."
    )


# Conservative trigger for auto plan-mode — only clearly multi-step intent.
_PLAN_TRIGGER_RE = re.compile(
    r"(วางแผน|เป็นขั้นเป็นตอน|ทีละขั้น|step.?by.?step|หลายขั้นตอน|multi.?step"
    r"|สร้างระบบ|ทำระบบ|พัฒนาระบบ"
    r"|build (a |an |the )?(system|app|application|pipeline|website|backend|api)"
    r"|implement (a |an |the )?(full|complete|whole|entire)"
    r"|set ?up (a |an |the )?(project|system|pipeline))",
    re.IGNORECASE,
)

_PLAN_STEP_RE = re.compile(r"^\s*(?:\d+[.)]|[-*•])\s+(.+?)\s*$")


def _plan_system_block() -> str:
    """System prompt for the plan-drafting pass — produce a numbered plan,
    no tool calls, no code."""
    return (
        "You are in PLANNING mode. Do NOT call tools or write code yet.\n"
        "Produce a concise, numbered plan to accomplish the user's request.\n"
        "Rules:\n"
        "  - 2 to 7 steps, each ONE concrete action starting with a verb\n"
        "  - Format strictly: one step per line as '1. <step>'\n"
        "  - No preamble, no commentary, no markdown headers — just the list\n"
        "  - Keep each step short (a single line)\n"
        "Output ONLY the numbered list."
    )


def _parse_plan_steps(text: str) -> list:
    """Extract step strings from a numbered/bulleted plan reply."""
    steps = []
    for line in text.splitlines():
        m = _PLAN_STEP_RE.match(line)
        if m:
            step = m.group(1).strip()
            if step and len(step) > 2:
                steps.append(step[:200])
    return steps


def _research_hint_block(analysis: "PromptAnalysis | None" = None) -> str:
    """Lightweight multi-source nudge auto-injected into NORMAL chat when a
    factual/current-info query is detected (via _RESEARCH_TRIGGER_RE).

    When a PromptAnalysis is provided, uses its pre-built search_angles for
    more targeted queries instead of generic TH/EN/broad placeholders."""

    # Build concrete query examples from analysis if available
    if analysis and analysis.search_angles:
        angles = analysis.search_angles
        q_a = angles[0] if len(angles) > 0 else "ราคา X วันนี้"
        q_b = angles[1] if len(angles) > 1 else "X price today"
        q_c = angles[2] if len(angles) > 2 else "X latest news"
        q_d = angles[3] if len(angles) > 3 else None
        angle_block = (
            f'   A) web_search("{q_a}", region="th-th", mode="news", timelimit="w")\n'
            f'   B) web_search("{q_b}", region="us-en", mode="news", timelimit="w")\n'
            f'   C) web_search("{q_c}", region="wt-wt", mode="text")\n'
        )
        if q_d:
            angle_block += (
                f'   D) web_search("{q_d}", region="th-th", mode="text")\n'
            )
    else:
        angle_block = (
            '   A) web_search("ราคา X วันนี้", region="th-th", mode="news", timelimit="w")\n'
            '   B) web_search("X price today", region="us-en", mode="news", timelimit="w")\n'
            '   C) web_search("X latest", region="wt-wt", mode="text")\n'
        )

    return (
        "[MANDATORY SEARCH PROTOCOL — execute before answering]\n"
        "This question involves current data (prices, news, rates, live info).\n"
        "Your training data is STALE — do NOT answer from memory.\n\n"
        "START with these parallel searches (emit all at once in one response):\n\n"
        + angle_block +
        "\n"
        "AFTER reviewing results:\n"
        "• If information is incomplete, outdated, or contradictory → run MORE searches.\n"
        "  Use different angles: follow-up queries, specific sources, web_fetch on URLs.\n"
        "• Keep searching until you have COMPREHENSIVE, up-to-date information.\n"
        "• Hard ceiling: 30 total tool calls. Stop only when content is thorough.\n\n"
        "FETCH: web_fetch(url, max_chars=4000) on 1-2 most relevant URLs per search round.\n\n"
        "SYNTHESIZE: combine all findings, note source dates, answer in user's language.\n\n"
        "DO NOT answer from memory. DO NOT stop after just the initial searches if data is thin."
    )


def _stringify_history_for_vlm(history: list[dict], system: str) -> str:
    """Flatten conversation history into a single role-tagged prompt.

    mlx_vlm.apply_chat_template takes one text string (not a messages list), so
    multi-turn / agent-loop context must be serialized here. Without this, only
    the most recent message reaches the model — which breaks tool-call chains
    (model gets a <tool_result> with no memory of why it was called) and the
    max-iters synthesis prompt (model can't see prior tool results).
    """
    parts = []
    if system:
        parts.append(f"[System]\n{system}")
    for h in history:
        role = h.get("role", "user")
        content = h.get("content", "")
        label = "User" if role == "user" else "Assistant" if role == "assistant" else role.title()
        parts.append(f"[{label}]\n{content}")
    # Cue the model to produce the next assistant turn
    parts.append("[Assistant]\n")
    return "\n\n".join(parts)


def _is_cloud_model(tag: str) -> bool:
    """True for Ollama *cloud* tags (run on ollama.com, not locally).

    Cloud tags come in two shapes and BOTH must be caught:
      • ':cloud' suffix          — e.g. glm-4.6:cloud, minimax-m2:cloud
      • '<size>-cloud' suffix    — e.g. gpt-oss:120b-cloud, qwen3-coder:480b-cloud
    A naive `':cloud' in tag` misses the second shape (the 'cloud' is preceded by
    '-', not ':'), which is how cloud models slipped through to the local num_ctx
    OOM ladder. Match on the segment after the final ':' instead."""
    last = (tag or "").lower().rsplit(":", 1)[-1]
    return last == "cloud" or last.endswith("-cloud")


def _ollama_tools_schema(tools_on) -> list:
    """Translate the enabled TOOLS into Ollama's native function-calling schema.

    Passing this as the `tools` field of /api/chat lets tool-trained models
    (gpt-oss, qwen3-coder, glm, minimax, llama3.1+, qwen3, even gemma) emit
    STRUCTURED `message.tool_calls` instead of relying on inline <tool_call>
    text formatting — far more reliable across model families. `tools_on` may be
    the enabled-tools dict (name→spec) or, from the skill path, a bare bool — in
    which case we expose the full TOOLS registry."""
    enabled = tools_on if isinstance(tools_on, dict) else TOOLS

    def _jtype(hint: str) -> str:
        h = (hint or "").lower()
        if "int" in h:                       return "integer"
        if "float" in h or "number" in h:    return "number"
        if "bool" in h:                      return "boolean"
        return "string"

    out = []
    for name, spec in enabled.items():
        if not isinstance(spec, dict):
            continue
        params = spec.get("params", {}) or {}
        props, required = {}, []
        for pname, phint in params.items():
            props[pname] = {"type": _jtype(str(phint)), "description": str(phint)}
            if "optional" not in str(phint).lower() and "default" not in str(phint).lower():
                required.append(pname)
        out.append({"type": "function", "function": {
            "name": name,
            "description": spec.get("desc", name),
            "parameters": {"type": "object", "properties": props, "required": required},
        }})
    return out


def _native_tool_calls_to_text(tool_calls: list) -> str:
    """Serialize Ollama native `message.tool_calls` into thmes's canonical
    <tool_call>{...}</tool_call> text so the existing parse_tool_calls() handles
    them with zero agent-loop changes (native path → same code path as text)."""
    out = []
    for tc in tool_calls or []:
        fn = (tc or {}).get("function") or {}
        name = fn.get("name")
        if not name:
            continue
        args = fn.get("arguments")
        if isinstance(args, str):
            try: args = json.loads(args)
            except Exception: args = {"_raw": args}
        if not isinstance(args, dict):
            args = {}
        # Some models (e.g. llama3.2) wrap a scalar as {"type":"string","value":X}
        # — unwrap so the tool fn receives the bare value.
        clean = {}
        for k, v in args.items():
            if isinstance(v, dict) and "value" in v and set(v) <= {"type", "value"}:
                clean[k] = v["value"]
            else:
                clean[k] = v
        out.append("<tool_call>"
                   + json.dumps({"name": name, "arguments": clean}, ensure_ascii=False)
                   + "</tool_call>")
    return "\n".join(out)


def _ollama_chat(history, system: str, max_tokens: int, tools: list | None = None,
                 *, model: str | None = None, ctx: int | None = None,
                 temperature: float | None = None,
                 think: bool | None = None) -> tuple[str, dict]:
    """Call Ollama `/api/chat`. Returns (text, stats) matching generate_reply shape.

    Image/audio inputs are intentionally not forwarded here — Ollama supports
    images via `images: [base64,...]` for vision models, but thmes's image
    pipeline is wired to mlx-vlm. If you need vision via Ollama, pick a vision
    model (e.g. llama3.2-vision) and we'll fall back to text-only history.
    """
    msgs = []
    if system:
        msgs.append({"role": "system", "content": system})
    for h in history:
        role = h.get("role", "user")
        content = h.get("content", "")
        # Ollama only accepts user/assistant/system/tool. tool_results stored as
        # user msgs with `<tool_result>` content stay as "user" — works fine.
        if role not in ("user", "assistant", "system", "tool"):
            role = "user"
        msgs.append({"role": role, "content": content})

    # Pass num_ctx explicitly so Ollama allocates the full window we promised
    # in native_ctx(). Without this, Ollama uses its own conservative default
    # (often 4k–32k depending on env) and silently truncates long histories
    # before our auto-compact threshold can fire.
    # Model/ctx may be overridden: the privacy relay calls a cloud model for the
    # REASON step WITHOUT swapping the loaded local `mm` (cloud runs on
    # ollama.com, costs no local RAM). Default to whatever `mm` has loaded.
    _model = model or mm.ollama_meta.get("model") or ""
    _ctx = ctx if ctx is not None else int(mm.ollama_meta.get("ctx") or _OLLAMA_DEFAULT_CTX)
    num_ctx = (_OLLAMA_NUM_CTX_OVERRIDE or _ctx)
    t0 = time.time()
    err_stats = {"tokens": 0, "tps": 0, "peak": 0}

    # Cloud models (`:cloud` tags) run on ollama.com, NOT this machine — their
    # context is allocated server-side. Sending an explicit num_ctx can make the
    # cloud endpoint reject the request with HTTP 500, and the local-RAM "OOM
    # ladder" below is meaningless for them. So for cloud: omit num_ctx (None
    # sentinel). A cloud 500 is usually transient (the model is busy / rate-
    # limited — common on big free-tier models), so allow a few plain retries.
    is_cloud = _is_cloud_model(_model)
    if is_cloud:
        ctx_attempts = [None, None, None]
    else:
        # Retry with progressively smaller num_ctx on HTTP 500 (OOM on low-RAM
        # machines). Ollama returns 500 when KV-cache allocation fails — halving
        # the context window usually resolves it without restarting the server.
        ctx_attempts = [num_ctx]
        reduced = num_ctx
        while reduced > 2048:
            reduced = reduced // 2
            ctx_attempts.append(reduced)

    data = None
    last_err: str | None = None
    timed_out = False
    for attempt_ctx in ctx_attempts:
        options = {"num_predict": int(max_tokens)}
        if temperature is not None:        # e.g. relay NER wants deterministic (0)
            options["temperature"] = temperature
        if attempt_ctx is not None:        # cloud → omit num_ctx entirely
            options["num_ctx"] = attempt_ctx
        payload_obj = {
            "model": _model,
            "messages": msgs,
            "stream": True,   # streaming: socket timeout resets per chunk received
            "options": options,
        }
        if tools:                        # native function-calling schema
            payload_obj["tools"] = tools
        if think is not None:            # thinking models (glm/gpt-oss/deepseek):
            payload_obj["think"] = think # False → return the answer, not the CoT
        payload = json.dumps(payload_obj).encode("utf-8")
        # The first read also waits for the model to load; if that exceeds the
        # idle timeout, retry ONCE with the longer load budget before giving up.
        for read_timeout in (OLLAMA_TIMEOUT, OLLAMA_LOAD_TIMEOUT):
            req = Request(f"{OLLAMA_HOST}/api/chat", data=payload,
                          headers=_ollama_headers(), method="POST")
            try:
                with urlopen(req, timeout=read_timeout) as r:
                    parts: list[str] = []
                    think_parts: list[str] = []
                    tool_calls_acc: list = []
                    final: dict = {}
                    for raw in r:
                        if not raw.strip():
                            continue
                        try:
                            chunk = json.loads(raw.decode("utf-8", errors="replace"))
                        except json.JSONDecodeError:
                            continue
                        msg = chunk.get("message") or {}
                        parts.append(msg.get("content", ""))
                        # Reasoning models (glm, deepseek-r1, qwen3-thinking, …)
                        # stream chain-of-thought in a separate `thinking` field,
                        # leaving `content` empty until reasoning ends. Capture it
                        # so a turn that runs out of budget mid-thought (or puts its
                        # whole answer there) doesn't collapse to "".
                        if msg.get("thinking"):
                            think_parts.append(msg["thinking"])
                        # Native function-calling: structured calls arrive here
                        # (usually in the final chunk), NOT as inline text.
                        if msg.get("tool_calls"):
                            tool_calls_acc.extend(msg["tool_calls"])
                        if chunk.get("done"):
                            final = chunk
                            break
                    content = "".join(parts)
                    if tool_calls_acc:
                        # Fold native calls into the canonical <tool_call> text so
                        # parse_tool_calls() handles them like any other call.
                        tc_text = _native_tool_calls_to_text(tool_calls_acc)
                        content = (content + "\n" + tc_text) if content.strip() else tc_text
                    elif not content.strip() and think_parts:
                        content = "".join(think_parts)
                    data = {
                        "message":       {"content": content},
                        "eval_count":    final.get("eval_count", 0),
                        "eval_duration": final.get("eval_duration", 0),
                    }
                if attempt_ctx is not None and attempt_ctx < num_ctx:
                    console.print(
                        f"[yellow]⚠ Ollama OOM at num_ctx={num_ctx} — "
                        f"retried with num_ctx={attempt_ctx} (set "
                        f"THMES_OLLAMA_NUM_CTX={attempt_ctx} to make permanent)[/]"
                    )
                break  # inner: success
            except TimeoutError:
                if read_timeout == OLLAMA_TIMEOUT:
                    console.print(
                        f"[yellow]⚠ Ollama timed out after {OLLAMA_TIMEOUT:.0f}s "
                        f"(model may be loading) — retrying once with "
                        f"{OLLAMA_LOAD_TIMEOUT:.0f}s…[/]")
                    continue   # inner: retry same ctx with the longer budget
                last_err = f"timeout after {OLLAMA_LOAD_TIMEOUT:.0f}s at num_ctx={attempt_ctx}"
                timed_out = True
                break          # inner: give up (already gave it the long budget)
            except HTTPError as e:
                if e.code in (401, 403):
                    tag = _model or "?"
                    cloud = _is_cloud_model(tag) or "/" in tag
                    hint = (
                        f"[ollama auth error] {e.code} Unauthorized for '{tag}'.\n"
                        + ("This is an Ollama CLOUD model — it runs on ollama.com, not "
                           "locally. Fix one of:\n"
                           "  1. Run `ollama signin` in a terminal (recommended), or\n"
                           "  2. Set THMES_OLLAMA_API_KEY=<your-key> and restart\n"
                           "Then `/model refresh` and try again."
                           if cloud else
                           "Set THMES_OLLAMA_API_KEY if your Ollama host needs auth.")
                    )
                    return hint, err_stats
                if e.code == 500:
                    if is_cloud:
                        # Cloud 500 is server-side (busy / over quota / transient),
                        # never local RAM. Retry the next plain attempt with a
                        # short backoff instead of pretending the ctx ladder helps.
                        last_err = "HTTP 500 from cloud (transient)"
                        console.print("[yellow]⚠ cloud HTTP 500 — retrying…[/]")
                        time.sleep(1.5)
                        break      # inner → outer retries the next None attempt
                    last_err = f"HTTP 500 at num_ctx={attempt_ctx}"
                    console.print(f"[yellow]⚠ Ollama HTTP 500 (num_ctx={attempt_ctx}) — retrying with smaller context…[/]")
                    break      # inner: not a timeout → fall to the ctx ladder
                return f"[ollama error] HTTP {e.code}: {e.reason}", err_stats
            except Exception as e:
                return f"[ollama error] {type(e).__name__}: {e}", err_stats
        if data is not None:
            break              # outer: success
        if timed_out:
            return (
                f"[ollama error] timed out waiting for {_model or '?'} "
                f"(tried {OLLAMA_TIMEOUT:.0f}s then {OLLAMA_LOAD_TIMEOUT:.0f}s).\n"
                f"The model may be loading or this machine is overloaded. Try again, "
                f"or raise THMES_OLLAMA_LOAD_TIMEOUT / pre-warm with /model.",
                err_stats,
            )
        # else: HTTP 500 → continue down the ctx ladder

    if data is None:
        if is_cloud:
            return (
                f"[ollama error] cloud model '{_model or '?'}' kept "
                f"returning HTTP 500 after {len(ctx_attempts)} tries — the ollama.com "
                f"endpoint is busy or rate-limited ({last_err}). Try again shortly.",
                err_stats,
            )
        return (
            f"[ollama error] HTTP 500 — context window too large for this machine's RAM.\n"
            f"Tried num_ctx values: {ctx_attempts}\n"
            f"Last error: {last_err}\n"
            f"Fix: set THMES_OLLAMA_NUM_CTX=2048 (or lower) and restart.",
            err_stats,
        )
    text = (data.get("message") or {}).get("content", "") or ""
    eval_count = int(data.get("eval_count") or 0)
    eval_ns = int(data.get("eval_duration") or 0)
    tps = (eval_count / (eval_ns / 1e9)) if eval_ns else 0
    elapsed = time.time() - t0
    return text, {
        "tokens": eval_count or len(text.split()),
        "tps":    tps or (len(text.split()) / max(elapsed, 0.001)),
        "peak":   0,   # Ollama doesn't report this; leave 0
    }


def generate_reply(history, system: str, *, image=None, audio=None, max_tokens=512,
                   tools=None, model=None, temperature=None, think=None):
    # Explicit `model` override (privacy relay → cloud REASON step) goes straight
    # to the Ollama HTTP path regardless of which backend `mm` currently has
    # loaded: cloud models run on ollama.com and never touch the local MLX model.
    if model:
        return _ollama_chat(history, system, max_tokens, tools=tools, model=model,
                            temperature=temperature, think=think)
    if mm.backend == "ollama":
        if image or audio:
            console.print("[yellow]⚠ image/audio ignored on Ollama backend "
                          "(use an MLX VLM model for multimodal)[/]")
        return _ollama_chat(history, system, max_tokens, tools=tools,
                            temperature=temperature, think=think)
    if mm.is_vlm:
        from mlx_vlm.prompt_utils import apply_chat_template
        msg_text = _stringify_history_for_vlm(history, system)
        num_images = 1 if image else 0
        formatted = apply_chat_template(
            mm.processor, mm.model.config, msg_text, num_images=num_images)
        stream_kwargs = {"max_tokens": max_tokens}
        if image: stream_kwargs["image"] = [image]
        if audio: stream_kwargs["audio"] = [audio]
        t = time.time()
        try:
            # stream_generate available in mlx_vlm ≥ 0.1.0 — yields per-token
            # results so ESC can interrupt between yields (reliable vs blocking C call).
            from mlx_vlm import stream_generate as _vlm_stream
            parts: list[str] = []
            try:
                for result in _vlm_stream(mm.model, mm.processor, formatted, **stream_kwargs):
                    parts.append(result.text if hasattr(result, "text") else str(result))
            except KeyboardInterrupt:
                pass  # ESC mid-generation — return partial output
            text = "".join(parts)
            elapsed = max(time.time() - t, 0.001)
            toks = len(parts)
            return text, {
                "tokens": toks or len(text.split()),
                "tps":    toks / elapsed,
                "peak":   0,
            }
        except (ImportError, AttributeError):
            # Older mlx_vlm without stream_generate — fall back to blocking call
            from mlx_vlm import generate
            r = generate(mm.model, mm.processor, formatted,
                         **stream_kwargs, verbose=False)
            text = r.text if hasattr(r, "text") else str(r)
            return text, {
                "tokens": getattr(r, "generation_tokens", 0),
                "tps":    getattr(r, "generation_tps", 0),
                "peak":   getattr(r, "peak_memory", 0),
            }
    else:
        msgs = [{"role": "system", "content": system}] if system else []
        msgs.extend(history)
        prompt = mm.processor.apply_chat_template(msgs, tokenize=False, add_generation_prompt=True)
        t = time.time()
        try:
            # stream_generate available in mlx_lm ≥ 0.18 — yields per-token results
            # so ESC interrupt is deliverable between yields (not inside C extension).
            from mlx_lm import stream_generate as _lm_stream
            parts: list[str] = []
            try:
                for result in _lm_stream(mm.model, mm.processor, prompt=prompt,
                                         max_tokens=max_tokens):
                    parts.append(result.text if hasattr(result, "text") else str(result))
            except KeyboardInterrupt:
                pass  # ESC mid-generation — return partial output
            text = "".join(parts)
            elapsed = max(time.time() - t, 0.001)
            toks = len(parts)
            return text, {
                "tokens": toks or len(text.split()),
                "tps":    toks / elapsed,
                "peak":   0,
            }
        except (ImportError, AttributeError):
            # Older mlx_lm without stream_generate — fall back to blocking call
            from mlx_lm import generate
            text = generate(mm.model, mm.processor, prompt=prompt,
                            max_tokens=max_tokens, verbose=False)
            elapsed = max(time.time() - t, 0.001)
            return text, {
                "tokens": len(text.split()),
                "tps":    len(text.split()) / elapsed,
                "peak":   0,
            }

# ╔════════════════════════════════════════════════════════════════════════╗
# ║ Privacy relay — mask (local) → reason (cloud) → unmask (local)         ║
# ╚════════════════════════════════════════════════════════════════════════╝
# The vault (real↔placeholder map) lives only in RAM for the active session;
# the cloud sees masked text exclusively, restore is deterministic. The MASK +
# UNMASK stages run on the loaded LOCAL model; only REASON hits the cloud.
# See lib/thmes_mask.py for the masking engine.

_relay_cfg: dict = {}            # persisted settings: cloud_model / deny_list / groups
_relay_vault = None             # MaskVault for the active session (created lazily)
_relay_vault_session = None     # session_id the vault belongs to (reset on switch)


def _relay_settings_load() -> dict:
    cfg = {
        "cloud_model": _env("THMES_RELAY_CLOUD") or None,
        "deny_list":   [],
        "groups":      list(DEFAULT_GROUPS),
    }
    try:
        if RELAY_SETTINGS_FILE.exists():
            data = json.loads(RELAY_SETTINGS_FILE.read_text("utf-8"))
            if isinstance(data, dict):
                if data.get("cloud_model"):
                    cfg["cloud_model"] = str(data["cloud_model"])
                if isinstance(data.get("deny_list"), list):
                    cfg["deny_list"] = [str(x) for x in data["deny_list"] if str(x).strip()]
                if isinstance(data.get("groups"), list) and data["groups"]:
                    cfg["groups"] = [str(x) for x in data["groups"]]
    except Exception:
        pass
    return cfg


def _relay_settings_save() -> None:
    try:
        RELAY_SETTINGS_FILE.write_text(
            json.dumps({
                "cloud_model": _relay_cfg.get("cloud_model"),
                "deny_list":   _relay_cfg.get("deny_list", []),
                "groups":      _relay_cfg.get("groups", list(DEFAULT_GROUPS)),
            }, ensure_ascii=False, indent=2),
            "utf-8",
        )
    except Exception as e:
        console.print(f"[yellow]⚠ relay: เซฟ settings ไม่ได้: {e}[/]")


# Ollama cloud models are usable right after `ollama signin` but DON'T appear in
# `/api/tags`, so a tag-only discovery shows nothing. Offer this catalog in the
# picker; the per-pick smoke-test confirms which ones the account can actually use.
_KNOWN_CLOUD_MODELS = [
    "glm-4.6:cloud", "gpt-oss:120b-cloud", "gpt-oss:20b-cloud",
    "qwen3-coder:480b-cloud", "deepseek-v3.1:671b-cloud", "kimi-k2:1t-cloud",
    "minimax-m2:cloud",
]


def _discover_cloud_models() -> dict:
    """Discovered Ollama models whose tag is a cloud model (runs on ollama.com).
    Note: signed-in cloud models often aren't in `/api/tags` — see the catalog
    used by `_pick_cloud_model`."""
    return {alias: meta for alias, meta in OLLAMA_MODELS.items()
            if _is_cloud_model((meta or {}).get("model") or alias)}


def _resolve_relay_cloud() -> Optional[str]:
    """Bare cloud-model tag to use for REASON, or None if unset."""
    return _relay_cfg.get("cloud_model") or (_env("THMES_RELAY_CLOUD") or None)


def _cloud_smoke_test(model: str) -> tuple[bool, str]:
    """One tiny generation to confirm the cloud model is reachable/authorized.
    Returns (ok, detail); ok=False if the call returned an `[ollama …]` error."""
    txt, _ = _ollama_chat([{"role": "user", "content": "ping"}], "", 1, model=model)
    txt = (txt or "").strip()
    return (not txt.startswith("[ollama")), txt


def _pick_cloud_model() -> Optional[str]:
    """Interactive cloud-model picker. Returns a bare tag, or None if cancelled.
    Lists `/api/tags` cloud models PLUS the known catalog (signed-in cloud models
    don't show in tags); the smoke-test on selection confirms real access."""
    discovered = [(meta.get("model") or alias) for alias, meta in _discover_cloud_models().items()]
    tags: list[str] = []
    for tag in discovered + _KNOWN_CLOUD_MODELS:        # discovered first, dedup, keep order
        if tag not in tags:
            tags.append(tag)
    detected = set(discovered)
    t = Table(show_header=True, header_style="bold dim", box=None, padding=(0, 1))
    t.add_column("#", width=4, justify="right", style="dim")
    t.add_column("Cloud model", style="cyan", no_wrap=True)
    t.add_column("", style="dim")
    for i, tag in enumerate(tags):
        t.add_row(str(i + 1), tag, "detected" if tag in detected else "catalog")
    console.print(Panel(t, title="[bold cyan]เลือก Cloud model (REASON)[/]",
                        subtitle="[dim]ต้อง `ollama signin` แล้ว · smoke-test จะเช็คสิทธิ์ให้[/]",
                        border_style="cyan"))
    console.print("[dim]  พิมพ์หมายเลข หรือพิมพ์ tag เอง (เช่น glm-4.6:cloud) · Enter = ยกเลิก[/]")
    while True:
        try:
            raw = pt_prompt("cloud › ").strip()
        except (KeyboardInterrupt, EOFError):
            return None
        if not raw:
            return None
        if raw.isdigit() and 1 <= int(raw) <= len(tags):
            return tags[int(raw) - 1]
        if _is_cloud_model(raw):
            return raw          # let the user type any cloud tag directly
        console.print("[yellow]  เลือกหมายเลขในรายการ หรือพิมพ์ tag ที่ลงท้าย :cloud / -cloud[/]")


def _relay_ensure_vault(session_id):
    """Return the MaskVault for `session_id`, creating it or clearing a stale one
    from a previous session. The vault never crosses a session boundary."""
    global _relay_vault, _relay_vault_session
    if _relay_vault is None:
        _relay_vault = MaskVault(_relay_cfg.get("groups") or DEFAULT_GROUPS,
                                 _relay_cfg.get("deny_list") or [])
        _relay_vault_session = session_id
    elif _relay_vault_session != session_id:
        _relay_vault.clear()
        _relay_vault.groups = {g for g in (_relay_cfg.get("groups") or DEFAULT_GROUPS)}
        _relay_vault.deny_list = list(_relay_cfg.get("deny_list") or [])
        _relay_vault_session = session_id
    return _relay_vault


def _enter_relay_mode(model: Optional[str] = None) -> bool:
    """Resolve/pick a cloud model → smoke-test → turn relay on (persist), or kick
    back to default mode on failure. Returns True iff relay mode is now on."""
    if not _MASK_OK:
        console.print("[red]✖ relay ใช้ไม่ได้: โหลด lib/thmes_mask.py ไม่สำเร็จ[/]")
        return False
    # MASK / UNMASK need a LOCAL model; refuse if the active model is itself a
    # cloud model (then nothing would actually stay on-device).
    if _is_cloud_model((mm.ollama_meta or {}).get("model") or ""):
        console.print("[red]✖ relay ต้องใช้ local model สำหรับ mask/unmask แต่ตอนนี้โหลด "
                      "cloud model อยู่ — สั่ง /model <local> ก่อน[/]")
        return False
    target = model or _resolve_relay_cloud() or _pick_cloud_model()
    if not target:
        console.print("[yellow]⚠ ยังไม่ได้เลือก cloud model — relay ไม่เปิด[/]")
        return False
    console.print(f"[dim]🛡️  smoke-test cloud `{target}` …[/]")
    ok, detail = _cloud_smoke_test(target)
    if not ok:
        console.print(f"[red]✖ smoke-test ล้มเหลว — เตะกลับ default mode[/]\n[dim]{detail[:300]}[/]")
        _FLAGS["relay_mode"] = False
        return False
    _relay_cfg["cloud_model"] = target
    _relay_settings_save()
    _FLAGS["relay_mode"] = True
    console.print(f"[bold green]🛡️  Privacy relay ON[/] → cloud=[cyan]{target}[/] "
                  f"[dim](mask→cloud→unmask; ของจริงไม่ออกนอกเครื่อง)[/]")
    return True


_relay_cfg = _relay_settings_load()

# ╔════════════════════════════════════════════════════════════════════════╗
# ║ Agentic loop — generate, parse tool calls, execute, regenerate        ║
# ╚════════════════════════════════════════════════════════════════════════╝
# ╔════════════════════════════════════════════════════════════════════════╗
# ║ ESC interrupt — background stdin watcher                              ║
# ╚════════════════════════════════════════════════════════════════════════╝
class _EscCancelGuard:
    """Daemon-thread ESC watcher that raises KeyboardInterrupt in the main
    thread when the user presses ESC. Supports pause/resume so that nested
    interactive prompts (`ask_yn`, slash-command input) can read stdin
    without racing the watcher for every byte.

    Concurrency model:
      - One guard active at a time (tracked in `_EscCancelGuard._active`).
      - During paused state: terminal restored to cooked mode, watcher loop
        skips the select+read step, and prompt_toolkit owns stdin alone.
      - On resume: cbreak re-applied, watcher resumes byte-level polling.
    """
    _active: "Optional[_EscCancelGuard]" = None

    def __init__(self):
        import threading
        self.stop_evt = threading.Event()
        self.pause_evt = threading.Event()
        self.thread = None
        self.fd = None
        self.saved = None

    def _set_cbreak(self):
        if self.fd is None: return
        import tty
        try: tty.setcbreak(self.fd)
        except Exception: pass

    def _restore(self):
        if self.fd is None or self.saved is None: return
        import termios
        try: termios.tcsetattr(self.fd, termios.TCSADRAIN, self.saved)
        except Exception: pass

    def start(self) -> bool:
        import threading, termios, sys
        if not sys.stdin.isatty():
            return False
        self.fd = sys.stdin.fileno()
        self.saved = termios.tcgetattr(self.fd)
        self._set_cbreak()
        self.thread = threading.Thread(target=self._watch, daemon=True)
        self.thread.start()
        _EscCancelGuard._active = self
        return True

    def _watch(self):
        import _thread, select, sys
        try:
            while not self.stop_evt.is_set():
                if self.pause_evt.is_set():
                    # Yield so the prompt thread can read stdin cleanly
                    self.stop_evt.wait(timeout=0.05)
                    continue
                r, _, _ = select.select([sys.stdin], [], [], 0.1)
                if r and not self.pause_evt.is_set():
                    try:
                        ch = sys.stdin.read(1)
                    except Exception:
                        return
                    if ch == "\x1b":
                        _thread.interrupt_main()
                        return
        finally:
            self._restore()

    def stop(self):
        self.stop_evt.set()
        if self.thread:
            self.thread.join(timeout=0.3)
        self._restore()
        if _EscCancelGuard._active is self:
            _EscCancelGuard._active = None

    def pause(self):
        """Restore cooked terminal mode and tell the watcher to idle."""
        self.pause_evt.set()
        self._restore()

    def resume(self):
        """Re-apply cbreak and let the watcher resume polling."""
        self._set_cbreak()
        self.pause_evt.clear()


from contextlib import contextmanager


@contextmanager
def pause_esc_watcher():
    """Context manager: temporarily disable the active ESC watcher so an
    interactive prompt can own stdin. No-op if no watcher is active (we're
    not inside `with_esc_cancel`)."""
    guard = _EscCancelGuard._active
    if guard is None:
        yield
        return
    guard.pause()
    try:
        yield
    finally:
        guard.resume()


def with_esc_cancel(func, *args, **kwargs):
    """Run func() with ESC-to-cancel monitoring. Idempotent on non-TTY."""
    import sys
    if not sys.stdin.isatty():
        return func(*args, **kwargs)
    guard = _EscCancelGuard()
    if not guard.start():
        return func(*args, **kwargs)
    try:
        return func(*args, **kwargs)
    finally:
        guard.stop()


# ── Command queue: type-ahead during agent_turn (Claude-style) ────────────
# Opt-in via THMES_QUEUE=1 because the background line-reader inevitably
# races with pt_prompt for stdin bytes during approval prompts. Default OFF so
# the approval flow is reliable; users who want type-ahead can enable it.
import queue as _queue_mod

QUEUE_ENABLED = _env("THMES_QUEUE", "0").lower() in ("1","true","yes","on")
_PROMPT_QUEUE: "_queue_mod.Queue[str]" = _queue_mod.Queue()
_CANCEL_KEYWORDS = {"/cancel", "/stop", "/abort", "cancel", "stop", "abort", "หยุด", "ยกเลิก"}


class _QueueListener:
    """Captures full lines from stdin during agent_turn. Pauses any active
    ESC watcher (cooked mode is incompatible with cbreak byte-poll). Special
    cancel keywords trigger KeyboardInterrupt; everything else gets queued.

    Reads byte-by-byte (not readline) so the daemon thread can react to
    stop_evt within ~100ms — readline blocks indefinitely if the user typed
    partial input without Enter, which left the thread alive and racing
    with approval prompt's pt_prompt for subsequent keystrokes.
    """

    def __init__(self):
        import threading
        self.stop_evt = threading.Event()
        self.thread = None
        self._esc_guard_was_active = False

    def start(self) -> bool:
        import sys, threading
        if not sys.stdin.isatty():
            return False
        guard = _EscCancelGuard._active
        if guard is not None:
            guard.pause()
            self._esc_guard_was_active = True
        self.stop_evt.clear()
        self.thread = threading.Thread(target=self._run, daemon=True)
        self.thread.start()
        return True

    def _run(self):
        import sys, select, _thread
        buffer: list[str] = []
        while not self.stop_evt.is_set():
            try:
                r, _, _ = select.select([sys.stdin], [], [], 0.1)
            except Exception:
                return
            if not r:
                continue
            try:
                ch = sys.stdin.read(1)
            except Exception:
                return
            if not ch:   # EOF
                return
            if ch in ("\n", "\r"):
                line = "".join(buffer).strip()
                buffer.clear()
                if not line:
                    continue
                if line.lower() in _CANCEL_KEYWORDS:
                    console.print(f"[yellow]⚠ '{line}' detected — cancelling current turn…[/]")
                    _thread.interrupt_main()
                    return
                _PROMPT_QUEUE.put(line)
                console.print(f"[dim]📥 queued (#{_PROMPT_QUEUE.qsize()}): "
                              f"{line[:80] + ('…' if len(line) > 80 else '')!r}[/]")
            else:
                buffer.append(ch)

    def stop(self):
        self.stop_evt.set()
        if self.thread:
            self.thread.join(timeout=0.4)
        if self._esc_guard_was_active:
            guard = _EscCancelGuard._active
            if guard is not None:
                guard.resume()


def drain_queue() -> Optional[str]:
    """Pop the oldest queued prompt (None if empty)."""
    try:
        return _PROMPT_QUEUE.get_nowait()
    except _queue_mod.Empty:
        return None


def queue_size() -> int:
    return _PROMPT_QUEUE.qsize()


def clear_queue() -> int:
    n = _PROMPT_QUEUE.qsize()
    while not _PROMPT_QUEUE.empty():
        try: _PROMPT_QUEUE.get_nowait()
        except _queue_mod.Empty: break
    return n


# ── Tool execution UX: per-tool expected timeout + live ticker ────────────
# Used to render `8.2s / 30s` style countdown so users have an upper bound on
# wait time (rather than staring at a spinner with no end in sight).
_TOOL_EXPECTED_TIMEOUT = {
    "bash":       30,
    "python":     10,
    "web_fetch":  20,
    "web_search": 10,
    "opencode":  300,
    "write_file":  5,
    "read_file":   5,
    "list_dir":    5,
    "grep":        5,
    "current_datetime": 1,
    "current_directory": 1,
}


def _format_tool_status(name: str, arg_preview: str, payload_hint: str,
                        elapsed: float, expected: float) -> str:
    """Live spinner text: name(args) · 8.2s / 30s · payload-hint
    Colors the elapsed counter red when we're past 90% of expected time."""
    pct = elapsed / expected if expected else 0
    elapsed_color = "yellow" if pct < 0.5 else "orange3" if pct < 0.9 else "red"
    return (f"[cyan]⚡[/] [bold]{name}[/]"
            f"[dim]({arg_preview})[/] · "
            f"[{elapsed_color}]{elapsed:5.1f}s[/] [dim]/ ~{int(expected)}s"
            f"{payload_hint}[/]")


def _start_tool_spinner(name: str, arg_preview: str, payload_hint: str,
                        start_time: float, expected_timeout: float):
    """Start a rich Status spinner with a ticker thread that updates the
    elapsed counter every 250ms. Returns (stop_callable, status_cm).
    Caller must call stop_callable() AND status_cm.__exit__(None,None,None).
    """
    import threading
    status = console.status(
        _format_tool_status(name, arg_preview, payload_hint, 0.0, expected_timeout),
        spinner="dots")
    status.__enter__()
    stop_evt = threading.Event()
    def _tick():
        while not stop_evt.wait(0.25):
            elapsed = time.time() - start_time
            try:
                status.update(_format_tool_status(
                    name, arg_preview, payload_hint, elapsed, expected_timeout))
            except Exception:
                return
    t = threading.Thread(target=_tick, daemon=True)
    t.start()
    def _stop():
        stop_evt.set()
        t.join(timeout=0.4)
    return _stop, status


def _run_safe_parallel(
    safe_batch: "list[tuple[dict, str]]",
    aggregate_stats: dict,
    history: list,
    executed_call_keys: set,
) -> None:
    """Run a batch of safe (no-approval) tool calls concurrently via
    ThreadPoolExecutor. Results are injected into history in the ORIGINAL
    call order regardless of which futures finish first, preserving
    determinism for the model's next generation.

    Uses an empty allow_dangerous set because safe tools never need
    user approval — that invariant is enforced by TOOL_RISK.
    """
    import concurrent.futures
    n = len(safe_batch)
    console.print(f"[dim]  ⚡×{n} running {n} safe tools in parallel…[/]")
    t0 = time.time()
    results: list = [None] * n
    with concurrent.futures.ThreadPoolExecutor(
            max_workers=min(n, 4),
            thread_name_prefix="tool-par") as pool:
        future_to_idx = {
            pool.submit(execute_tool, c, set()): i
            for i, (c, _exec_key) in enumerate(safe_batch)
        }
        for fut in concurrent.futures.as_completed(future_to_idx):
            idx = future_to_idx[fut]
            try:
                results[idx] = fut.result()
            except Exception as exc:
                results[idx] = (f"Tool error: {exc}", False)
    elapsed = time.time() - t0
    # Inject results in original call order (deterministic)
    for i, (c, exec_key) in enumerate(safe_batch):
        result, ok = results[i]
        name = c.get("name", "?")
        aggregate_stats["tool_calls"] += 1
        symbol = "[green]✓[/]" if ok else "[red]✗[/]"
        first_line = next((ln for ln in result.splitlines() if ln.strip()), "(empty)")
        preview = first_line[:60] + ("…" if len(first_line) > 60 else "")
        arg_preview = json.dumps(c.get("arguments", {}), ensure_ascii=False)[:50]
        console.print(
            f"  {symbol} [bold]{name}[/]"
            f"[dim]({arg_preview}) · {elapsed:.1f}s ⚡par · "
            f"{len(result):,} chars[/] [white]{preview}[/]")
        history.append({"role": "user",
                        "content": f"<tool_result name=\"{name}\">\n{result}\n</tool_result>"})
        if ok:
            executed_call_keys.add(exec_key)


def agent_turn(history, *, system, image, audio, max_tokens,
               tools_on, allow_dangerous, max_iters=6):
    """Agent loop with tolerant tool parsing + self-correction.

    If model produces unparseable tool-like output, inject a corrective message
    and let it retry (max 2 format-correction attempts per turn).
    """
    aggregate_stats = {"tokens": 0, "tps_sum": 0, "iters": 0,
                       "peak": 0, "tool_calls": 0, "corrections": 0,
                       "router_ms": 0, "drift_nudges": 0}
    known_tools = set(TOOLS.keys())
    correction_count = 0
    MAX_CORRECTIONS = 2
    # Capture the original user question (last user msg that isn't a tool_result
    # or our own injected nudge). Used to re-ground the model after long tool
    # chains drift off-topic, and to quote verbatim in the max-iters synthesis.
    original_question = next(
        (h["content"] for h in reversed(history)
         if h["role"] == "user"
         and not h["content"].startswith("<tool_result")
         and not h["content"].startswith("[stay-on-task")),
        "",
    )
    DRIFT_NUDGE_EVERY = 3   # remind model of the goal every N tool-call iters

    reply = ""
    # Cross-iter dedupe — track every (name, args) we've already approved &
    # executed in this turn. If the model re-emits the same call in a later
    # iter, skip it silently (synthesize a tool_result reminding the model
    # the work was done). Without this, gemma/qwen-vl will repeat the same
    # write_file or bash three or four times in a single turn, forcing the
    # user to click approve each time.
    executed_call_keys: set = set()
    # ask_user budget — small models will loop on ask_user forever (ask, get
    # answer, fail to use it, ask again). Cap it; once exhausted, further
    # ask_user calls return a synthetic result that forces the model onward.
    ask_user_count = 0
    MAX_ASK_USER = 3
    # Stuck detector — count consecutive iters where EVERY emitted call was a
    # cross-iter duplicate (zero real progress). Two in a row → the model is
    # repeating itself; break out and synthesize instead of looping to max.
    stuck_iters = 0
    # Empty-turn budget — some reasoning models (glm, …) occasionally return a
    # turn with no content AND no tool call (stalled mid-thought). Nudge them to
    # continue instead of ending the task on "", bounded to avoid loops.
    empty_nudges = 0
    MAX_EMPTY_NUDGES = 2

    # Native Ollama tool-calling: hand the model a structured tool schema so
    # tool-trained models emit reliable `message.tool_calls` instead of having to
    # format inline <tool_call> text. Built once per turn. MLX path ignores it;
    # models without native support simply fall back to the text protocol.
    _ollama_tools = (_ollama_tools_schema(tools_on)
                     if (tools_on and mm.backend == "ollama") else None)

    for it in range(max_iters):
        iter_t0 = time.time()
        # Optional queue listener for the long model-generation phase (opt-in
        # via THMES_QUEUE=1). Default OFF because the background reader
        # races stdin with the approval prompt's pt_prompt and steals 'y'
        # bytes — breaking the approval flow.
        _qlistener = _QueueListener() if QUEUE_ENABLED else None
        if _qlistener is not None:
            _qlistener.start()
        try:
            with console.status(
                f"[cyan]✻[/] thinking [dim]· iter {it+1}/{max_iters}"
                f"{f' · 📥 {queue_size()} queued' if queue_size() else ''}[/]",
                spinner="dots"):
                reply, st = generate_reply(history, system,
                                           image=image if it == 0 else None,
                                           audio=audio if it == 0 else None,
                                           max_tokens=max_tokens,
                                           tools=_ollama_tools)
        except KeyboardInterrupt:
            console.print(f"[yellow]  ⚠ cancelled at iter {it+1}/{max_iters}[/]")
            raise
        finally:
            if _qlistener is not None:
                _qlistener.stop()
        iter_elapsed = time.time() - iter_t0
        # Compact one-liner status
        console.print(
            f"[dim]  ✻ thinking · {iter_elapsed:.1f}s · "
            f"{st['tokens']:,} tokens · {st.get('tps', 0):.0f} tps[/]"
        )
        history.append({"role": "assistant", "content": reply})
        aggregate_stats["tokens"] += st["tokens"]
        aggregate_stats["tps_sum"] += st["tps"]
        aggregate_stats["peak"] = max(aggregate_stats["peak"], st["peak"])
        aggregate_stats["iters"] += 1

        if not tools_on:
            return reply, aggregate_stats

        calls, notes = parse_tool_calls(reply, known_tools=known_tools)

        # ── Self-correction: model tried but in wrong format ─────────────
        if not calls and correction_count < MAX_CORRECTIONS:
            suspect = has_suspicious_tool_attempt(reply)
            if suspect:
                correction_count += 1
                aggregate_stats["corrections"] += 1
                console.print(Panel(
                    f"[yellow]⚠ Detected unparseable tool attempt:[/] {suspect}\n"
                    f"[dim]Injecting format correction…[/]",
                    border_style="yellow"))
                history.append({"role": "user", "content":
                    "Your previous output looked like a tool call but used the wrong format "
                    f"({suspect}). I CANNOT parse that. Retry the call using EXACTLY this format "
                    "(no markdown fences, no other syntax):\n\n"
                    "<tool_call>\n"
                    '{"name": "TOOL_NAME", "arguments": {"KEY": "VALUE"}}\n'
                    "</tool_call>\n\n"
                    "Then I will execute it. If you don't need a tool, just write the answer plainly."
                })
                continue  # regenerate

        # Empty/dead turn mid-task — no content AND no tool call (model ran out
        # mid-thought). Don't silently end the task on "": nudge once to continue.
        if (not calls and not reply.strip()
                and it < max_iters - 1 and empty_nudges < MAX_EMPTY_NUDGES):
            empty_nudges += 1
            console.print(f"[dim]  ↻ empty turn — nudging to continue "
                          f"({empty_nudges}/{MAX_EMPTY_NUDGES})[/]")
            history.append({"role": "user", "content":
                "Your last turn was empty. Continue the task now: emit the next "
                "tool call to make progress, or if everything is already done, "
                "write the final answer."})
            continue

        if not calls:
            return reply, aggregate_stats

        # ── Strip model artifact tokens (thinking blocks, channel tags) ────────
        # Must run before preamble-prose check so <|channel>thought doesn't
        # appear as "prose" and shift the first_tag position.
        reply = _strip_model_artifacts(reply)

        # ── Strip narration prose that precedes tool calls ───────────────────
        # Small models (Gemma especially) write "I will now search…" or
        # "I should wait for the results…" before/between <tool_call> blocks.
        # This text is never useful — suppress it silently so the UI stays clean.
        first_tag = reply.find("<tool_call>")
        if first_tag > 20:          # more than a tiny lead-in
            prose_before = reply[:first_tag].strip()
            if prose_before:
                reply = reply[first_tag:]   # drop the preamble narration

        # Dedupe identical tool calls within the same generation. Small models
        # (gemma/qwen-vl) often emit two back-to-back <tool_call> blocks with
        # exactly the same args, forcing the user to approve twice for the
        # same action. Keep first occurrence, drop the rest, log to console.
        seen_keys: set[tuple] = set()
        deduped: list[dict] = []
        dup_count = 0
        for c in calls:
            try:
                key = (c.get("name"),
                       json.dumps(c.get("arguments", {}), sort_keys=True,
                                  ensure_ascii=False))
            except (TypeError, ValueError):
                key = (c.get("name"), repr(c.get("arguments")))
            if key in seen_keys:
                dup_count += 1
                continue
            seen_keys.add(key)
            deduped.append(c)
        if dup_count:
            console.print(f"[dim]  ↩ dropped {dup_count} duplicate tool call(s) "
                          f"in this generation[/]")
        calls = deduped

        # Show parser path used (helpful for debugging model behavior)
        format_label = ", ".join(set(notes))
        if format_label and format_label != "canonical":
            console.print(f"[dim]parsed via:[/] [yellow]{format_label}[/]")

        # ── Partition calls: safe (parallelisable) vs ask (sequential) ──────
        # Cross-iter dedupe happens here; dupes get a synthetic tool_result
        # that tells the model the work was already done.
        safe_batch: list = []   # (call, exec_key) — run concurrently
        sequential: list = []   # (call, exec_key) — run sequentially with approval

        for c in calls:
            name_c = c.get("name", "?")
            args_c = c.get("arguments", {}) or {}
            try:
                exec_key_c = (name_c,
                              json.dumps(args_c, sort_keys=True, ensure_ascii=False))
            except (TypeError, ValueError):
                exec_key_c = (name_c, repr(args_c))
            arg_prev_c = json.dumps(args_c, ensure_ascii=False)
            if len(arg_prev_c) > 80: arg_prev_c = arg_prev_c[:77] + "…"

            # Cross-iter dedupe
            if exec_key_c in executed_call_keys:
                console.print(f"  [yellow]↩ skipping repeat[/] [bold]{name_c}[/]"
                              f"[dim]({arg_prev_c}) — already executed this turn[/]")
                history.append({"role": "user", "content":
                    f"<tool_result name=\"{name_c}\">\n"
                    f"[duplicate — this exact call already ran successfully "
                    f"earlier in this turn. Do not emit it again. If the "
                    f"previous result was satisfactory, write the final "
                    f"answer now.]\n</tool_result>"})
                continue

            # Interactive safe tools (ask_user) must run sequentially on the
            # main thread — never in a parallel worker.
            if (TOOL_RISK.get(name_c, "ask") == "safe"
                    and name_c not in _INTERACTIVE_TOOLS):
                safe_batch.append((c, exec_key_c))
            else:
                sequential.append((c, exec_key_c))

        # Stuck detector: this iter emitted call(s) but EVERY one was a
        # cross-iter duplicate → zero progress. Two such iters in a row means
        # the model is looping; break out to the synthesis path.
        if calls and not safe_batch and not sequential:
            stuck_iters += 1
            if stuck_iters >= 2:
                console.print("[yellow]⚠ model is repeating the same call(s) "
                              "with no progress — stopping to synthesize[/]")
                break
        else:
            stuck_iters = 0

        # ── Run safe tools in parallel (if >1 in batch) ───────────────────
        if len(safe_batch) > 1:
            _run_safe_parallel(safe_batch, aggregate_stats, history, executed_call_keys)
        elif len(safe_batch) == 1:
            # Single safe call — run inline, no ThreadPool overhead
            c, exec_key = safe_batch[0]
            name = c.get("name", "?")
            args = c.get("arguments", {}) or {}
            arg_preview = json.dumps(args, ensure_ascii=False)
            if len(arg_preview) > 80: arg_preview = arg_preview[:77] + "…"
            if _FLAGS["verbose_tools"]:
                console.print(Panel(
                    Syntax(json.dumps(c, ensure_ascii=False, indent=2), "json",
                           theme="ansi_dark", background_color="default"),
                    title=f"🔧 {name} ({it+1}/{max_iters})", border_style="cyan"))
            exec_t0 = time.time()
            expected_timeout = _TOOL_EXPECTED_TIMEOUT.get(name, 30)
            payload_hint = ""
            ticker_stop, status_cm = _start_tool_spinner(
                name, arg_preview, payload_hint, exec_t0, expected_timeout)
            try:
                result, ok = execute_tool(c, set())   # safe → no approval needed
            finally:
                ticker_stop(); status_cm.__exit__(None, None, None)
                try: console.file.flush()
                except Exception: pass
            exec_elapsed = time.time() - exec_t0
            symbol = "[green]✓[/]" if ok else "[red]✗[/]"
            first_line = next((ln for ln in result.splitlines() if ln.strip()), "(empty)")
            preview = first_line[:60] + ("…" if len(first_line) > 60 else "")
            console.print(
                f"  {symbol} [bold]{name}[/]"
                f"[dim]([cyan]{arg_preview[:50]}[/])"
                f" · {exec_elapsed:.1f}s · "
                f"{len(result):,} chars[/] [white]{preview}[/]")
            aggregate_stats["tool_calls"] += 1
            history.append({"role": "user",
                            "content": f"<tool_result name=\"{name}\">\n{result}\n</tool_result>"})
            if ok:
                executed_call_keys.add(exec_key)

        # ── Run ask tools sequentially with approval ───────────────────────
        for c, exec_key in sequential:
            name = c.get("name", "?")
            args = c.get("arguments", {}) or {}
            arg_preview = json.dumps(args, ensure_ascii=False)
            if len(arg_preview) > 80: arg_preview = arg_preview[:77] + "…"
            # ask_user budget guard — prevent the ask→answer→ask loop
            if name == "ask_user":
                if ask_user_count >= MAX_ASK_USER:
                    console.print(f"  [yellow]⚠ ask_user limit ({MAX_ASK_USER}) "
                                  f"reached — telling the model to proceed[/]")
                    history.append({"role": "user", "content":
                        f"<tool_result name=\"ask_user\">\n"
                        f"[ask_user limit reached — you have already asked "
                        f"{MAX_ASK_USER} questions this turn. Do NOT call "
                        f"ask_user again. Proceed now using the answers you "
                        f"already have, or pick sensible defaults, then give "
                        f"the final answer.]\n</tool_result>"})
                    aggregate_stats["tool_calls"] += 1
                    continue
                ask_user_count += 1
            aggregate_stats["tool_calls"] += 1
            if _FLAGS["verbose_tools"]:
                console.print(Panel(
                    Syntax(json.dumps(c, ensure_ascii=False, indent=2), "json",
                           theme="ansi_dark", background_color="default"),
                    title=f"🔧 tool call ({it+1}/{max_iters})  [dim](ESC to cancel)[/]",
                    border_style="cyan"))
            approval_t0 = time.time()
            if _tool_needs_approval(c, allow_dangerous):
                if not request_tool_approval(c, allow_dangerous):
                    approval_wait = time.time() - approval_t0
                    console.print(f"  [red]✗[/] [bold]{name}[/] [dim]· denied by user "
                                  f"after {approval_wait:.1f}s[/]")
                    history.append({"role": "user", "content":
                                    f"<tool_result name=\"{name}\">\n"
                                    f"User denied execution\n</tool_result>"})
                    continue
            approval_wait = time.time() - approval_t0
            payload_hint = ""
            if name in ("write_file", "bash"):
                content_len = sum(len(str(v)) for v in (args or {}).values())
                if content_len > 500:
                    payload_hint = f"  ({content_len:,} chars payload)"
            exec_t0 = time.time()
            expected_timeout = _TOOL_EXPECTED_TIMEOUT.get(name, 30)
            try:
                if name in _INTERACTIVE_TOOLS:
                    # No spinner — the tool itself prints a panel + reads stdin;
                    # a rich Live region would hide the question.
                    result, ok = execute_tool(c, allow_dangerous, pre_approved=True)
                else:
                    ticker_stop, status_cm = _start_tool_spinner(
                        name, arg_preview, payload_hint, exec_t0, expected_timeout)
                    try:
                        result, ok = execute_tool(c, allow_dangerous, pre_approved=True)
                    finally:
                        ticker_stop()
                        status_cm.__exit__(None, None, None)
                        try: console.file.flush()
                        except Exception: pass
            except KeyboardInterrupt:
                exec_elapsed = time.time() - exec_t0
                console.print(
                    f"[yellow]  ⚠[/] [bold]{name}[/] "
                    f"[dim]· cancelled (ESC) · {exec_elapsed:.1f}s[/]")
                result, ok = "[cancelled by user via ESC]", False
                history.append({"role": "user",
                                "content": f"<tool_result name=\"{name}\">\n{result}\n</tool_result>"})
                raise
            exec_elapsed = time.time() - exec_t0
            symbol = "[green]✓[/]" if ok else "[red]✗[/]"
            time_str = f"{exec_elapsed:.1f}s"
            if approval_wait > 1.0:
                time_str = f"{exec_elapsed:.1f}s exec + {approval_wait:.1f}s approve-wait"
            if _FLAGS["verbose_tools"]:
                console.print(Panel(_truncate(result, 1500),
                                    title=f"{'✓' if ok else '✗'} result · {time_str}",
                                    border_style="green" if ok else "red"))
            else:
                first_line = next(
                    (ln for ln in result.splitlines() if ln.strip()), "(empty)")
                preview = first_line[:60] + ("…" if len(first_line) > 60 else "")
                console.print(
                    f"  {symbol} [bold]{name}[/]"
                    f"[dim]([cyan]{arg_preview[:50]}[/])"
                    f" · {time_str} · "
                    f"{len(result):,} chars[/] [white]{preview}[/]")
            history.append({"role": "user",
                            "content": f"<tool_result name=\"{name}\">\n{result}\n</tool_result>"})
            if ok:
                executed_call_keys.add(exec_key)

        # Drift guard: every N tool-call iterations, re-state the goal so the
        # model doesn't wander off into unrelated searches.
        if (original_question and (it + 1) % DRIFT_NUDGE_EVERY == 0
                and it < max_iters - 1):
            aggregate_stats["drift_nudges"] += 1
            console.print(f"[dim]  🎯 stay-on-task reminder at iter {it+1}[/]")
            history.append({"role": "user", "content":
                f"[stay-on-task] Reminder — the user's original question is:\n"
                f"  \"{original_question[:300]}\"\n\n"
                f"If the tool results so far are enough, ANSWER NOW. "
                f"Do not call tools for unrelated topics."
            })
    # Hit max iters with tool calls still pending → ask for a clean summary.
    # Re-quote the original question verbatim; after many tool results the
    # model often loses track of what was asked and refuses to synthesize.
    console.print(f"[yellow]⚠ max iterations ({max_iters}) — synthesizing final answer[/]")
    if original_question:
        synth_msg = (
            "You've reached the iteration limit. "
            f"The user's ORIGINAL question was:\n  \"{original_question[:500]}\"\n\n"
            "Answer it now from the <tool_result> blocks already in this "
            "conversation. Lead with the direct bottom-line answer in the first "
            "sentence, then back it with concrete facts from those results "
            "(numbers, dates, names), citing sources as [domain] or file:line "
            "where relevant. The tool results ARE in the history above — do not "
            "claim you lack context, and do not describe what the results "
            "contain instead of answering. Do NOT call any more tools."
        )
    else:
        synth_msg = (
            "You've reached the iteration limit. Give the final answer now: "
            "lead with the bottom-line answer, then the key supporting facts "
            "from the tool results. Do NOT call any more tools."
        )
    history.append({"role": "user", "content": synth_msg})
    try:
        final_reply, st = generate_reply(history, system,
                                         image=None, audio=None,
                                         max_tokens=max_tokens)
    except KeyboardInterrupt:
        raise
    history.append({"role": "assistant", "content": final_reply})
    aggregate_stats["tokens"] += st["tokens"]
    aggregate_stats["tps_sum"] += st["tps"]
    aggregate_stats["iters"] += 1
    return final_reply, aggregate_stats

# ╔════════════════════════════════════════════════════════════════════════╗
# ║ Research controller — deterministic, multi-round, keyword-expanding   ║
# ╚════════════════════════════════════════════════════════════════════════╝
# Why a controller (not just a prompt): small local models routinely (a) emit
# malformed tool calls and (b) stop after one search. So instead of telling the
# model to "keep searching", the controller OWNS the loop: it calls web_search
# directly (model-agnostic — no tool-call syntax needed), counts unique source
# domains, and if coverage is thin it asks the model only for RELATED keywords,
# then searches again. The model is used for exactly three judgment tasks:
# drafting (uncertainty signal), proposing keywords, and final synthesis.

def _expand_keywords(query: str, tried: list, analysis=None, *,
                     allow_model: bool = True, gap: str = "", n: int = 3) -> list:
    """Return up to `n` NEW related search queries not already in `tried`.

    LLM-first (genuinely *related* terms — synonyms, broader/narrower, related
    entities, TH↔EN) with a deterministic heuristic fallback so it always
    yields something even if the model is offline or unhelpful."""
    tried_l = {t.strip().lower() for t in tried}
    out: list = []

    def _add(c: str):
        c = (c or "").strip().strip('"').strip()
        if not c:
            return
        cl = c.lower()
        if cl in tried_l or cl in {o.lower() for o in out}:
            return
        out.append(c)

    if allow_model:
        try:
            sys_b = ("You expand a search task into NEW related search queries. "
                     "Output ONLY the queries — one per line, no numbering, no "
                     "commentary, no quotes.")
            already = "; ".join(list(tried)[-8:]) or "(none)"
            prompt = (
                f'Original question: "{query}"\n'
                f'Already searched: {already}\n'
                f'Coverage so far: {gap or "insufficient — need more sources"}.\n\n'
                f'Give {n} DIFFERENT related search queries likely to surface NEW '
                f'information. Vary the angle: synonyms, broader/narrower terms, a '
                f'related entity, and include both Thai and English phrasings.')
            txt, _ = generate_reply([{"role": "user", "content": prompt}],
                                    sys_b, max_tokens=120)
            for line in (txt or "").splitlines():
                _add(line.lstrip("-*•0123456789.) ").strip())
                if len(out) >= n:
                    break
        except Exception:
            pass

    if len(out) < n:
        base = query.strip()
        if analysis and getattr(analysis, "search_angles", None):
            for a in analysis.search_angles:
                _add(a)
        # morphological / lingual fallback variants
        for suff in (" ล่าสุด", " latest", " 2026", " review",
                     " รายละเอียด", " ข้อมูลล่าสุด"):
            if len(out) >= n:
                break
            _add(base + suff)
        if _THAI_RE.search(base):           # Thai → strip to non-Thai remainder
            _add(re.sub(r"[ก-๿\s]+", " ", base).strip())

    return out[:n]


# Synthesis input budget — keep the corpus small enough that even a 4B local
# model finishes within the Ollama request timeout. Tunable via env.
_SYNTH_CORPUS_BUDGET = int(_env("THMES_RESEARCH_CORPUS", "6000") or 6000)
_SYNTH_BLOCK_CAP = 1400          # max chars kept per evidence block
_SYNTH_MAX_TOKENS = int(_env("THMES_RESEARCH_ANSWER_TOKENS", "1600") or 1600)


def _synthesize_research(query: str, evidence: list, lang: str = "th") -> str:
    """Write the final cited answer over the gathered evidence (model-agnostic).
    `evidence` is a list of (query, result_text).

    The corpus is bounded (per-block + total budget) so a small local model can
    finish within its request timeout — large fetched pages won't stall it."""
    if not evidence:
        return ""
    dt = current_datetime_context()
    blocks, used = [], 0
    for i, (q, res) in enumerate(evidence, 1):
        chunk = _truncate(res, _SYNTH_BLOCK_CAP)
        if used + len(chunk) > _SYNTH_CORPUS_BUDGET and blocks:
            break                # keep the prompt within budget
        # Surface the domains up-front so the model cites the real source
        # ([sanook.com]) instead of the block label. The block header is
        # deliberately NOT bracketed so it can't be mistaken for a citation.
        doms = sorted(_extract_domains(res))
        dom_tag = ", ".join(doms[:6]) if doms else "(no domain — cite a URL in the text)"
        blocks.append(f"--- evidence {i} | query: {q} | cite these sources: "
                      f"{dom_tag} ---\n{chunk}")
        used += len(chunk)
    corpus = "\n\n".join(blocks)
    lang_line = ("ตอบเป็นภาษาไทยทั้งหมด" if lang == "th"
                 else "Answer in the user's language")
    sys_b = (
        f"{dt}\n\n"
        "[Research synthesis] Answer the user's question from the web evidence "
        "below. Your job is to REASON from the facts to a conclusion — not to "
        "describe what the sources contain.\n\n"
        "STRUCTURE — follow in this order:\n"
        "1. Open with the direct bottom-line answer in 1-2 sentences. For a "
        "yes/no or 'will X happen' question, commit to the best-supported "
        "position. For a forecast, give your best-supported view and label it a "
        "projection. NEVER open by saying the data is insufficient.\n"
        "2. Then 2-4 supporting points, each ONE to TWO sentences max. Each must "
        "pull a CONCRETE fact from the evidence — a number, date, trend, or "
        "named expert view — and connect it to the conclusion. Lead each point "
        "with the fact, not with filler. Cite the real source domain shown on "
        "each block's 'cite these sources:' line, e.g. [sanook.com]. NEVER cite "
        "as [evidence 1], [search 1], or any block number.\n"
        "3. Close with ONE short caveat line (≤1 sentence) flagging the main "
        "uncertainty or what to watch next.\n\n"
        "Keep the whole answer tight — aim for under ~180 words. Finish every "
        "sentence; never stop mid-thought.\n\n"
        "RULES:\n"
        "- Use ONLY the evidence; do not invent facts — but you MUST interpret "
        "and weigh them into a judgment. That interpretation is the answer.\n"
        "- Do NOT write meta-commentary about the evidence itself (e.g. 'the "
        "data is only historical…', 'I cannot determine because…'). If a real "
        "gap exists, fold it into one clause in point 3 — never make it the "
        "headline, and never list what each source 'contains'.\n"
        "- If sources disagree or differ in date, prefer the most recent and "
        "say which.\n"
        f"- Be concrete and concise. {lang_line}."
    )
    user = (f'Question: "{query}"\n\n=== EVIDENCE ===\n{corpus}\n=== END EVIDENCE ===\n\n'
            "Write the answer now. First line = the direct bottom-line answer; "
            "then the supporting points.")
    try:
        txt, _ = generate_reply([{"role": "user", "content": user}], sys_b,
                                max_tokens=min(DEFAULT_MAX_TOKENS, _SYNTH_MAX_TOKENS))
        answer = _strip_model_artifacts(TOOL_CALL_RE.sub("", txt)).strip()
    except KeyboardInterrupt:
        raise
    except Exception as e:
        answer = f"[synthesis failed] {type(e).__name__}: {e}"
    # If the model couldn't synthesize (timeout / OOM / empty), degrade to a
    # deterministic digest of the sources so the user still gets value.
    if (not answer) or answer.startswith(("[ollama error]", "[synthesis failed]")):
        return _evidence_digest(query, evidence, lang)
    return answer


def _evidence_digest(query: str, evidence: list, lang: str = "th") -> str:
    """Model-free fallback: a plain bullet list of the sources gathered, with a
    one-line snippet each. Used when synthesis fails so research never returns
    nothing-but-an-error."""
    lines = []
    seen: set = set()
    for q, res in evidence:
        for raw in (res or "").splitlines():
            s = raw.strip()
            if not s or s.startswith(("[", "═", "http")) or _URL_IN_TEXT_RE.match(s):
                continue
            doms = _extract_domains(res)
            dom = next(iter(sorted(doms)), "")
            key = (dom, s[:60])
            if dom and key not in seen:
                seen.add(key)
                lines.append(f"- [{dom}] {s[:200]}")
            break
    if not lines:
        return ""
    head = ("สรุปอัตโนมัติไม่สำเร็จ — นี่คือแหล่งข้อมูลที่ค้นพบ:"
            if lang == "th" else
            "Could not auto-summarize — here are the sources found:")
    return head + "\n" + "\n".join(lines[:8])


def run_research_loop(query: str, *, depth: int = None, max_rounds: int = None,
                      max_results: int = 5, analysis=None,
                      allow_model_keywords: bool = None) -> tuple:
    """Deterministic multi-round web research.

    Round 1 searches the analysis' angles; after each round it counts unique
    source domains and — if still short of `depth` and rounds remain — asks for
    RELATED keywords and searches again. Stops on: enough domains, two stagnant
    rounds (no new sources), or `max_rounds`. Then synthesizes a cited answer.

    Returns (answer_text, meta) where meta = {rounds, n_sources, domains,
    queries, evidence_count}. answer_text is "" only when nothing was found."""
    depth = depth if depth is not None else int(_FLAGS.get("research_depth", 3))
    max_rounds = (max_rounds if max_rounds is not None
                  else int(_FLAGS.get("research_rounds", 3)))
    if allow_model_keywords is None:
        allow_model_keywords = bool(_FLAGS.get("research_kw_llm", True))
    analysis = analysis or _analyze_prompt(query)
    lang = getattr(analysis, "language", "th")

    def _search_one(q: str, fetch: bool) -> str:
        region = "th-th" if _THAI_RE.search(q) else "us-en"
        mode = "news" if getattr(analysis, "time_sensitive", False) else "text"
        tl = "w" if getattr(analysis, "time_sensitive", False) else None
        return tool_web_search(q, max_results=max_results, mode=mode,
                               timelimit=tl, region=region, auto_fetch=fetch)

    entity = (_extract_finance_entity(query)
              if getattr(analysis, "domain", "") == "finance" else None)
    angles = [a for a in (getattr(analysis, "search_angles", None)
                          or _build_search_angles(query, analysis.domain,
                                                  analysis.intent, lang, entity))
              if a and a.strip()] or [query]

    tried: list = []
    evidence: list = []
    domains: set = set()
    stagnant = 0
    rounds = 0

    while rounds < max_rounds:
        rounds += 1
        batch = []
        for q in angles:
            ql = q.strip().lower()
            if ql and ql not in {t.lower() for t in tried}:
                tried.append(q.strip())
                batch.append(q.strip())
        if not batch:
            break
        console.print(f"[dim]  🔎 round {rounds}/{max_rounds}: "
                      + " · ".join(repr(b) for b in batch) + "[/]")
        before = len(domains)
        for i, q in enumerate(batch):
            try:
                res = _search_one(q, fetch=(i == 0))   # deep-fetch first query only
            except KeyboardInterrupt:
                raise
            except Exception as e:
                res = f"(search error: {type(e).__name__}: {e})"
            evidence.append((q, res))
            domains |= _extract_domains(res)
        gained = len(domains) - before
        console.print(f"[dim]     ↳ +{gained} source(s) "
                      f"(have {len(domains)}/{depth})[/]")
        if len(domains) >= depth:
            break
        if gained == 0:
            stagnant += 1
            if stagnant >= 2:
                console.print("[dim]     ↳ no new sources — stopping[/]")
                break
        else:
            stagnant = 0
        if rounds >= max_rounds:
            break
        angles = _expand_keywords(query, tried, analysis,
                                  allow_model=allow_model_keywords,
                                  gap=f"have {len(domains)} of {depth} sources")
        if not angles:
            console.print("[dim]     ↳ no further keywords — stopping[/]")
            break
        console.print(f"[dim]     ↳ expanding keywords → "
                      + " · ".join(repr(a) for a in angles) + "[/]")

    answer = _synthesize_research(query, evidence, lang)
    meta = {"rounds": rounds, "n_sources": len(domains),
            "domains": sorted(domains), "queries": tried,
            "evidence_count": len(evidence)}
    return answer, meta


def _run_and_present_research(user_msg: str, analysis, store, session_id: str,
                             history: list, *, depth: int = None,
                             reason: str = ""):
    """Run the research controller, print + persist the answer, and append it to
    `history`. Returns the answer string (or None if nothing was found / the
    user cancelled). Shared by the auto path and the `/research` command."""
    console.print(f"[bold cyan]🔬 ค้นข้อมูลหลายมิติ[/]"
                  + (f" [dim]({reason})[/]" if reason else "") + " [dim]…[/]")
    t0 = time.time()
    # ESC (KeyboardInterrupt) propagates to the caller so it can roll back.
    answer, meta = with_esc_cancel(run_research_loop, user_msg,
                                   depth=depth, analysis=analysis)
    elapsed = time.time() - t0
    if not answer:
        console.print("[yellow]  ⚠ ไม่พบข้อมูลจากการค้นหา[/]")
        return None
    history.append({"role": "assistant", "content": answer})
    try:
        store.add_message(session_id, "assistant", answer[:5000])
    except Exception:
        pass
    console.print(Rule(style="dim"))
    console.print(Markdown(answer))
    console.print(
        f"[dim]🔬 {meta['rounds']} round(s) · {meta['n_sources']} source(s) · "
        f"{len(meta['queries'])} queries · {elapsed:.1f}s[/]")
    console.print(Rule(style="dim"))
    return answer


# ── Privacy-relay pipeline (controller + presenter) ──────────────────────────
_RELAY_SYS = (
    "You are a careful assistant. Some values in the conversation have been "
    "replaced with redaction placeholders shaped like __PII_LABEL_N__ (for "
    "example __PII_EMAIL_1__, __PII_PERSON_2__). Treat each placeholder as an "
    "opaque stand-in for a real value of that kind: reason about it normally and "
    "ALWAYS copy placeholders verbatim into your answer wherever you refer to "
    "them — never invent, translate, expand, or alter a placeholder. "
    "Answer in the user's language. Reply with ONLY the final result — be "
    "direct and concise, do NOT show your reasoning, thinking steps, analysis, "
    "or any preamble."
)


def _relay_ner(text: str) -> list:
    """Local-model NER for contextual entities (person/org/project). Best-effort;
    runs on the loaded LOCAL model (no cloud), failures degrade to []."""
    if not _MASK_OK or not (text or "").strip():
        return []
    try:
        # temperature=0 → deterministic, reproducible masking (privacy must not
        # depend on a stochastic roll of a small model).
        # Headroom: small reasoning models (gemma) emit a long think-aloud BEFORE
        # the JSON array — 512 tokens truncated it. 1536 lets the array land.
        reply, _ = generate_reply([{"role": "user", "content": NER_PROMPT + text}],
                                  "", max_tokens=1536, temperature=0, think=False)
        return parse_ner(reply)
    except Exception:
        return []


_RELAY_PATH_RE = re.compile(r"(?:(?<=\s)|^)(~?/[^\s'\"`]+|[A-Za-z]:\\[^\s'\"`]+)")


def _relay_gather_files(text: str, *, max_files: int = 4, max_bytes: int = 16000) -> list:
    """Build-data step: read any existing LOCAL files the user referenced by path
    so the cloud can work on them (e.g. "ทำ report จากไฟล์ /path/x.log"). Their
    content is masked downstream like everything else. Read-only, size-capped."""
    out: list = []
    seen: set = set()
    for m_ in _RELAY_PATH_RE.finditer(text or ""):
        raw = m_.group(1).rstrip(".,;:)]}")
        if raw in seen:
            continue
        seen.add(raw)
        try:
            p = Path(raw).expanduser()
            if p.is_file() and p.stat().st_size <= max_bytes * 6:
                out.append((str(p), p.read_text(errors="replace")[:max_bytes]))
        except Exception:
            continue
        if len(out) >= max_files:
            break
    return out


def run_mask_pipeline(history, *, cloud_model, vault, max_tokens, ner_fn,
                      agent_system="", gather_files=True):
    """MASK the outgoing payload → leak-scan → cloud REASON → UNMASK locally.

    Returns (final_text, meta). final_text is None when aborted (leak detected or
    cloud failure) so the caller can fall back to a local answer. NER runs on the
    latest user message only; the vault re-applies known values to the rest.
    """
    masked_extra = vault.mask(agent_system, ner_fn=None) if agent_system else ""
    sys_full = _RELAY_SYS + (("\n\n" + masked_extra) if masked_extra else "")

    last_user = max((i for i, h in enumerate(history)
                     if h.get("role") == "user"), default=-1)

    # Build-data: pull in any local files the latest message references, so the
    # cloud can analyze/report on them. File content is masked like everything else.
    n_files = 0
    if gather_files and last_user >= 0:
        gathered = _relay_gather_files(history[last_user].get("content", ""))
        if gathered:
            n_files = len(gathered)
            blob = "\n\n".join(f"--- file: {p} ---\n{c}" for p, c in gathered)
            history = [dict(h) for h in history]          # copy — don't mutate caller's
            history[last_user]["content"] += "\n\n[Local files attached for analysis]\n" + blob

    masked_hist = []
    for i, h in enumerate(history):
        content = h.get("content", "") or ""
        use_ner = ner_fn if (i == last_user and content) else None
        masked_hist.append({**h, "content": vault.mask(content, ner_fn=use_ner) if content else content})

    # Leak guard on the FULL outgoing payload before it touches the network.
    leaks = list(vault.leak_scan(sys_full))
    for h in masked_hist:
        leaks += vault.leak_scan(h.get("content", ""))
    if leaks:
        return None, {"aborted": "leak", "leaks": leaks}

    # think=False → thinking cloud models (glm/gpt-oss/deepseek) return the answer,
    # not their chain-of-thought (which would otherwise be the whole reply).
    out, st = generate_reply(masked_hist, sys_full, max_tokens=max_tokens,
                             model=cloud_model, think=False)
    if not out or out.startswith("[ollama"):
        return None, {"aborted": "cloud", "err": out or ""}

    final = vault.unmask(out)
    return final, {
        "stats": vault.stats(),
        "cloud": cloud_model,
        "tokens": st.get("tokens", 0),
        "files": n_files,
        "residual": "__PII_" in final,   # cloud mangled a token → left a placeholder
    }


# ── Agentic relay: cloud reasons + decides tool calls, LOCAL executes ─────────
# Added to the cloud system prompt only when relay_tools is on. Tells the cloud it
# may call tools and that placeholders inside tool ARGUMENTS are restored locally.
_RELAY_TOOLS_SYS = (
    " You may call tools (read/write files, run shell/python, search the web). "
    "This machine executes them locally and returns each result — results may also "
    "contain __PII_LABEL_N__ placeholders, which you treat the same way. When you "
    "put a placeholder in a tool ARGUMENT (a path, file content, a command), copy "
    "it verbatim too — the machine restores the real value before running. Never "
    "guess, expand, or invent the value behind a placeholder. Call tools when you "
    "need to act on real data; when you are done, reply with the final answer and "
    "no tool call."
)

# Tools whose output is free-form text (may carry names the regex rules miss) →
# run the local NER pass when re-masking their result. bash/python output is
# usually structured, and the rule layer + leak_scan already cover its secrets,
# so we skip the (slower) NER call there to keep the loop responsive.
_RELAY_NER_RESULT_TOOLS = {"read_file", "grep", "list_dir", "web_fetch", "web_search"}


def _relay_unmask_args(value, vault):
    """Restore real values inside a cloud-issued tool call's arguments so the LOCAL
    execution uses the real path/content/command. The cloud speaks only in
    __PII_*__ placeholders; unmask is the deterministic inverse. Walks nested
    dicts/lists so a placeholder anywhere in the args is restored."""
    if isinstance(value, str):
        return vault.unmask(value)
    if isinstance(value, dict):
        return {k: _relay_unmask_args(v, vault) for k, v in value.items()}
    if isinstance(value, (list, tuple)):
        return [_relay_unmask_args(v, vault) for v in value]
    return value


def _relay_mask_result(result, vault, *, run_ner):
    """Re-mask a LOCAL tool result before it goes back to the cloud, then leak-scan.

    If a high-risk secret survives masking (couldn't be tokenized — e.g. a key the
    rules don't recognize), REDACT the whole result: the tool already ran on the
    machine, so the work is done; the cloud just doesn't see the raw output. Keeps
    the agentic loop alive while never letting an unmaskable secret leave.
    Returns (cloud_safe_text, redacted_bool)."""
    text = result if isinstance(result, str) else str(result or "")
    masked = vault.mask(text, ner_fn=(_relay_ner if run_ner else None))
    leaks = vault.leak_scan(masked)
    if leaks:
        return (f"[relay: tool result withheld — {len(leaks)} value(s) could not be "
                f"safely masked; the action ran locally on your machine]"), True
    return masked, False


def run_relay_agent_loop(history, *, cloud_model, vault, tools_on, allow_dangerous,
                         max_tokens, ner_fn, agent_system="", max_iters=6,
                         gather_files=True, on_event=None):
    """Agentic relay — the CLOUD is the brain, the LOCAL machine is the hands.

    The cloud reasons over masked placeholders and decides which tools to call; this
    machine executes every tool and re-masks the result before it returns to the
    cloud. The symmetry is the whole trick:
      • cloud → local : UNMASK the call arguments (exec needs real values)
      • local → cloud : MASK the tool result   (raw PII never leaves the machine)
    The vault accumulates across rounds, so a value surfaced by read_file in round 1
    keeps the same placeholder the cloud can reference in round 3.

    Returns (final_text, meta). final_text is None on a hard abort (initial leak or a
    first-round cloud failure) so the caller falls back to a local agent_turn.
    """
    known_tools = set(TOOLS.keys())
    sys_full = _RELAY_SYS + _RELAY_TOOLS_SYS
    masked_extra = vault.mask(agent_system, ner_fn=None) if agent_system else ""
    if masked_extra:
        sys_full += "\n\n" + masked_extra

    last_user = max((i for i, h in enumerate(history)
                     if h.get("role") == "user"), default=-1)

    # Build-data: pull any local files the latest message references into it, so the
    # cloud can act on their (masked) content — same as the one-shot pipeline.
    n_files = 0
    if gather_files and last_user >= 0:
        gathered = _relay_gather_files(history[last_user].get("content", ""))
        if gathered:
            n_files = len(gathered)
            blob = "\n\n".join(f"--- file: {p} ---\n{c}" for p, c in gathered)
            history = [dict(h) for h in history]          # copy — don't mutate caller's
            history[last_user]["content"] += "\n\n[Local files attached for analysis]\n" + blob

    # Mask the whole starting payload (NER on the latest user message only). From
    # here on the loop runs ENTIRELY on this masked history — the real values live
    # only in the vault and inside execute_tool (just-in-time unmask).
    cloud_history = []
    for i, h in enumerate(history):
        content = h.get("content", "") or ""
        use_ner = ner_fn if (i == last_user and content) else None
        cloud_history.append({**h, "content": vault.mask(content, ner_fn=use_ner) if content else content})

    # Leak guard on the initial outgoing payload before it touches the network.
    leaks = list(vault.leak_scan(sys_full))
    for h in cloud_history:
        leaks += vault.leak_scan(h.get("content", ""))
    if leaks:
        return None, {"aborted": "leak", "leaks": leaks}

    # Native function-calling schema (the cloud is always reached over Ollama HTTP
    # via model=, so this does NOT depend on the local mm.backend).
    _ollama_tools = _ollama_tools_schema(tools_on) if tools_on else None

    meta = {"cloud": cloud_model, "files": n_files, "tool_calls": 0,
            "iters": 0, "redacted": 0, "tokens": 0}
    executed_keys: set = set()   # cross-iter dedupe (cloud occasionally repeats a call)
    # Empty-turn budget — small models occasionally return a turn with no content AND
    # no tool call mid-chain (stalled mid-thought). That is NOT a cloud failure: nudge
    # to continue instead of aborting the tool loop. Mirrors agent_turn's MAX_EMPTY_NUDGES.
    empty_nudges = 0
    MAX_EMPTY_NUDGES = 3

    for it in range(max_iters):
        meta["iters"] = it + 1
        out, st = generate_reply(cloud_history, sys_full, max_tokens=max_tokens,
                                 model=cloud_model, tools=_ollama_tools, think=False)
        meta["tokens"] += (st or {}).get("tokens", 0)
        # Distinguish a real cloud ERROR ("[ollama …]") from an empty STALL ("").
        if out and out.startswith("[ollama"):
            if it == 0:
                return None, {"aborted": "cloud", "err": out}
            break   # cloud broke after real work — synthesize from what we have
        if not (out or "").strip():
            # Stalled turn — nudge to continue (bounded), don't lose the tool chain.
            if empty_nudges < MAX_EMPTY_NUDGES:
                empty_nudges += 1
                cloud_history.append({"role": "user", "content":
                    "(continue) Keep going with the task: call the next tool now, or "
                    "if everything is finished, reply with the final answer."})
                continue
            break
        cloud_history.append({"role": "assistant", "content": out})

        calls, _notes = parse_tool_calls(out, known_tools=known_tools)
        if not calls:
            final = vault.unmask(out)            # no tool call → this is the answer
            meta["residual"] = "__PII_" in (final or "")
            meta["stats"] = vault.stats()
            return final, meta
        empty_nudges = 0                         # productive turn → reset stall budget

        for call in calls:
            name = call.get("name")
            real_call = {"name": name,
                         "arguments": _relay_unmask_args(call.get("arguments", {}) or {}, vault)}
            fp = _call_fingerprint(real_call)
            if fp in executed_keys:
                cloud_history.append({"role": "user", "content":
                    f'<tool_result name="{name}">[already executed this exact call '
                    f'earlier in the turn — not repeated]</tool_result>'})
                continue
            executed_keys.add(fp)
            if on_event:
                on_event("tool", name, real_call["arguments"])
            # Execute LOCALLY with REAL args. Approval (for ask-risk tools) shows the
            # real action to the human — defense in depth + informed consent.
            result, _ok = execute_tool(real_call, allow_dangerous)
            meta["tool_calls"] += 1
            safe, redacted = _relay_mask_result(
                result, vault, run_ner=(name in _RELAY_NER_RESULT_TOOLS))
            if redacted:
                meta["redacted"] += 1
            if on_event:
                on_event("result", name, safe)
            cloud_history.append({"role": "user", "content":
                f'<tool_result name="{name}">{safe}</tool_result>'})

    # max_iters reached (or cloud broke after progress) → one final tools-free round
    # so the cloud answers over everything it gathered.
    out, st = generate_reply(
        cloud_history,
        sys_full + "\n\nProvide your final answer now using ONLY the information "
        "gathered above. Do not call any more tools.",
        max_tokens=max_tokens, model=cloud_model, think=False)
    meta["tokens"] += (st or {}).get("tokens", 0)
    if out and not out.startswith("[ollama"):
        final = vault.unmask(out)
    else:
        final = vault.unmask(next((h["content"] for h in reversed(cloud_history)
                                   if h.get("role") == "assistant"), ""))
    meta["residual"] = "__PII_" in (final or "")
    meta["stats"] = vault.stats()
    meta["maxed"] = True
    return (final or None), meta


# ── Self-heal: verify locally → LOCAL model triages the error → re-ask the cloud ──
# Closes the loop so a runtime failure (not just a syntax slip) is caught, distilled
# locally, and handed back to the cloud to fix — without a human in the middle.
_RELAY_TRIAGE_PROMPT = (
    "คุณคือผู้ช่วยดีบั๊ก. วิเคราะห์ error/ผลทดสอบที่ล้มเหลวข้างล่าง แล้วตอบสั้น ๆ 2-3 บรรทัด: "
    "(1) สาเหตุที่แท้จริง (2) สิ่งที่ต้องแก้ในโค้ดให้เจาะจง. ตอบกระชับ ไม่ต้องมี preamble "
    "หรือ markdown. หมายเหตุ: error message บางครั้งทำให้เข้าใจผิด — ดูบริบทให้รอบด้าน.\n\nERROR:\n"
)


def _relay_triage(raw_error: str) -> str:
    """LOCAL model reads the REAL error (it has the real values) and distills a short
    diagnosis. Best-effort; never blocks the heal loop. Runs on `mm` (no cloud)."""
    if not (raw_error or "").strip():
        return ""
    try:
        diag, _ = generate_reply(
            [{"role": "user", "content": _RELAY_TRIAGE_PROMPT + raw_error[:4000]}],
            "", max_tokens=512, temperature=0, think=False)
        return (diag or "").strip()
    except Exception:
        return ""


def _relay_run_verify(cmd: str, *, timeout: int = 90) -> tuple[bool, str]:
    """Run the user-set verify command locally. Returns (passed, combined_output).
    passed = exit 0. Output is captured (stdout+stderr) and trimmed for feedback."""
    try:
        r = subprocess.run(cmd, shell=True, capture_output=True, text=True,
                           timeout=timeout)
        out = ((r.stdout or "") + (r.stderr or "")).strip()
        return r.returncode == 0, out
    except subprocess.TimeoutExpired:
        return False, f"[verify timed out after {timeout}s]"
    except Exception as e:
        return False, f"[verify could not run] {type(e).__name__}: {e}"


def _relay_heal_prompt(raw_error: str, diagnosis: str) -> str:
    """The follow-up turn fed back to the cloud. (Masked by the relay before sending —
    real paths/values in the error become placeholders.)"""
    parts = ["The code you produced FAILED verification when actually run.\n",
             "Verification output / error:\n", (raw_error or "")[:3000], "\n\n"]
    if diagnosis:
        parts += ["A LOCAL model analyzed it (treat as a HINT — it can be wrong; "
                  "trust the raw error above too):\n", diagnosis, "\n\n"]
    parts += ["Read the current file(s) with the tools if needed, then FIX the code so "
              "verification passes. Apply the fix with the tools, do not just explain."]
    return "".join(parts)


def run_relay_selfheal(history, *, cloud_model, vault, tools_on, allow_dangerous,
                       max_tokens, ner_fn, agent_system="", max_iters=6,
                       verify_cmd="", heal_attempts=3, on_event=None, on_attempt=None):
    """run_relay_agent_loop + a verify→triage→re-ask heal loop.

    Each attempt: cloud builds (loop) → run verify_cmd locally → if it fails, the LOCAL
    model triages the raw error and (error + diagnosis) is appended as a new turn so the
    next attempt's cloud round fixes it. Stops on pass, on a hard abort, or after
    `heal_attempts`. Heal turns live in a private copy — they don't pollute the session.
    Returns (final, meta) like run_relay_agent_loop, with meta['attempt']/['verify_ok']."""
    hist = [dict(h) for h in history]
    final, meta = None, {}
    n = max(1, int(heal_attempts or 1))
    for attempt in range(1, n + 1):
        final, meta = run_relay_agent_loop(
            hist, cloud_model=cloud_model, vault=vault, tools_on=tools_on,
            allow_dangerous=allow_dangerous, max_tokens=max_tokens, ner_fn=ner_fn,
            agent_system=agent_system, max_iters=max_iters, on_event=on_event)
        meta["attempt"] = attempt
        if final is None or not verify_cmd:
            return final, meta              # hard abort, or no verify configured
        ok, raw = _relay_run_verify(verify_cmd)
        meta["verify_ok"] = ok
        meta["verify_out"] = raw[:600]
        if on_attempt:
            on_attempt(attempt, ok, raw, None)
        if ok or attempt >= n:
            return final, meta
        diag = _relay_triage(raw)           # ← LOCAL model analyzes the error itself
        meta["triage"] = diag
        if on_attempt:
            on_attempt(attempt, ok, raw, diag)
        hist.append({"role": "assistant", "content": final})
        hist.append({"role": "user", "content": _relay_heal_prompt(raw, diag)})
    return final, meta


def _run_and_present_relay_agent(user_msg, store, session_id, history, *, cloud_model,
                                 vault, tools_on, allow_dangerous, agent_system=""):
    """Run the AGENTIC relay loop, print + persist the unmasked answer, append it to
    `history`. Returns the answer, or None if aborted (caller falls back local)."""
    if not _MASK_OK or vault is None:
        return None
    console.print("[bold cyan]🛡️  Privacy relay[/] [magenta](agentic)[/] "
                  "[dim]— cloud decides · this machine executes · results re-masked …[/]")
    t0 = time.time()

    def _on_event(kind, name, payload):
        if kind == "tool":
            console.print(f"[dim]  🤖 cloud → [/][cyan]{name}[/] "
                          f"[dim](running locally on real data)[/]")

    def _on_attempt(attempt, ok, raw, diag):
        if ok:
            console.print(f"[green]  ✓ verify ผ่าน (รอบ {attempt})[/]")
        elif diag is None:
            console.print(f"[yellow]  ✗ verify ล้มเหลว (รอบ {attempt})[/] "
                          f"[dim]{(raw or '').strip()[:160]}[/]")
        else:
            console.print(f"[dim]  🔎 local triage:[/] {(diag or '(ไม่มี)').strip()[:200]}")
            console.print("[dim]  ↩ ส่ง error+คำวินิจฉัยกลับให้ cloud แก้ …[/]")

    verify_cmd = (_FLAGS.get("relay_verify_cmd") or "").strip()
    heal = int(_FLAGS.get("relay_heal_attempts", 3) or 3)
    if verify_cmd:
        console.print(f"[dim]  🧪 self-heal: verify = [/][cyan]{verify_cmd}[/] "
                      f"[dim](สูงสุด {heal} รอบ)[/]")
    _common = dict(
        cloud_model=cloud_model, vault=vault, tools_on=tools_on,
        allow_dangerous=allow_dangerous,
        max_tokens=_FLAGS.get("relay_reason_tokens", 3072),
        ner_fn=_relay_ner, agent_system=agent_system,
        max_iters=int(_FLAGS.get("relay_max_iters", 6) or 6), on_event=_on_event)
    if verify_cmd:
        final, meta = run_relay_selfheal(
            history, verify_cmd=verify_cmd, heal_attempts=heal,
            on_attempt=_on_attempt, **_common)
    else:
        final, meta = run_relay_agent_loop(history, **_common)
    elapsed = time.time() - t0

    if final is None:
        why = (meta or {}).get("aborted")
        if why == "leak":
            console.print(f"[red]  ✖ leak-scan จับข้อมูลที่ไม่ควรส่งขึ้น cloud "
                          f"({len((meta or {}).get('leaks', []))} จุด) — ยกเลิกการส่ง[/]")
        elif why == "cloud":
            console.print("[yellow]  ⚠ cloud ล้มเหลว[/]"
                          f"\n[dim]{((meta or {}).get('err') or '')[:200]}[/]")
        return None

    stats = meta.get("stats", {})
    summary = ", ".join(f"{v} {k.lower()}" for k, v in sorted(stats.items())) or "ไม่มี"
    history.append({"role": "assistant", "content": final})
    try:
        store.add_message(session_id, "assistant", final[:5000])
    except Exception:
        pass
    console.print(Rule(style="dim"))
    console.print(Markdown(final))
    tail = (" · [yellow]มี placeholder เหลือใน output (cloud เพี้ยน token)[/]"
            if meta.get("residual") else "")
    redacted = meta.get("redacted", 0)
    red_str = f" · [yellow]{redacted} result(s) ถูก redact[/]" if redacted else ""
    heal_str = ""
    if "verify_ok" in meta:
        heal_str = (f" · [green]verify ✓ (รอบ {meta.get('attempt', 1)})[/]"
                    if meta.get("verify_ok")
                    else f" · [red]verify ✗ หลัง {meta.get('attempt', 1)} รอบ[/]")
    console.print(f"[dim]🛡️ masked: {summary} · {meta.get('tool_calls', 0)} tool calls · "
                  f"{meta.get('iters', 0)} iters · cloud={cloud_model} · {elapsed:.1f}s{red_str}{heal_str}{tail}[/]")
    if _FLAGS.get("relay_show_values") and vault.mapping():
        console.print("[dim]  vault: "
                      + "; ".join(f"{t}={r}" for t, r in vault.mapping()) + "[/]")
    console.print(Rule(style="dim"))
    return final


def _run_and_present_mask(user_msg, store, session_id, history, *, cloud_model,
                          vault, agent_system=""):
    """Run the relay pipeline, print + persist the unmasked answer, append it to
    `history`. Returns the answer, or None if aborted (caller falls back local)."""
    if not _MASK_OK or vault is None:
        return None
    console.print("[bold cyan]🛡️  Privacy relay[/] [dim]— mask → cloud → unmask …[/]")
    t0 = time.time()
    final, meta = with_esc_cancel(
        run_mask_pipeline, history,
        cloud_model=cloud_model, vault=vault,
        max_tokens=_FLAGS.get("relay_reason_tokens", 3072),
        ner_fn=_relay_ner, agent_system=agent_system)
    elapsed = time.time() - t0

    if final is None:
        why = (meta or {}).get("aborted")
        if why == "leak":
            console.print(f"[red]  ✖ leak-scan จับข้อมูลที่ไม่ควรส่งขึ้น cloud "
                          f"({len((meta or {}).get('leaks', []))} จุด) — ยกเลิกการส่ง[/]")
        elif why == "cloud":
            console.print("[yellow]  ⚠ cloud ล้มเหลว[/]"
                          f"\n[dim]{((meta or {}).get('err') or '')[:200]}[/]")
        return None

    stats = meta.get("stats", {})
    summary = ", ".join(f"{v} {k.lower()}" for k, v in sorted(stats.items())) or "ไม่มี"
    history.append({"role": "assistant", "content": final})
    try:
        store.add_message(session_id, "assistant", final[:5000])
    except Exception:
        pass
    console.print(Rule(style="dim"))
    console.print(Markdown(final))
    tail = (" · [yellow]มี placeholder เหลือใน output (cloud เพี้ยน token)[/]"
            if meta.get("residual") else "")
    console.print(f"[dim]🛡️ masked: {summary} · cloud={cloud_model} · {elapsed:.1f}s{tail}[/]")
    if _FLAGS.get("relay_show_values") and vault.mapping():
        console.print("[dim]  vault: "
                      + "; ".join(f"{t}={r}" for t, r in vault.mapping()) + "[/]")
    console.print(Rule(style="dim"))
    return final


# ╔════════════════════════════════════════════════════════════════════════╗
# ║ UI helpers                                                            ║
# ╚════════════════════════════════════════════════════════════════════════╝
def banner(agents_n, skills_n):
    title = Text("THMES — Thai Hermes Agentic Shell", style="bold cyan")
    sub = Text(f"{agents_n} agents · {skills_n} skills · {len(TOOLS)} tools · /help",
               style="dim")
    console.print(Panel(Group(title, sub), border_style="cyan"))


def _model_picker(ollama_models: dict, mlx_models: dict, default: str) -> str:
    """Interactive startup model selector shown once before loading any model.

    Returns the alias the user chose (or *default* if they just pressed Enter /
    Ctrl-C).  Skipped automatically when only one model is available."""
    entries: list[dict] = []
    for alias in mlx_models:
        ctx = MODEL_CONTEXT.get(alias, 0)
        ctx_str = f"{ctx // 1024}k" if ctx >= 1024 else (str(ctx) if ctx else "—")
        entries.append({"alias": alias, "type": "mlx",
                        "size": "", "params": "", "ctx": ctx_str})
    for alias, meta in sorted(ollama_models.items()):
        ctx = meta.get("ctx", 0) or 0
        ctx_str = f"{ctx // 1024}k" if ctx >= 1024 else (str(ctx) if ctx else "—")
        size = meta.get("size_gb", 0) or 0
        entries.append({
            "alias": alias, "type": "ollama",
            "size": f"{size:.1f}GB" if size else "",
            "params": meta.get("params", ""),
            "ctx": ctx_str,
        })

    if len(entries) <= 1:
        return default

    t = Table(show_header=True, header_style="bold dim", box=None, padding=(0, 1))
    t.add_column("#",      width=4, justify="right", style="dim")
    t.add_column("Model",  style="cyan", no_wrap=True)
    t.add_column("Type",   width=7)
    t.add_column("Size",   justify="right", style="dim")
    t.add_column("Params", justify="right", style="dim")
    t.add_column("Ctx",    justify="right", style="dim")

    for i, e in enumerate(entries):
        is_def = e["alias"] == default
        num    = f"[bold]▶{i + 1}[/]" if is_def else f"  {i + 1}"
        name   = f"[bold]{e['alias']}[/]" if is_def else e["alias"]
        type_tag = "[dim]mlx[/]" if e["type"] == "mlx" else "🦙"
        t.add_row(num, name, type_tag, e["size"], e["params"], e["ctx"])

    console.print(Panel(t,
                        title="[bold cyan]Select Model[/]",
                        subtitle=f"[dim]default: {default}[/]",
                        border_style="cyan"))
    console.print(f"[dim]  ↵ Enter = {default}   |   type number to pick a different model[/]\n")

    while True:
        try:
            raw = pt_prompt("model › ").strip()
        except (KeyboardInterrupt, EOFError):
            console.print(f"[dim]  → {default}[/]")
            return default
        if not raw:
            return default
        if raw.isdigit():
            idx = int(raw) - 1
            if 0 <= idx < len(entries):
                chosen = entries[idx]["alias"]
                console.print(f"[dim]  → {chosen}[/]")
                return chosen
        # accept bare Ollama tag (e.g. "gemma4:e4b" → "ol:gemma4:e4b")
        for e in entries:
            if e["alias"] == raw or e["alias"] == f"ol:{raw}":
                console.print(f"[dim]  → {e['alias']}[/]")
                return e["alias"]
        console.print(f"[yellow]  ✗ enter 1–{len(entries)}, or press Enter for default[/]")

def help_panel():
    t = Table(show_header=False, box=None, padding=(0, 2))
    t.add_column(style="cyan", no_wrap=True); t.add_column()
    for k, v in [
        ("/image PATH",            "attach image for next message"),
        ("/audio PATH",            "attach audio for next message"),
        ("/agent [NAME|list]",     "switch persona (Claude agents)"),
        ("/skill [NAME|list]",     "invoke a skill workflow"),
        ("/tool [list|on|off|allow NAME]", "manage tool execution"),
        ("/opencode [on|off]",     "🚀 toggle opencode delegation"),
        ("/verbose [on|off]",      "📋 verbose tool panels vs compact lines"),
        ("/auto [on|off|last]",    "🧠 smart-load: model picks its own context"),
        ("/context",               "📏 show current token usage + remaining"),
        ("/compact [N|on|off|threshold N]", "🗜  summarize old turns (N=keep)"),
        ("/session [list|load ID|new|archive|rename T]", "💾 persistent sessions (SQLite)"),
        ("/breakers [reset [NAME]]", "⛔ circuit breaker status / reset"),
        ("/research QUERY [--depth N] [--rounds N]", "🔬 deterministic multi-round research — searches, expands keywords, re-searches"),
        ("/plan TASK [· auto on|off]", "📐 draft+approve a step plan, then execute (seeds /task)"),
        ("/research auto [on|off]", "🔍 toggle auto multi-source hint on factual queries"),
        ("/relay [on|off|tools|verify|model|cats|deny|vault]", "🛡️  privacy relay: mask→cloud→unmask · tools→local exec · verify→self-heal"),
        ("/continuity [on|off]",   "🆕 auto-detect new topic → fresh session"),
        ("/task [list|add|done N|doing N|clear]", "📋 session task list (model + you share it)"),
        ("/queue [list|clear|on|off]", "📥 type-ahead while model works (opt-in via /queue on)"),
        ("/model [NAME|list|refresh|unload]",
                                       f"switch model: mlx ({'|'.join(MODELS)}) "
                                       f"or ollama (ol:<tag>); 'unload' frees RAM"),
        ("/system TEXT",           "custom system prompt"),
        ("/max N",                 "set max generation tokens"),
        ("/clear",                 "reset conversation"),
        ("/save FILE | /load FILE","persist conversation"),
        ("/stats",                 "show last-turn stats"),
        ("/help",                  "this help"),
        ("ESC",                   "cancel generation / tool execution"),
        ("Ctrl+C",                "clear input only (during typing)"),
        ("/quit | /exit | Ctrl+D", "leave"),
    ]: t.add_row(k, v)
    console.print(Panel(t, title="commands", border_style="dim"))

def list_panel(title: str, items: dict):
    t = Table(show_header=True, header_style="bold cyan", box=None, padding=(0, 2))
    t.add_column("name", style="green", no_wrap=True)
    t.add_column("description")
    for k in sorted(items):
        t.add_row(k, items[k]["description"] or "—")
    console.print(Panel(t, title=title, border_style="dim"))


def render_header(state: dict):
    """One-line live status strip printed before each input prompt."""
    mm = state["mm"]
    hist = state["history"]
    native = native_ctx()
    ctx = measure_context(hist, state.get("last_system", ""), mm.processor)
    pct = ctx["total_in"] / native * 100
    ctx_color = "green" if pct < 50 else "yellow" if pct < 80 else "red"

    pieces = [
        f"[bold cyan]📦 {mm.name}[/]",
    ]
    if state.get("current_agent"):
        role = state.get("agents", {}).get(state['current_agent'], {}).get("role", "")
        role_tag = f"[dim]:{role}[/]" if role else ""
        pieces.append(f"[magenta]👤 {state['current_agent']}{role_tag}[/]")
    pieces.append(f"[{'green' if state['tools_on'] else 'red'}]"
                  f"🔧 {'on' if state['tools_on'] else 'off'}[/]")
    pieces.append(f"[{'blue' if state['auto_load'] else 'dim'}]"
                  f"🧠 {'on' if state['auto_load'] else 'off'}[/]")
    pieces.append(f"[{ctx_color}]📏 {ctx['total_in']:,}/{native//1000}k ({pct:.0f}%)[/]")
    if _FLAGS["opencode_enabled"]:
        pieces.append("[cyan]🚀 oc[/]")
    # Circuit breaker indicator (only when something is open or half_open)
    snap = _BREAKER.snapshot()
    bad = [n for n, s in snap.items() if s["state"] != "closed"]
    if bad:
        pieces.append(f"[red]⛔ {len(bad)} open[/]")
    if state.get("session_id"):
        pieces.append(f"[dim]💾 sess:{state['session_id'][:6]}[/]")
    if state.get("last_peak"):
        pieces.append(f"[dim]🖥 {state['last_peak']:.1f}G[/]")
    if state.get("last_elapsed"):
        pieces.append(f"[dim]⏱  {state['last_elapsed']:.1f}s[/]")
    pieces.append(f"[dim]📝 {len(hist)}msg[/]")
    qsz = queue_size()
    if qsz:
        pieces.append(f"[green]📥 {qsz} queued[/]")
    if state.get("last_tps"):
        pieces.append(f"[dim]⚡ {state['last_tps']:.0f}tps[/]")

    console.print(Rule("  ".join(pieces), style="dim"))


def make_bottom_toolbar(state: dict):
    """Return a callable for PromptSession's bottom_toolbar."""
    def _bar():
        mm = state["mm"]
        hist = state["history"]
        native = native_ctx()
        ctx = measure_context(hist, state.get("last_system", ""), mm.processor)
        pct = int(ctx["total_in"] / native * 100)
        pct_bar = "█" * (pct // 5) + "░" * (20 - pct // 5)

        flags = []
        if state.get("pending_image"): flags.append("🖼")
        if state.get("pending_audio"): flags.append("🎵")
        if state["tools_on"]: flags.append("🔧")
        if state["auto_load"]: flags.append("🧠")
        flags_str = " ".join(flags) if flags else "·"

        agent = state.get("current_agent") or "—"
        return HTML(
            f' <b>{mm.name}</b>'
            f' │ agent:<ansimagenta>{agent}</ansimagenta>'
            f' │ {flags_str}'
            f' │ ctx <ansigreen>{pct_bar}</ansigreen> {pct}%'
            f' │ msgs:{len(hist)}'
            f' │ <ansigray>/help · ESC=cancel · Ctrl+D=quit</ansigray>'
        )
    return _bar

# ╔════════════════════════════════════════════════════════════════════════╗
# ║ Main                                                                  ║
# ╚════════════════════════════════════════════════════════════════════════╝
def main():
    agents = load_agents()
    skills = load_skills()
    banner(len(agents), len(skills))

    # ── Ollama discovery (silent — failure means "no Ollama running") ─────
    OLLAMA_MODELS.update(discover_ollama_models())
    if OLLAMA_MODELS:
        console.print(f"[dim]🦙 Ollama: discovered {len(OLLAMA_MODELS)} models at "
                      f"{OLLAMA_HOST}  (use /model ol:<tag>)[/]")

    # Resolve DEFAULT_MODEL — accept bare ollama tags (e.g. THMES_MODEL=gemma4:e4b)
    default_model = DEFAULT_MODEL
    if default_model not in MODELS and not _is_ollama_alias(default_model):
        if f"ol:{default_model}" in OLLAMA_MODELS:
            default_model = f"ol:{default_model}"
        elif default_model not in MODELS and OLLAMA_MODELS:
            console.print(f"[yellow]⚠ THMES_MODEL={DEFAULT_MODEL!r} not found; "
                          f"falling back to first available[/]")
            default_model = next(iter(MODELS), next(iter(OLLAMA_MODELS)))

    # ── Model picker — shown once at startup ──────────────────────────────
    default_model = _model_picker(OLLAMA_MODELS, MODELS, default_model)
    mm.load(default_model)

    # ── Session store ─────────────────────────────────────────────────────
    store = SessionStore(SESSIONS_DB)
    session_id = store.create_session(model=default_model, agent=None)
    session_first_msg = True   # rename session by first user msg

    # ── Task store (per-session task list, shared with the `tasklist` tool) ─
    task_store = TaskStore(TASKS_DB)
    _TASK_CTX["store"] = task_store
    _TASK_CTX["session_id"] = session_id

    history: list[dict] = []
    pending_image = pending_audio = None
    max_tokens = DEFAULT_MAX_TOKENS   # default 2048 (was 512)
    custom_system: Optional[str] = None
    current_agent: Optional[str] = None
    tools_on = True
    auto_load = True       # ← smart router: model picks its own context
    auto_compact = True    # ← auto-summarize old history when >threshold
    compact_threshold = COMPACT_THRESHOLD
    allow_dangerous: set[str] = set()
    last_stats: dict = {}
    last_routed: dict = {}  # show what was loaded last turn
    last_system: str = ""    # snapshot of system used last turn (for /context)

    # ── Smart slash-command completer ────────────────────────────────────
    # Maps each command → list of sub-arg generators (dynamic at completion time)
    CMD_META = {
        "/image":    {"desc": "attach image", "args": "PATH"},
        "/audio":    {"desc": "attach audio", "args": "PATH"},
        "/agent":    {"desc": "switch persona", "subs": lambda: list(agents.keys()) + ["list"]},
        "/skill":    {"desc": "invoke skill", "subs": lambda: list(skills.keys()) + ["list"]},
        "/tool":     {"desc": "manage tools", "subs": lambda: ["list","on","off","allow"] + list(TOOLS.keys())},
        "/opencode": {"desc": "delegation toggle", "subs": lambda: ["on","off"]},
        "/verbose":  {"desc": "verbose tool display", "subs": lambda: ["on","off"]},
        "/model":    {"desc": "switch model",
                      "subs": lambda: list(MODELS.keys())
                                      + sorted(OLLAMA_MODELS.keys())
                                      + ["list", "refresh", "unload"]},
        "/auto":     {"desc": "smart-router toggle", "subs": lambda: ["on","off","last"]},
        "/context":  {"desc": "show token usage"},
        "/compact":  {"desc": "summarize old history", "subs": lambda: ["on","off","threshold"]},
        "/session":  {"desc": "session manager", "subs": lambda: ["list","new","load","archive","rename"]},
        "/breakers": {"desc": "circuit breaker state", "subs": lambda: ["reset"]},
        "/research": {"desc": "deterministic multi-round keyword-expanding research",
                      "subs": lambda: ["--depth", "--rounds", "auto"]},
        "/relay":    {"desc": "privacy relay: mask→cloud→unmask",
                      "subs": lambda: ["on","off","tools","verify","model","cats","deny","vault","status"]},
        "/plan":     {"desc": "draft a plan before executing",
                      "subs": lambda: ["auto"]},
        "/continuity": {"desc": "topic-continuity auto-detection",
                        "subs": lambda: ["on","off"]},
        "/task":     {"desc": "session task list",
                      "subs": lambda: ["list","add","done","doing","pending","cancel","clear"]},
        "/queue":    {"desc": "show/clear queued prompts; on|off toggles listener",
                      "subs": lambda: ["list","clear","on","off"]},
        "/system":   {"desc": "custom system prompt"},
        "/report":   {"desc": "export last answer as a styled HTML report", "args": "TITLE"},
        "/clear":    {"desc": "reset history"},
        "/save":     {"desc": "save conversation"},
        "/load":     {"desc": "load conversation", "args": "FILE"},
        "/max":      {"desc": "max output tokens"},
        "/stats":    {"desc": "last-turn stats"},
        "/help":     {"desc": "show help"},
        "/quit":     {"desc": "exit"},
        "/exit":     {"desc": "exit"},
    }

    class SlashCompleter(Completer):
        def get_completions(self, document, complete_event):
            text = document.text_before_cursor
            if not text.startswith("/"):
                return  # no completion outside of commands
            # Split into command + current arg
            parts = text.split(maxsplit=1)
            cmd = parts[0]
            rest = parts[1] if len(parts) > 1 else ""
            # Stage 1: completing the command name itself
            if " " not in text:
                for name, meta in CMD_META.items():
                    if name.lower().startswith(cmd.lower()):
                        yield Completion(
                            name, start_position=-len(cmd),
                            display=name,
                            display_meta=meta.get("desc", ""),
                        )
                return
            # Stage 2: completing sub-argument
            meta = CMD_META.get(cmd)
            if not meta: return
            subs_fn = meta.get("subs")
            if not subs_fn: return
            # Word being typed (last token of rest)
            current = rest.split()[-1] if rest.split() else ""
            for s in subs_fn():
                if s.lower().startswith(current.lower()):
                    yield Completion(
                        s, start_position=-len(current),
                        display=s,
                    )

    # Wrap with FuzzyCompleter for typo tolerance
    completer = FuzzyCompleter(SlashCompleter())

    # Shared state dict — closures (header + bottom toolbar) read from this
    state = {
        "mm": mm,
        "history": history,
        "tools_on": tools_on,
        "auto_load": auto_load,
        "current_agent": current_agent,
        "pending_image": pending_image,
        "pending_audio": pending_audio,
        "last_system": last_system,
        "session_id": session_id,
        "agents": agents,
        "last_peak": 0,
        "last_elapsed": 0,
        "last_tps": 0,
    }
    session = PromptSession(history=FileHistory(str(HISTORY_FILE)),
                            auto_suggest=AutoSuggestFromHistory(),
                            completer=completer,
                            complete_while_typing=True,
                            bottom_toolbar=make_bottom_toolbar(state),
                            refresh_interval=0.5)

    while True:
        # Sync state for header + bottom toolbar
        state.update({
            "mm": mm, "history": history, "tools_on": tools_on,
            "auto_load": auto_load, "current_agent": current_agent,
            "pending_image": pending_image, "pending_audio": pending_audio,
            "last_system": last_system, "session_id": session_id,
        })
        # Keep the tasklist tool pointed at the current session
        _TASK_CTX["session_id"] = session_id
        render_header(state)

        # If user queued prompts during the previous turn (typed while model
        # was working), drain one before pt_prompt blocks.
        queued = drain_queue()
        if queued is not None:
            remaining = queue_size()
            console.print(f"[green]▶ running queued prompt[/] "
                          f"[dim]({remaining} more in queue)[/]: "
                          f"[white]{queued[:120]}[/]")
            line = queued
        else:
            prompt_label = HTML(f'<ansicyan><b>you</b></ansicyan> › ')
            try:
                line = session.prompt(prompt_label).strip()
            except KeyboardInterrupt:
                # Ctrl+C while typing → clear input + stay
                console.print("[dim](ESC=cancel generation · Ctrl+D=quit · "
                              "type while model works → queued)[/]")
                continue
            except EOFError:
                sess = store.get_session(session_id)
                if sess and sess["message_count"] == 0:
                    store.archive(session_id)
                store.close()
                task_store.close()
                mm.unload(quiet=True)
                console.print("\n[dim]bye[/]"); break
        if not line: continue

        # ── Auto plan-mode: clearly multi-step request → offer to plan first ─
        # Rewrites `line` into a `/plan ...` invocation so the single /plan
        # handler does the work (no duplicated flow).
        if (_FLAGS.get("plan_auto", True)
                and not line.startswith("/")
                and line != "__skill_invocation__"
                and _PLAN_TRIGGER_RE.search(line)):
            ans = ask_yn("งานนี้ดูเป็นหลายขั้นตอน — ร่างแผนก่อนเริ่มไหม?",
                         default="y")
            if ans == "y":
                line = "/plan " + line

        # ── slash commands ────────────────────────────────────────────────
        if line.startswith("/"):
            parts = line.split(maxsplit=1)
            cmd, arg = parts[0].lower(), (parts[1] if len(parts) > 1 else "")

            if cmd in {"/quit", "/exit"}:
                # Clean up empty/untouched session + free model memory
                sess = store.get_session(session_id)
                if sess and sess["message_count"] == 0:
                    store.archive(session_id)
                store.close()
                task_store.close()
                mm.unload(quiet=True)
                console.print("[dim]bye[/]"); break
            if cmd == "/help": help_panel(); continue
            if cmd == "/clear":
                history.clear(); pending_image = pending_audio = None
                console.print("[yellow]history cleared[/]"); continue

            if cmd == "/image":
                p = Path(arg).expanduser()
                if not p.exists(): console.print(f"[red]no file:[/] {p}"); continue
                pending_image = str(p); console.print(f"[green]📎 image:[/] {p.name}"); continue
            if cmd == "/audio":
                p = Path(arg).expanduser()
                if not p.exists(): console.print(f"[red]no file:[/] {p}"); continue
                pending_audio = str(p); console.print(f"[green]📎 audio:[/] {p.name}"); continue

            if cmd == "/agent":
                if not arg or arg == "list":
                    list_panel(f"agents ({len(agents)})", agents); continue
                if arg not in agents:
                    console.print(f"[red]unknown agent:[/] {arg}"); continue
                current_agent = arg; custom_system = None
                console.print(f"[green]👤 agent set:[/] {arg} — {agents[arg]['description'][:80]}")
                continue

            if cmd == "/skill":
                if not arg or arg == "list":
                    list_panel(f"skills ({len(skills)})", skills); continue
                if arg not in skills:
                    console.print(f"[red]unknown skill:[/] {arg}"); continue
                # Inject skill body + ask user for the actual input
                console.print(Panel(skills[arg]["description"],
                                    title=f"📋 skill: {arg}", border_style="magenta"))
                try:
                    ask = session.prompt(HTML(f'<ansimagenta>skill input ›</ansimagenta> ')).strip()
                except (KeyboardInterrupt, EOFError): continue
                if not ask: continue
                run_skill_agentic(arg, skills[arg], ask, history, store, session_id,
                                  tools_on, allow_dangerous, max_tokens)
                if session_first_msg:
                    store.update_title(session_id, f"Skill:{arg}: {ask[:50]}")
                    session_first_msg = False
                continue
            elif cmd == "/tool":
                sub = arg.split(maxsplit=1)
                if not sub or sub[0] == "list":
                    t = Table(show_header=True, header_style="bold cyan", box=None)
                    t.add_column("tool", style="green"); t.add_column("risk")
                    t.add_column("auto-allow"); t.add_column("desc")
                    for k, v in TOOLS.items():
                        t.add_row(k, TOOL_RISK[k],
                                  "✓" if k in allow_dangerous or TOOL_RISK[k]=="safe" else "ask",
                                  v["desc"])
                    console.print(Panel(t, title=f"tools (enabled={tools_on})", border_style="dim"))
                elif sub[0] == "on": tools_on = True; console.print("[green]tools ON[/]")
                elif sub[0] == "off": tools_on = False; console.print("[yellow]tools OFF[/]")
                elif sub[0] == "allow" and len(sub) > 1:
                    allow_dangerous.add(sub[1])
                    console.print(f"[green]auto-allow:[/] {sub[1]}")
                else:
                    console.print("[red]usage: /tool [list|on|off|allow NAME][/]")
                continue

            if cmd == "/model":
                # Refresh Ollama discovery so newly-pulled tags appear without restart
                if not arg or arg in ("list", "refresh"):
                    OLLAMA_MODELS.clear()
                    OLLAMA_MODELS.update(discover_ollama_models())
                if not arg or arg == "list":
                    entries = {k: {"description": f"[mlx] {v}"} for k, v in MODELS.items()}
                    for k, meta in sorted(OLLAMA_MODELS.items()):
                        entries[k] = {"description":
                            f"[ollama] {meta['model']}  "
                            f"({meta.get('params','?')} · {meta.get('size_gb',0):.1f}GB · "
                            f"ctx {meta['ctx']:,})"}
                    list_panel(f"models ({len(MODELS)} mlx + {len(OLLAMA_MODELS)} ollama)", entries)
                    continue
                if arg == "refresh":
                    console.print(f"[green]✓ refreshed:[/] {len(OLLAMA_MODELS)} ollama models")
                    continue
                if arg == "unload":
                    mm.unload()
                    continue
                # Resolve: explicit MLX alias, ollama alias, or bare tag (treat as ol:)
                target = arg
                if target not in MODELS and not _is_ollama_alias(target):
                    if f"ol:{target}" in OLLAMA_MODELS or ":" in target:
                        target = f"ol:{target}"
                if target not in MODELS and not _is_ollama_alias(target):
                    avail = ", ".join(list(MODELS) + list(OLLAMA_MODELS)[:5])
                    console.print(f"[red]unknown model. examples: {avail}[/]")
                    continue
                mm.load(target); continue

            if cmd == "/session":
                sub = arg.split(maxsplit=1)
                action = sub[0] if sub else "list"
                if action == "list":
                    sessions = store.list_sessions(limit=20)
                    t = Table(show_header=True, header_style="bold cyan", box=None, padding=(0, 1))
                    t.add_column("id", style="green", no_wrap=True)
                    t.add_column("title")
                    t.add_column("model", style="cyan")
                    t.add_column("agent", style="magenta")
                    t.add_column("msgs", justify="right")
                    t.add_column("tokens", justify="right")
                    t.add_column("updated", style="dim")
                    for s in sessions:
                        marker = "→ " if s["id"] == session_id else "  "
                        t.add_row(marker + s["id"], (s["title"] or "")[:60],
                                  s["model"] or "—", s["agent"] or "—",
                                  str(s["message_count"]), str(s["total_tokens"]),
                                  s["updated_at"][:16])
                    console.print(Panel(t, title=f"sessions ({len(sessions)})  • current: {session_id}",
                                        border_style="dim"))
                elif action == "load" and len(sub) > 1:
                    target_id = sub[1]
                    loaded = store.load_messages(target_id)
                    sess = store.get_session(target_id)
                    if not sess:
                        console.print(f"[red]no session:[/] {target_id}"); continue
                    history.clear(); history.extend(loaded)
                    session_id = target_id
                    session_first_msg = False
                    if sess["model"] and (sess["model"] in MODELS
                                          or _is_ollama_alias(sess["model"])):
                        mm.load(sess["model"])
                    if sess["agent"] and sess["agent"] in agents:
                        current_agent = sess["agent"]
                    console.print(f"[green]✓ resumed session[/] [cyan]{target_id}[/]  "
                                  f"[dim]({len(loaded)} msgs, model={sess['model']}, agent={sess['agent']})[/]")
                elif action == "new":
                    history.clear()
                    session_id = store.create_session(model=mm.name, agent=current_agent)
                    session_first_msg = True
                    console.print(f"[green]✓ new session[/] [cyan]{session_id}[/]")
                elif action == "archive":
                    target = sub[1] if len(sub) > 1 else session_id
                    store.archive(target)
                    console.print(f"[yellow]✓ archived[/] {target}")
                    if target == session_id:
                        session_id = store.create_session(model=mm.name, agent=current_agent)
                        history.clear()
                        console.print(f"[green]✓ new session[/] [cyan]{session_id}[/]")
                elif action == "rename" and len(sub) > 1:
                    store.update_title(session_id, sub[1])
                    console.print(f"[green]✓ renamed[/] {session_id} → {sub[1]}")
                else:
                    console.print("[red]usage: /session [list|load ID|new|archive [ID]|rename TITLE][/]")
                continue
            if cmd == "/breakers":
                sub = arg.split(maxsplit=1)
                if sub and sub[0] == "reset":
                    name = sub[1] if len(sub) > 1 else None
                    _BREAKER.reset(name)
                    console.print(f"[green]✓ reset[/] {'all' if not name else name}")
                    continue
                snap = _BREAKER.snapshot()
                if not snap:
                    console.print("[dim]no tool calls tracked yet[/]"); continue
                t = Table(show_header=True, header_style="bold cyan", box=None, padding=(0, 2))
                t.add_column("tool", style="green")
                t.add_column("state"); t.add_column("fails"); t.add_column("calls"); t.add_column("cooldown")
                for name, s in snap.items():
                    color = {"closed":"green","half_open":"yellow","open":"red"}.get(s["state"],"white")
                    t.add_row(name, f"[{color}]{s['state']}[/]",
                              f"{s['total_fails']}/{s['total_calls']}",
                              str(s['total_calls']),
                              f"{s['cooldown_left']}s" if s['cooldown_left'] else "—")
                console.print(Panel(t, title="circuit breakers", border_style="dim"))
                continue
            if cmd == "/plan":
                # /plan auto on|off  → toggle auto plan-mode
                _pa = arg.split()
                if _pa and _pa[0] == "auto":
                    if len(_pa) > 1 and _pa[1] in ("on", "off"):
                        _FLAGS["plan_auto"] = (_pa[1] == "on")
                        console.print(f"[green]✓ plan auto-mode "
                                      f"{'ON' if _FLAGS['plan_auto'] else 'OFF'}[/]")
                    else:
                        cur = "ON" if _FLAGS.get("plan_auto", True) else "OFF"
                        console.print(f"[cyan]plan auto-mode:[/] {cur}  "
                                      f"(usage: /plan auto on|off)")
                    continue
                if not arg:
                    console.print("[red]usage: /plan TASK[/]  "
                                  "[dim](or /plan auto on|off)[/]")
                    continue
                plan_task = arg
                # 1. Draft the plan (no tools, dedicated planning prompt)
                console.print("[dim]  ✻ drafting a plan…[/]")
                try:
                    plan_reply, _ = generate_reply(
                        [{"role": "user", "content": f"Task: {plan_task}"}],
                        system=_plan_system_block(), max_tokens=400)
                except Exception as e:
                    console.print(f"[red]plan generation failed:[/] {rich_escape(str(e))}")
                    continue
                steps = _parse_plan_steps(plan_reply)
                if not steps:
                    console.print("[yellow]⚠ could not parse a step list — "
                                  "treating as a normal request[/]")
                    # Insert plan_task into history/store directly so agent_turn
                    # receives it.  Then use the __skill_invocation__ sentinel to
                    # bypass the catch-all "unknown command" check and fall through
                    # to normal message processing.  (plain `line = plan_task` kept
                    # us inside the command-dispatch block and triggered the error.)
                    history.append({"role": "user", "content": plan_task})
                    store.add_message(session_id, "user", plan_task)
                    if session_first_msg:
                        store.update_title(session_id, plan_task[:80])
                        session_first_msg = False
                    line = "__skill_invocation__"   # fall through to agent_turn
                else:
                    # 2. Display the proposed plan
                    plan_tbl = Table(show_header=False, box=None, padding=(0, 1))
                    plan_tbl.add_column(style="cyan", no_wrap=True)
                    plan_tbl.add_column()
                    for i, s in enumerate(steps, 1):
                        plan_tbl.add_row(f"{i}.", s)
                    console.print(Panel(plan_tbl,
                                  title=f"📋 proposed plan — {plan_task[:60]}",
                                  title_align="left", border_style="cyan"))
                    # 3. Approve
                    ans = ask_yn("ดำเนินการตามแผนนี้?", default="y", allow_always=False)
                    if ans != "y":
                        console.print("[yellow]plan cancelled[/]")
                        continue
                    # 4. Seed the task list with the plan steps
                    task_store.add_many(session_id, steps)
                    render_tasklist()
                    # 5. Execute — inject plan + run the agent loop
                    plan_lines = "\n".join(f"{i}. {s}" for i, s in enumerate(steps, 1))
                    exec_msg = (
                        f"{plan_task}\n\n[Approved plan — execute it step by step]\n"
                        f"{plan_lines}\n\n"
                        f"Use the tasklist tool: mark each step in_progress before "
                        f"starting it and done after finishing. Work through all steps."
                    )
                    history.append({"role": "user", "content": exec_msg})
                    store.add_message(session_id, "user", f"[Plan] {plan_task}")
                    if session_first_msg:
                        store.update_title(session_id, f"Plan: {plan_task[:60]}")
                        session_first_msg = False
                    system_full = tools_system_block(
                        TOOLS if tools_on else {}, list(skills.keys()),
                        agents[current_agent]["system"] if current_agent else "",
                        profile=_detect_model_profile(mm))
                    last_system = system_full
                    pre_turn_len = max(0, len(history) - 1)
                    try:
                        t0 = time.time()
                        reply, stats = with_esc_cancel(
                            agent_turn, history, system=system_full,
                            image=None, audio=None,
                            max_tokens=max(max_tokens, 2048),
                            tools_on=tools_on, allow_dangerous=allow_dangerous,
                            max_iters=30)
                        elapsed = time.time() - t0
                        last_stats = stats
                        store.add_message(session_id, "assistant",
                                          TOOL_CALL_RE.sub("", reply).strip()[:5000]
                                          or reply[:5000],
                                          tokens=stats.get("tokens", 0))
                        console.print(Rule(style="dim"))
                        console.print(Markdown(TOOL_CALL_RE.sub("", reply).strip() or reply))
                        console.print(f"[dim]📋 plan executed · {stats['iters']} iters · "
                                      f"{stats['tool_calls']} tool calls · {elapsed:.1f}s[/]")
                        console.print(Rule(style="dim"))
                        render_tasklist()
                    except KeyboardInterrupt:
                        dropped = len(history) - pre_turn_len
                        del history[pre_turn_len:]
                        console.print(f"[yellow]⚠ plan execution cancelled — "
                                      f"rolled back {dropped} msg(s)[/]")
                    pending_image = pending_audio = None
                    continue

            if cmd == "/relay":
                _rl = arg.split()
                sub = _rl[0].lower() if _rl else "status"
                if sub == "status":
                    cur = "[green]ON[/]" if _FLAGS.get("relay_mode") else "[dim]OFF[/]"
                    cloud = _resolve_relay_cloud() or "[dim]— (ยังไม่ตั้ง)[/]"
                    groups = ", ".join(_relay_cfg.get("groups") or DEFAULT_GROUPS)
                    deny = _relay_cfg.get("deny_list") or []
                    eng = "ready" if _MASK_OK else "[red]UNAVAILABLE (lib/thmes_mask.py)[/]"
                    agentic = ("[magenta]ON[/] [dim](cloud decides · local executes)[/]"
                               if _FLAGS.get("relay_tools") else "[dim]OFF[/]")
                    vcmd = _FLAGS.get("relay_verify_cmd") or ""
                    vstr = (f"[green]{vcmd}[/] [dim](≤{_FLAGS.get('relay_heal_attempts',3)} รอบ)[/]"
                            if vcmd else "[dim]OFF[/]")
                    console.print(
                        f"[bold cyan]🛡️ Privacy relay[/]  {cur}\n"
                        f"  [dim]cloud (REASON):[/] {cloud}\n"
                        f"  [dim]agentic tools:[/] {agentic}\n"
                        f"  [dim]self-heal verify:[/] {vstr}\n"
                        f"  [dim]mask groups:[/] {groups}\n"
                        f"  [dim]deny-list:[/] {len(deny)} term(s)\n"
                        f"  [dim]vault:[/] {len(_relay_vault) if _relay_vault else 0} masked this session\n"
                        f"  [dim]engine:[/] {eng}\n"
                        f"  [dim]usage:[/] /relay on|off · tools on|off · verify <cmd>|off · model [TAG] · cats a,b · deny add|rm TERM · vault")
                    continue
                if sub == "on":
                    _enter_relay_mode()
                    continue
                if sub == "off":
                    _FLAGS["relay_mode"] = False
                    console.print("[yellow]🛡️ relay OFF[/] [dim](กลับ default local mode)[/]")
                    continue
                if sub == "tools":
                    act = _rl[1].lower() if len(_rl) > 1 else "status"
                    if act in ("on", "off"):
                        _FLAGS["relay_tools"] = (act == "on")
                    cur_t = ("[magenta]ON[/]" if _FLAGS.get("relay_tools") else "[dim]OFF[/]")
                    console.print(
                        f"[cyan]🛡️ relay agentic tools:[/] {cur_t}\n"
                        "  [dim]ON  → cloud decides tool calls; THIS machine reads/writes/"
                        "runs them; each result is re-masked before returning to cloud.[/]\n"
                        "  [dim]OFF → one-shot relay (cloud reasons on masked text, no tools).[/]")
                    if act not in ("on", "off", "status"):
                        console.print("[dim]  (usage: /relay tools on|off)[/]")
                    continue
                if sub == "verify":
                    rest = arg.split(None, 1)
                    spec = rest[1].strip() if len(rest) > 1 else ""
                    if spec.lower() in ("off", "none", "clear"):
                        _FLAGS["relay_verify_cmd"] = ""
                        console.print("[yellow]🧪 self-heal verify OFF[/]")
                    elif spec:
                        _FLAGS["relay_verify_cmd"] = spec
                        console.print(
                            f"[green]✓ self-heal verify =[/] [cyan]{spec}[/]\n"
                            f"  [dim]หลัง relay agentic เสร็จ จะรันคำสั่งนี้; ถ้า fail → local "
                            f"model วิเคราะห์ error → ส่งกลับให้ cloud แก้ (สูงสุด "
                            f"{_FLAGS.get('relay_heal_attempts', 3)} รอบ). ต้องเปิด /relay tools on ด้วย.[/]")
                    else:
                        cur_v = _FLAGS.get("relay_verify_cmd") or ""
                        console.print(f"[cyan]🧪 self-heal verify:[/] "
                                      + (f"[green]{cur_v}[/]" if cur_v else "[dim]OFF[/]")
                                      + "  [dim](usage: /relay verify <shell-cmd> | off)[/]")
                    continue
                if sub == "model":
                    tag = _rl[1] if len(_rl) > 1 else _pick_cloud_model()
                    if not tag:
                        console.print("[dim]  ยกเลิก[/]"); continue
                    console.print(f"[dim]🛡️  smoke-test `{tag}` …[/]")
                    ok, detail = _cloud_smoke_test(tag)
                    if not ok:
                        console.print(f"[red]✖ smoke-test ล้มเหลว — ไม่บันทึก[/]\n[dim]{detail[:200]}[/]")
                        continue
                    _relay_cfg["cloud_model"] = tag
                    _relay_settings_save()
                    console.print(f"[green]✓ relay cloud model = [cyan]{tag}[/] (บันทึกแล้ว)[/]")
                    continue
                if sub == "cats":
                    if len(_rl) > 1:
                        req = [g.lower() for g in re.split(r"[,\s]+", " ".join(_rl[1:])) if g]
                        valid = [g for g in req if g in _RELAY_DEFAULT_GROUPS]
                        if not valid:
                            console.print(f"[red]หมวดไม่ถูกต้อง[/] "
                                          f"[dim](เลือกจาก: {', '.join(_RELAY_DEFAULT_GROUPS)})[/]")
                            continue
                        _relay_cfg["groups"] = valid
                        _relay_settings_save()
                        if _relay_vault is not None:
                            _relay_vault.groups = set(valid)
                        console.print(f"[green]✓ mask groups = {', '.join(valid)}[/]")
                    else:
                        console.print(f"[cyan]mask groups:[/] "
                                      f"{', '.join(_relay_cfg.get('groups') or DEFAULT_GROUPS)}  "
                                      f"[dim](available: {', '.join(_RELAY_DEFAULT_GROUPS)})[/]")
                    continue
                if sub == "deny":
                    act = _rl[1].lower() if len(_rl) > 1 else "list"
                    term = " ".join(_rl[2:]).strip()
                    dl = _relay_cfg.setdefault("deny_list", [])
                    if act == "add" and term:
                        if term not in dl:
                            dl.append(term)
                        _relay_settings_save()
                        if _relay_vault is not None:
                            _relay_vault.deny_list = list(dl)
                        console.print(f"[green]✓ deny-list + '{term}' ({len(dl)} terms)[/]")
                    elif act in ("rm", "remove", "del") and term:
                        _relay_cfg["deny_list"] = [d for d in dl if d != term]
                        _relay_settings_save()
                        if _relay_vault is not None:
                            _relay_vault.deny_list = list(_relay_cfg["deny_list"])
                        console.print(f"[green]✓ deny-list − '{term}'[/]")
                    elif act == "list":
                        console.print(f"[cyan]deny-list ({len(dl)}):[/] "
                                      + (", ".join(dl) if dl else "[dim]ว่าง[/]"))
                    else:
                        console.print("[red]usage: /relay deny add|rm TERM | list[/]")
                    continue
                if sub == "vault":
                    if not _relay_vault or len(_relay_vault) == 0:
                        console.print("[dim]vault ว่าง (ยังไม่มีการ mask ใน session นี้)[/]")
                        continue
                    st = _relay_vault.stats()
                    console.print("[cyan]🛡️ vault (session):[/] "
                                  + ", ".join(f"{v} {k.lower()}" for k, v in sorted(st.items())))
                    show_vals = _FLAGS.get("relay_show_values") or (len(_rl) > 1 and _rl[1] in ("-v", "values"))
                    if show_vals:
                        for t, r in _relay_vault.mapping():
                            console.print(f"  [dim]{t}[/] = {r}")
                    else:
                        console.print("[dim]  (ค่าจริงซ่อนไว้ — `/relay vault -v` เพื่อแสดง)[/]")
                    continue
                console.print("[red]usage:[/] /relay on|off · tools on|off · verify <cmd>|off · model [TAG] · "
                              "cats a,b · deny add|rm TERM · vault · status")
                continue
            if cmd == "/research":
                # /research auto on|off  → toggle the auto multi-source hint
                _ra = arg.split()
                if _ra and _ra[0] == "auto":
                    if len(_ra) > 1 and _ra[1] in ("on", "off"):
                        _FLAGS["research_auto"] = (_ra[1] == "on")
                        console.print(f"[green]✓ research auto-hint "
                                      f"{'ON' if _FLAGS['research_auto'] else 'OFF'}[/]  "
                                      f"[dim](inject multi-source hint on factual queries)[/]")
                    else:
                        cur = "ON" if _FLAGS.get("research_auto", True) else "OFF"
                        console.print(f"[cyan]research auto-hint:[/] {cur}  "
                                      f"(usage: /research auto on|off)")
                    continue
                if not arg:
                    console.print("[red]usage: /research QUERY [--depth N][/]  "
                                  "[dim](e.g. /research ราคาทองวันนี้ --depth 3 · "
                                  "or /research auto on|off)[/]")
                    continue
                import re as _re
                depth_m = _re.search(r"--depth\s+(\d+)", arg)
                rounds_m = _re.search(r"--rounds\s+(\d+)", arg)
                research_depth = (int(depth_m.group(1)) if depth_m
                                  else int(_FLAGS.get("research_depth", 3)))
                research_rounds = (int(rounds_m.group(1)) if rounds_m
                                   else int(_FLAGS.get("research_rounds", 3)))
                research_query = _re.sub(r"--(?:depth|rounds)\s+\d+", "", arg).strip()
                if not research_query:
                    console.print("[red]usage: /research QUERY [--depth N] [--rounds N][/]")
                    continue

                history.append({"role": "user",
                                "content": f"[Research] {research_query}"})
                store.add_message(session_id, "user", f"[Research] {research_query}")
                if session_first_msg:
                    store.update_title(session_id, f"Research: {research_query[:60]}")
                    session_first_msg = False

                console.print(Panel(
                    f"[bold cyan]🔬 Research mode[/]  "
                    f"[dim]≥{research_depth} sources · up to {research_rounds} rounds · "
                    f"keyword-expanding · deterministic (model-agnostic)[/]\n"
                    f"[white]{research_query}[/]",
                    border_style="cyan", title_align="left"))

                # Controller drives the search loop directly — it does NOT rely on
                # the model emitting tool calls, so it works the same across models.
                pre_turn_len = max(0, len(history) - 1)
                try:
                    t0 = time.time()
                    _ra_pa = _analyze_prompt(research_query)
                    answer, meta = with_esc_cancel(
                        run_research_loop, research_query,
                        depth=research_depth, max_rounds=research_rounds,
                        analysis=_ra_pa)
                    elapsed = time.time() - t0
                    last_stats = {"tokens": 0, "tps_sum": 0.0,
                                  "iters": max(meta["rounds"], 1),
                                  "tool_calls": meta["evidence_count"], "peak": 0}
                    state["last_peak"] = 0
                    state["last_elapsed"] = elapsed
                    state["last_tps"] = 0
                    if answer:
                        history.append({"role": "assistant", "content": answer})
                        store.add_message(session_id, "assistant", answer[:5000])
                        console.print(Rule(style="dim"))
                        console.print(Markdown(answer))
                        console.print(
                            f"[dim]🔬 research complete · {meta['rounds']} round(s) · "
                            f"{meta['n_sources']} source(s) · "
                            f"{len(meta['queries'])} queries · {elapsed:.1f}s[/]")
                        if meta["domains"]:
                            console.print("[dim]   sources: "
                                          + ", ".join(meta["domains"][:8]) + "[/]")
                        console.print(Rule(style="dim"))
                    else:
                        # Nothing found — roll back so the dangling [Research] user
                        # message doesn't poison later context.
                        del history[pre_turn_len:]
                        console.print("[yellow]⚠ ไม่พบข้อมูลจากการค้นหา "
                                      "(ลองปรับคำค้น หรือตรวจสอบการเชื่อมต่อเน็ต)[/]")
                except KeyboardInterrupt:
                    dropped = len(history) - pre_turn_len
                    del history[pre_turn_len:]
                    console.print(f"[yellow]⚠ research cancelled — rolled back {dropped} msg(s)[/]")
                pending_image = pending_audio = None
                continue

            if cmd == "/queue":
                sub = arg.split(maxsplit=1)
                if sub and sub[0] == "clear":
                    n = clear_queue()
                    console.print(f"[yellow]✓ cleared {n} queued prompt(s)[/]")
                    continue
                if sub and sub[0] in ("on", "off"):
                    global QUEUE_ENABLED
                    QUEUE_ENABLED = (sub[0] == "on")
                    state_str = "ON" if QUEUE_ENABLED else "OFF"
                    console.print(f"[green]✓ queue listener {state_str}[/]  "
                                  f"[dim](type-ahead during model gen "
                                  f"{'enabled — beware: may race with approval prompts' if QUEUE_ENABLED else 'disabled'})[/]")
                    continue
                size = queue_size()
                status = "ON" if QUEUE_ENABLED else "OFF"
                if size == 0:
                    console.print(f"[dim]queue empty.[/] "
                                  f"[dim](listener: {status} — toggle with /queue on|off; "
                                  f"cancel with 'cancel' / 'หยุด' / Ctrl+C when ON)[/]")
                else:
                    # Peek (drain + re-fill so order preserved)
                    items = []
                    while not _PROMPT_QUEUE.empty():
                        try: items.append(_PROMPT_QUEUE.get_nowait())
                        except _queue_mod.Empty: break
                    for s in items: _PROMPT_QUEUE.put(s)
                    t = Table(show_header=True, header_style="bold cyan", box=None, padding=(0, 2))
                    t.add_column("#", style="green", no_wrap=True)
                    t.add_column("prompt")
                    for i, q in enumerate(items, 1):
                        t.add_row(str(i), q[:100] + ("…" if len(q) > 100 else ""))
                    console.print(Panel(t, title=f"queue ({size} pending)",
                                        border_style="dim"))
                continue
            if cmd == "/verbose":
                if arg in {"on","true","1","enable"}:
                    _FLAGS["verbose_tools"] = True
                    console.print("[green]✓ verbose tools ON[/] — full panels for tool calls/results")
                elif arg in {"off","false","0","disable"}:
                    _FLAGS["verbose_tools"] = False
                    console.print("[yellow]✓ verbose tools OFF[/] — compact one-line display")
                else:
                    cur = "ON" if _FLAGS["verbose_tools"] else "OFF"
                    console.print(f"[cyan]verbose:[/] {cur}  (usage: /verbose on|off)")
                continue
            if cmd == "/opencode":
                if arg in {"on","enable","true","1"}:
                    _FLAGS["opencode_enabled"] = True
                    console.print("[green]✓ opencode ON[/] — bias rules will inject it for code tasks")
                elif arg in {"off","disable","false","0"}:
                    _FLAGS["opencode_enabled"] = False
                    console.print("[yellow]✓ opencode OFF[/] — model uses direct tools (write_file, bash, …)")
                else:
                    cur = "ON" if _FLAGS["opencode_enabled"] else "OFF"
                    console.print(f"[cyan]opencode:[/] {cur}  (usage: /opencode on|off)")
                continue
            if cmd == "/context":
                ctx = measure_context(history, last_system, mm.processor)
                native = native_ctx()
                pct = ctx["total_in"] / native * 100
                bar_w = 40
                filled = int(min(pct, 100) / 100 * bar_w)
                bar = "█" * filled + "░" * (bar_w - filled)
                color = "green" if pct < 50 else "yellow" if pct < 80 else "red"
                t = Table(show_header=False, box=None, padding=(0, 2))
                t.add_column(style="cyan", no_wrap=True); t.add_column()
                t.add_row("model",           f"{mm.name}  (native: {native:,} tokens)")
                t.add_row("system prompt",   f"{ctx['system_tokens']:,} tokens")
                t.add_row("history",         f"{ctx['history_tokens']:,} tokens  ({ctx['history_msgs']} msgs)")
                t.add_row("total input",     f"[bold {color}]{ctx['total_in']:,}[/] tokens  ({pct:.1f}% used)")
                t.add_row("remaining",       f"{native - ctx['total_in']:,} tokens")
                t.add_row("auto-compact",    f"{'ON' if auto_compact else 'OFF'} @ {compact_threshold*100:.0f}% threshold")
                t.add_row("usage",           f"[{color}]{bar}[/] {pct:.1f}%")
                # Show heaviest messages
                if ctx["per_msg"]:
                    top = sorted(enumerate(ctx["per_msg"]), key=lambda x: -x[1])[:3]
                    heavy = "  ".join(f"#{i} ({history[i]['role'][:1]}): {n:,}t" for i, n in top if n > 100)
                    if heavy: t.add_row("heaviest msgs", heavy)
                console.print(Panel(t, title="context usage", border_style=color))
                continue
            if cmd == "/compact":
                sub = arg.split(maxsplit=1)
                if sub and sub[0] == "on": auto_compact = True; console.print("[green]auto-compact ON[/]"); continue
                if sub and sub[0] == "off": auto_compact = False; console.print("[yellow]auto-compact OFF[/]"); continue
                if sub and sub[0] == "threshold" and len(sub) > 1:
                    try:
                        v = float(sub[1])
                        compact_threshold = v / 100 if v > 1 else v
                        console.print(f"[green]threshold = {compact_threshold*100:.0f}%[/]"); continue
                    except: console.print("[red]usage: /compact threshold N[/]"); continue
                # Manual compact now
                keep = int(arg) if arg.isdigit() else 4
                ctx = measure_context(history, last_system, mm.processor)
                if len(history) <= keep:
                    console.print(f"[dim]history too small to compact ({len(history)} msgs)[/]"); continue
                with console.status("[cyan]summarizing old turns…", spinner="dots"):
                    t0 = time.time()
                    history[:], n_compacted = compact_history(history, mm.processor, keep_recent=keep)
                    elapsed = time.time() - t0
                ctx2 = measure_context(history, last_system, mm.processor)
                saved = ctx["total_in"] - ctx2["total_in"]
                console.print(f"[green]✓ compacted[/] {n_compacted} msgs → 1 summary  "
                              f"[dim]({elapsed:.1f}s, saved {saved:,} tokens)[/]")
                continue
            if cmd == "/auto":
                if arg == "on": auto_load = True; console.print("[green]🧠 auto-load ON[/] (model picks its own context per turn)")
                elif arg == "off": auto_load = False; console.print("[yellow]🧠 auto-load OFF[/] (full context sent every turn)")
                elif arg == "last":
                    if not last_routed: console.print("[dim](no route yet)[/]")
                    else: console.print(Panel(
                        f"tools:  {last_routed.get('tools') or []}\n"
                        f"agent:  {last_routed.get('agent') or '—'}\n"
                        f"skills: {last_routed.get('skills') or []}",
                        title="last routing", border_style="magenta"))
                else: console.print(f"[cyan]auto-load:[/] {'ON' if auto_load else 'OFF'}   (usage: /auto on|off|last)")
                continue
            if cmd == "/task" or cmd == "/tasks":
                sub = arg.split(maxsplit=1)
                action = sub[0] if sub else "list"
                if action == "add" and len(sub) > 1:
                    ids = task_store.add_many(session_id,
                                              sub[1].splitlines() or [sub[1]])
                    console.print(f"[green]✓ added {len(ids)} task(s)[/]")
                    render_tasklist()
                elif action in ("done", "doing", "pending", "cancel") and len(sub) > 1:
                    status_map = {"done": "done", "doing": "in_progress",
                                  "pending": "pending", "cancel": "cancelled"}
                    try:
                        tid = int(sub[1].lstrip("#").split()[0])
                    except (ValueError, IndexError):
                        console.print("[red]usage: /task done|doing|pending|cancel N[/]")
                        continue
                    if task_store.set_status(session_id, tid, status_map[action]):
                        console.print(f"[green]✓ task #{tid} → {status_map[action]}[/]")
                        render_tasklist()
                    else:
                        console.print(f"[red]task #{tid} not found[/]")
                elif action == "clear":
                    n = task_store.clear(session_id)
                    console.print(f"[yellow]✓ cleared {n} task(s)[/]")
                elif action == "list":
                    render_tasklist(quiet_if_empty=False)
                else:
                    console.print("[red]usage: /task [list|add TEXT|done N|"
                                  "doing N|pending N|cancel N|clear][/]")
                continue
            if cmd == "/continuity":
                if arg in {"on","true","1","enable"}:
                    _FLAGS["continuity_check"] = True
                    console.print("[green]✓ continuity check ON[/] — new topics "
                                  "auto-start a fresh session")
                elif arg in {"off","false","0","disable"}:
                    _FLAGS["continuity_check"] = False
                    console.print("[yellow]✓ continuity check OFF[/] — context "
                                  "always carried forward")
                else:
                    cur = "ON" if _FLAGS.get("continuity_check", True) else "OFF"
                    console.print(f"[cyan]continuity check:[/] {cur}  "
                                  f"(usage: /continuity on|off)")
                continue
            if cmd == "/system":
                custom_system = arg or None; current_agent = None
                console.print(f"[green]system set[/]" if arg else "[yellow]system cleared[/]")
                continue
            if cmd == "/max":
                try: max_tokens = int(arg); console.print(f"[green]max_tokens = {max_tokens}[/]")
                except: console.print("[red]usage: /max N[/]")
                continue
            if cmd == "/save":
                fn = Path(arg or f"chat-{int(time.time())}.json").expanduser()
                fn.write_text(json.dumps(history, ensure_ascii=False, indent=2))
                console.print(f"[green]saved →[/] {fn}"); continue
            if cmd == "/load":
                fn = Path(arg).expanduser()
                if not fn.exists(): console.print(f"[red]no file:[/] {fn}"); continue
                history = json.loads(fn.read_text())
                console.print(f"[green]loaded {len(history)} messages[/]"); continue
            if cmd == "/stats":
                if not last_stats: console.print("[dim](no gen yet)[/]"); continue
                console.print(f"[cyan]tokens:[/] {last_stats['tokens']}  "
                              f"[cyan]avg_tps:[/] {last_stats['tps_sum']/max(last_stats['iters'],1):.1f}  "
                              f"[cyan]iters:[/] {last_stats['iters']}  "
                              f"[cyan]tool_calls:[/] {last_stats['tool_calls']}  "
                              f"[cyan]corrections:[/] {last_stats.get('corrections',0)}  "
                              f"[cyan]drift_nudges:[/] {last_stats.get('drift_nudges',0)}  "
                              f"[cyan]peak:[/] {last_stats['peak']:.2f} GB")
                continue
            if cmd == "/report":
                last_a = next((h["content"] for h in reversed(history)
                               if h.get("role") == "assistant"
                               and str(h.get("content", "")).strip()), "")
                if not last_a:
                    console.print("[yellow](no assistant answer to report yet)[/]"); continue
                title = arg.strip() or "THMES Session Report"
                console.print(tool_make_report(title, last_a, "html")); continue
            if line != "__skill_invocation__":
                console.print(f"[red]unknown command:[/] {cmd}  (try /help)")
                continue

        # ── Context-continuity check (before adding to history) ───────────
        # If the new message starts an unrelated topic, archive the current
        # session and start fresh so stale context doesn't pollute reasoning.
        if (line != "__skill_invocation__"
                and _FLAGS.get("continuity_check", True)
                and history):
            verdict = _detect_continuity(line, history)
            do_new_session = False
            if verdict == "new":
                console.print("[dim]  🆕 detected a new topic — starting a fresh "
                              "session (old one archived, see /session list)[/]")
                do_new_session = True
            elif verdict == "unsure":
                ans = ask_yn("ดูเหมือนอาจเป็นคนละเรื่องกับที่คุยก่อนหน้า — "
                             "เริ่ม session ใหม่ไหม?", default="n")
                do_new_session = (ans == "y")
            if do_new_session:
                sess = store.get_session(session_id)
                if sess and sess["message_count"] == 0:
                    store.archive(session_id)
                else:
                    store.archive(session_id)
                history.clear()
                session_id = store.create_session(model=mm.name, agent=current_agent)
                session_first_msg = True
                state["session_id"] = session_id

        # ── add to history (unless skill already appended) ────────────────
        if line != "__skill_invocation__":
            history.append({"role": "user", "content": line})
            store.add_message(session_id, "user", line)
            # First user message becomes session title
            if session_first_msg:
                store.update_title(session_id, line[:80])
                session_first_msg = False

        # ── compose system prompt (smart route OR static) ─────────────────
        agent_desc = ""
        chosen_agent = current_agent
        chosen_tools = TOOLS if tools_on else {}
        chosen_skills_idx: list[str] = list(skills.keys())
        last_routed = {}

        # Smart routing only on fresh user turns (not skill-invocations or empty)
        user_msg = history[-1]["content"] if history else ""

        # ── Prompt analysis: domain/intent/language/search-angles ────────────
        # Fast heuristic (<1 ms) — drives format injection and better queries.
        # Skipped for tool_result continuations and skill invocations.
        _pa = (_analyze_prompt(user_msg)
               if (user_msg and not user_msg.startswith(("<tool_result", "[Research]", "/"))
                   and len(user_msg) > 3)
               else None)

        if (auto_load and tools_on and not custom_system and not current_agent
                and not user_msg.startswith("<tool_result")):
            route_t0 = time.time()
            sel = smart_route(user_msg, agents, skills)
            route_ms = int((time.time() - route_t0) * 1000)
            if sel:
                last_routed = sel
                chosen_tools = {k: v for k, v in TOOLS.items() if k in sel["tools"]}
                chosen_skills_idx = sel["skills"]
                if sel["agent"]:
                    chosen_agent = sel["agent"]
                # ALWAYS show all 3 slots so user can spot empty selections
                t_str = f"[{'green' if sel['tools'] else 'red'}][{','.join(sel['tools']) or '—'}][/]"
                a_str = f"[{'magenta' if sel['agent'] else 'dim'}]{sel['agent'] or '—'}[/]"
                s_str = f"[{'cyan' if sel['skills'] else 'dim'}][{','.join(sel['skills']) or '—'}][/]"
                kw = sel.get("added_by_keyword") or []
                kw_str = f"  [magenta](+kw:{','.join(kw)})[/]" if kw else ""
                path_label = "[green]🧠 kw-fast[/]" if sel.get("fast_path") else "[magenta]🧠 routed[/]"
                console.print(f"{path_label} in {route_ms}ms → "
                              f"[dim]tools=[/]{t_str}  "
                              f"[dim]agent=[/]{a_str}  "
                              f"[dim]skills=[/]{s_str}{kw_str}")
            else:
                console.print(f"[yellow]🧠 router failed ({route_ms}ms) — falling back to full context[/]")

        # ── Privacy relay: mask → cloud → unmask (takes precedence) ────────
        # When relay mode is on, the whole turn is masked locally, reasoned by a
        # cloud model that sees only placeholders, then unmasked locally. On any
        # leak / cloud failure it falls through to the normal local agent_turn —
        # which is safe (the local model never sends data off the machine).
        if _FLAGS.get("relay_mode") and not user_msg.startswith("<tool_result"):
            _cloud = _resolve_relay_cloud()
            if not _cloud or not _MASK_OK:
                _FLAGS["relay_mode"] = False
                console.print("[yellow]⚠ relay: ไม่มี cloud model — กลับ default mode[/]")
            else:
                _relay_ensure_vault(session_id)
                _agent_sys = ""
                if current_agent and current_agent in agents:
                    _agent_sys = agents[current_agent].get("system", "")
                elif custom_system:
                    _agent_sys = custom_system
                _rl_pre = max(0, len(history) - 1)
                try:
                    if _FLAGS.get("relay_tools"):
                        # Agentic sub-mode: cloud decides tool calls, this machine
                        # executes them locally, results are re-masked back to cloud.
                        _rl_ans = _run_and_present_relay_agent(
                            user_msg, store, session_id, history,
                            cloud_model=_cloud, vault=_relay_vault,
                            tools_on=chosen_tools, allow_dangerous=allow_dangerous,
                            agent_system=_agent_sys)
                    else:
                        _rl_ans = _run_and_present_mask(
                            user_msg, store, session_id, history,
                            cloud_model=_cloud, vault=_relay_vault, agent_system=_agent_sys)
                except KeyboardInterrupt:
                    del history[_rl_pre:]
                    console.print("[yellow]⚠ relay ยกเลิก[/]")
                    pending_image = pending_audio = None
                    continue
                if _rl_ans:
                    pending_image = pending_audio = None
                    continue
                console.print("[dim]  ↪ relay ไม่สำเร็จ — ตอบด้วย local model "
                              "(ของจริงไม่ออกนอกเครื่อง)[/]")

        # Auto-detect factual/current-info query → ensure web tools are loaded
        # and inject the multi-source research hint (Option B). Skipped for
        # tool_result continuations, custom system, explicit agent, or when
        # the user turned it off via /research auto off.
        research_triggered = bool(
            _FLAGS.get("research_auto", True) and tools_on
            and not custom_system and not current_agent
            and not user_msg.startswith("<tool_result")
            and not user_msg.startswith("[Research]")
            and _RESEARCH_TRIGGER_RE.search(user_msg)
        )
        if research_triggered:
            # Pre-emptive deterministic research: a clear current-info question
            # gets searched-then-answered without first drafting from stale memory.
            # The controller owns the loop (search → judge coverage → expand
            # keywords → search again), so it behaves the same on any model.
            _rt_pre = max(0, len(history) - 1)
            try:
                _rt_ans = _run_and_present_research(
                    user_msg, _pa, store, session_id, history,
                    reason="คำถามต้องใช้ข้อมูลปัจจุบัน")
            except KeyboardInterrupt:
                del history[_rt_pre:]
                console.print("[yellow]⚠ research ยกเลิก[/]")
                pending_image = pending_audio = None
                continue
            if _rt_ans:
                pending_image = pending_audio = None
                continue
            # Controller found nothing → let the model answer itself, but give it
            # the web tools + search hint so it can still try.
            console.print("[dim]  ↪ ค้นไม่ได้ — ให้โมเดลตอบเอง (พร้อม web tools)[/]")
            for _wt in ("web_search", "web_fetch"):
                if _wt in TOOLS and _wt not in chosen_tools:
                    chosen_tools[_wt] = TOOLS[_wt]

        # Auto-bump max_tokens for long-content tasks (write_file truncation problem)
        effective_max = max_tokens
        if "write_file" in chosen_tools or "bash" in chosen_tools:
            effective_max = max(max_tokens, 2048)
            if effective_max != max_tokens:
                console.print(f"[dim]ℹ auto-bump max_tokens → {effective_max} (write/bash needs headroom)[/]")

        if chosen_agent: agent_desc = agents[chosen_agent]["system"]
        if custom_system: agent_desc = custom_system
        # Append HTML/code safety hint when write_file is in play
        if "write_file" in chosen_tools and any(
                k in user_msg.lower() for k in ["html", "code", "script", "page", "infographic"]):
            agent_desc = (agent_desc + "\n\n" if agent_desc else "") + (
                "IMPORTANT — writing large HTML/CSS/JS files:\n"
                "Split the file into 3–5 chunks using write_file with mode='a' (append).\n"
                "First chunk: call write_file with mode='w' (creates/overwrites the file).\n"
                "Subsequent chunks: call write_file with mode='a' (appends to the file).\n"
                f"Keep each chunk under {_detect_model_profile(mm).max_chunk_chars} characters to avoid JSON encoding issues.\n"
                "Example sequence for a 4KB HTML file:\n"
                "  call 1: write_file(path, '<!DOCTYPE html>...<style>', mode='w')\n"
                "  call 2: write_file(path, '...rest of CSS...', mode='a')\n"
                "  call 3: write_file(path, '</style><body>...hero section...', mode='a')\n"
                "  call 4: write_file(path, '...features section...</body></html>', mode='a')\n"
                "Do NOT put the entire file in one write_file call — it will fail."
            )
        # Inject 3-part format instruction into agent_desc when query benefits
        fmt_block = _format_instruction_block(_pa) if _pa else ""
        if fmt_block:
            agent_desc = (agent_desc + "\n\n" if agent_desc else "") + fmt_block

        system_full = tools_system_block(chosen_tools, chosen_skills_idx, agent_desc,
                                         profile=_detect_model_profile(mm))
        if research_triggered:
            system_full = _research_hint_block(_pa) + "\n\n" + system_full
            pa_label = (f"  \\[{_pa.domain}·{_pa.intent}]" if _pa else "")
            console.print(f"[dim]  🔍 multi-source mode — factual query detected{pa_label} "
                          "(toggle: /research auto off)[/]")
        last_system = system_full

        # ── Auto-compact: if context > threshold, summarize old turns ─────
        if auto_compact and len(history) > 6:
            ctx = measure_context(history, system_full, mm.processor)
            native = native_ctx()
            pct = ctx["total_in"] / native
            if pct > compact_threshold:
                console.print(f"[yellow]🗜  auto-compact triggered:[/] "
                              f"{ctx['total_in']:,}/{native:,} ({pct*100:.0f}%)")
                with console.status("[yellow]summarizing old turns…", spinner="dots"):
                    history, n_compacted = compact_history(history, mm.processor, keep_recent=4)
                ctx2 = measure_context(history, system_full, mm.processor)
                saved = ctx["total_in"] - ctx2["total_in"]
                console.print(f"[green]   ✓ compacted {n_compacted} → 1 summary  "
                              f"(saved {saved:,} tokens, now {ctx2['total_in']:,})[/]")

        # ── run agent loop (ESC cancels) ──────────────────────────────────
        # Atomic-turn semantics: capture history length BEFORE the user msg
        # was appended. On ESC, truncate back to this point so partial
        # assistant replies / tool_results / drift nudges don't leak.
        pre_turn_len = max(0, len(history) - 1)
        # Reset per-turn approval allow-list (separate from session allow-list)
        _TURN_ALLOWED_TOOLS.clear()
        try:
            t0 = time.time()
            try:
                reply, stats = with_esc_cancel(
                    agent_turn, history, system=system_full,
                    image=pending_image, audio=pending_audio,
                    max_tokens=effective_max, tools_on=tools_on,
                    allow_dangerous=allow_dangerous,
                    max_iters=(30 if research_triggered else 6))
            except KeyboardInterrupt:
                elapsed = time.time() - t0
                dropped = len(history) - pre_turn_len
                console.print(Rule(style="dim"))
                console.print(f"[yellow]⚠ Cancelled by ESC after {elapsed:.1f}s — "
                              f"rolled back {dropped} msg(s), returning to prompt[/]")
                console.print(Rule(style="dim"))
                pending_image = pending_audio = None
                del history[pre_turn_len:]
                continue
            elapsed = time.time() - t0
            last_stats = stats
            state["last_peak"] = stats.get("peak", 0)
            state["last_elapsed"] = elapsed
            state["last_tps"] = stats["tps_sum"] / max(stats["iters"], 1)

            # ── Quality check (pre-output) ────────────────────────────────────
            # Skip quality check when reply has pending tool calls (not yet executed)
            _has_pending_calls = bool(TOOL_CALL_RE.search(reply))
            if _pa and stats.get("tool_calls", 0) == 0 and not _has_pending_calls:
                _qc_ok, _qc_issues, _qc_retry = _quality_check(user_msg, reply, _pa)
                if not _qc_ok:
                    for _issue in _qc_issues:
                        console.print(f"[yellow]  ⚠ quality:[/] [dim]{_issue}[/]")
                    if _qc_retry and len(history) > 0:
                        # Language mismatch: inject a correction and retry once
                        console.print("[yellow]  ↩ retrying with language correction…[/]")
                        history.append({"role": "user", "content":
                            "คำตอบที่แล้วเป็นภาษาผิด กรุณาตอบใหม่เป็นภาษาไทย "
                            "(The previous reply was in the wrong language. "
                            "Please rewrite it fully in Thai.)"})
                        try:
                            reply, stats2 = with_esc_cancel(
                                agent_turn, history, system=system_full,
                                max_tokens=effective_max, tools_on=False)
                            reply = reply  # replace with corrected reply
                            aggregate_stats_retry = stats2  # noqa: F841
                        except Exception:
                            pass  # keep original reply if retry fails

            # ── Multi-dimensional research on an UNCERTAIN draft ───────────────
            # The model answered from memory but admitted it doesn't really know
            # (TH/EN knowledge-gap phrases) → search the web and answer again.
            # Only for memory-only answers to factual/explain/compare/opinion
            # questions (never code/task/chat, agents, or tool-producing turns).
            if (_pa and not research_triggered
                    and stats.get("tool_calls", 0) == 0 and not _has_pending_calls
                    and tools_on and not custom_system and not current_agent
                    and _FLAGS.get("research_auto", True)
                    and "web_search" in TOOLS
                    and _pa.intent not in ("code", "task", "chat")):
                _unc = _detect_uncertainty(reply)
                if _unc:
                    console.print(f"[bold cyan]🔬 ร่างคำตอบไม่มั่นใจ[/] "
                                  f"[dim](“{_unc}”) — ขอค้นข้อมูลก่อนตอบ…[/]")
                    try:
                        _r_ans, _r_meta = with_esc_cancel(
                            run_research_loop, user_msg, analysis=_pa)
                    except KeyboardInterrupt:
                        _r_ans, _r_meta = None, None
                        console.print("[yellow]  ⚠ research ยกเลิก — ใช้ร่างเดิม[/]")
                    if _r_ans:
                        reply = _r_ans
                        if history and history[-1].get("role") == "assistant":
                            history[-1]["content"] = _r_ans
                        else:
                            history.append({"role": "assistant", "content": _r_ans})
                        stats["research_rounds"] = _r_meta.get("rounds")
                        stats["research_sources"] = _r_meta.get("n_sources")
                        console.print(
                            f"[dim]  🔬 {_r_meta['rounds']} round(s) · "
                            f"{_r_meta['n_sources']} source(s) gathered[/]")

            # Persist tool trail (intermediate assistant tool_calls + tool_results)
            # so /session load can restore the full reasoning trace, not just the
            # final answer. Stores the wrapped content verbatim so the in-memory
            # history format round-trips exactly (load_messages reads role+content
            # as-is). tool_call/tool_result columns are filled for indexability.
            trail_known_tools = set(TOOLS.keys())
            for msg in history[pre_turn_len + 1:-1]:
                role = msg.get("role", "")
                content = msg.get("content", "")
                if role == "assistant":
                    calls, _ = parse_tool_calls(content, known_tools=trail_known_tools)
                    if calls:
                        store.add_message(
                            session_id, "assistant", content[:5000],
                            tool_call=(calls[0] if len(calls) == 1
                                       else {"batch": calls}),
                        )
                elif role == "user" and content.startswith("<tool_result"):
                    store.add_message(session_id, "user", content[:5000],
                                      tool_result=content[:5000])
            # Persist final assistant reply
            store.add_message(session_id, "assistant",
                              TOOL_CALL_RE.sub("", reply).strip()[:5000] or reply[:5000],
                              tokens=stats.get("tokens", 0))
            pending_image = pending_audio = None

            # Salvage: if no tool call succeeded but model produced file content
            # (skip if opencode was available — it handles its own file writes)
            if (stats["tool_calls"] == 0 and tools_on
                    and "write_file" in chosen_tools
                    and "opencode" not in chosen_tools):
                salvaged = salvage_file_writes(reply, user_msg)
                # Dedup: same path may appear multiple times (model emitted
                # multiple broken chunks). Keep largest content per path so
                # the user is only prompted once with the most complete version.
                _seen: dict[str, tuple[str, str]] = {}
                for _sp, _sc, _ss in salvaged:
                    if _sp not in _seen or len(_sc) > len(_seen[_sp][0]):
                        _seen[_sp] = (_sc, _ss)
                salvaged = [(_p, _c, _s) for _p, (_c, _s) in _seen.items()]
                for path, content, source in salvaged:
                    p = Path(path).expanduser()
                    console.print(Panel(
                        f"[bold yellow]🛟 Salvaged from {source}:[/] [cyan]{p}[/]\n"
                        f"[dim]Model's tool call broke; recovered "
                        f"{len(content):,} bytes ({len(content.splitlines())} lines)[/]",
                        border_style="yellow"))
                    ans = ask_yn("write this file?", default="y")
                    if ans == "y":
                        p.parent.mkdir(parents=True, exist_ok=True)
                        p.write_text(content, encoding="utf-8")
                        console.print(f"[green]✓ wrote[/] [cyan]{p}[/] ({len(content):,} bytes)")
                    else:
                        console.print("[dim]skipped[/]")

            console.print(Rule(style="dim"))
            # strip tool_call blocks + model artifacts from final display
            clean = _strip_model_artifacts(TOOL_CALL_RE.sub("", reply)).strip()
            # Only print if there's actual prose left — never fall back to raw
            # reply, which would dump the raw <tool_call> JSON to the user.
            if clean:
                console.print(Markdown(clean))
            corr = stats.get('corrections', 0)
            corr_str = f" · {corr} fmt-fix" if corr else ""
            drift = stats.get('drift_nudges', 0)
            drift_str = f" · {drift} drift-nudge" if drift else ""
            rsrc = stats.get('research_sources')
            research_str = (f" · 🔬 {stats.get('research_rounds', 0)}r/{rsrc} src"
                            if rsrc is not None else "")
            # Compute context usage after this turn
            ctx_now = measure_context(history, system_full, mm.processor)
            native_w = native_ctx()
            ctx_pct = ctx_now["total_in"] / native_w * 100
            ctx_color = "green" if ctx_pct < 50 else "yellow" if ctx_pct < 80 else "red"
            footer = (f"[dim]{stats['tokens']} tok · "
                      f"{stats['iters']} turn(s) · "
                      f"{stats['tool_calls']} tool call(s)"
                      f"{corr_str}{drift_str}{research_str} · "
                      f"{stats['peak']:.2f} GB · "
                      f"{elapsed:.1f}s · "
                      f"ctx [{ctx_color}]{ctx_now['total_in']:,}/{native_w:,} ({ctx_pct:.0f}%)[/][dim]"
                      f"[/]")
            console.print(footer); console.print(Rule(style="dim"))
        except Exception as e:
            console.print(f"[red bold]error:[/] {rich_escape(str(e))}")
            console.print(f"[dim]{rich_escape(traceback.format_exc())}[/]")
            if history and history[-1]["role"] == "user": history.pop()


if __name__ == "__main__":
    try: main()
    except KeyboardInterrupt: console.print("\n[dim]bye[/]")
