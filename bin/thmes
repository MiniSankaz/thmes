# Ollama integration — opt-in via auto-discovery. If Ollama is unreachable,
# the discovery probe returns empty and only the MLX models above are exposed.
# Use `/model ol:<tag>` to pick an Ollama model (e.g. /model ol:gemma4:e4b).
OLLAMA_HOST = _env("THMES_OLLAMA_HOST", "http://127.0.0.1:11434")
# Per-chunk idle timeout (seconds). Streaming resets this on every token
# received — only fires when the model sends nothing for this long (stuck/crashed).
# Much safer than a flat total timeout: slow models can run indefinitely as long
# as they keep generating.  Override via THMES_OLLAMA_TIMEOUT.
OLLAMA_TIMEOUT = float(_env("THMES_OLLAMA_TIMEOUT", "60"))
# Cold-load budget (seconds). The FIRST read of a request also waits for the
# model to load into (V)RAM, which can far exceed the per-chunk idle timeout for
# a multi-GB model. Used for warmup and as the one-shot retry timeout when a
# call times out (likely because the model was loading). THMES_OLLAMA_LOAD_TIMEOUT.
OLLAMA_LOAD_TIMEOUT = float(_env("THMES_OLLAMA_LOAD_TIMEOUT", "180"))
# Optional bearer key for Ollama cloud models (the `:cloud`-suffixed tags that
# run on ollama.com, not locally). If unset, cloud models still work provided
# the local daemon is signed in via `ollama signin`.
OLLAMA_API_KEY = _env("THMES_OLLAMA_API_KEY", "").strip()


def _ollama_headers(extra: Optional[dict] = None) -> dict:
    """Standard headers for Ollama HTTP calls — adds Authorization when an
    API key is configured (needed for cloud models on some setups)."""
    h = {"Content-Type": "application/json", "Accept": "application/json"}
    if OLLAMA_API_KEY:
        h["Authorization"] = f"Bearer {OLLAMA_API_KEY}"
    if extra:
        h.update(extra)
    return h
# Per-family context defaults (used when Ollama doesn't report explicit ctx).
# These reflect what we will REQUEST from Ollama via num_ctx — capped to keep
# VRAM in check on laptops. Ollama's own default is small (≈4k/32k depending
# on env) and would silently truncate long histories without our compaction
# ever triggering. Override per-session via THMES_OLLAMA_NUM_CTX.
