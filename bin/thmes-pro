class SessionListItem(ListItem):
    def __init__(self, session: dict):
        super().__init__()
        self.session = session

    def compose(self) -> ComposeResult:
        s = self.session
        title = (s["title"] or "(untitled)")[:24]
        msgs = s["message_count"]
        when = s["updated_at"][11:16] if s["updated_at"] else "—"
        # One-line layout to avoid sub-row clipping
        yield Label(f"[bold]{title}[/] [dim]{when}·{msgs}m[/]")


