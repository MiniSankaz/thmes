#!/usr/bin/env python3
"""thmes-pro — Textual-based agentic TUI (next-gen successor to thmes classic).

Three-pane layout:
  ┌──────────────────────────────────────────────────────────┐
  │ Header: model · agent · ctx% · breaker · ⏱                │
  ├──────────┬──────────────────────┬────────────────────────┤
  │ Sessions │  Chat (markdown)     │  Monitor (stats/logs)  │
  │  list    │  + tool call cards   │  + tool exec timeline  │
  │          │                      │                        │
  ├──────────┴──────────────────────┴────────────────────────┤
  │ Input: > _                                                │
  ├──────────────────────────────────────────────────────────┤
  │ Footer: keybindings                                       │
  └──────────────────────────────────────────────────────────┘

Imports core (SessionStore, CircuitBreaker, agents) from thmes.
"""
from __future__ import annotations
