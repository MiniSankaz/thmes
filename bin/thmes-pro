# ── Defuse tqdm + subprocess inside Textual ────────────────────────────────
# Problem: mlx_vlm.generate_step uses tqdm("Prefill") which on broken stdout
# (Textual hijacks it) falls back to spawning `stty size` subprocess. Inside
# Textual's worker thread, subprocess fds are corrupted → fatal:
#   "Error: bad value(s) in fds_to_keep"
#
# Solution: REPLACE tqdm classes with a no-op stub BEFORE any mlx_vlm import.
# This neutralizes every tqdm variant (tqdm.tqdm, tqdm.auto.tqdm, etc).

_FAKE_SIZE = (140, 40)
shutil.get_terminal_size = lambda fallback=_FAKE_SIZE: os.terminal_size(_FAKE_SIZE)
os.environ.setdefault("TQDM_DISABLE", "1")

class _NoOpTqdm:
    """Drop-in replacement that does nothing — no subprocess, no terminal probe.

    Also exposes class-level methods that HuggingFace Hub / transformers call.
    """
    monitor_interval = 10
    _instances = set()

    def __init__(self, iterable=None, *args, **kwargs):
        self.iterable = iterable if iterable is not None else []
        self.n = 0
        self.total = kwargs.get("total")
        self.desc = kwargs.get("desc", "")
        self.disable = True
    def __iter__(self):
        for item in self.iterable:
            self.n += 1
            yield item
    def __enter__(self): return self
    def __exit__(self, *a): pass
    def update(self, n=1):       self.n += n
    def close(self):             pass
    def set_description(self, *a, **kw): pass
    def set_description_str(self, *a, **kw): pass
    def set_postfix(self, *a, **kw):     pass
    def set_postfix_str(self, *a, **kw): pass
    def write(self, msg, *a, **kw):      pass
    def refresh(self):           pass
    def reset(self, total=None): self.n = 0; self.total = total
    def display(self, *a, **kw): pass
    def clear(self, *a, **kw):   pass
    def __getattr__(self, name): return lambda *a, **kw: None
    # ── Class-level methods huggingface_hub / multiprocessing expect ───
    @classmethod
    def set_lock(cls, lock): cls._lock = lock
    @classmethod
    def get_lock(cls): return getattr(cls, "_lock", None)
    @classmethod
    def write_class(cls, *a, **kw): pass
    @staticmethod
    def format_sizeof(num, *a, **kw): return str(num)
    @staticmethod
    def format_interval(t): return f"{t:.0f}s"
    @staticmethod
    def format_meter(*a, **kw): return ""
    @staticmethod
    def status_printer(*a, **kw):
        return lambda *a, **kw: None
    @classmethod
    def pandas(cls, *a, **kw): pass

# Patch every tqdm export that mlx_vlm or transformers might use
try:
    import tqdm as _tqdm_pkg
    _tqdm_pkg.tqdm = _NoOpTqdm
    if hasattr(_tqdm_pkg, "trange"):
        _tqdm_pkg.trange = lambda *a, **kw: _NoOpTqdm(range(*a))
    try:
        import tqdm.auto as _tqdm_auto
        _tqdm_auto.tqdm = _NoOpTqdm
        if hasattr(_tqdm_auto, "trange"):
            _tqdm_auto.trange = lambda *a, **kw: _NoOpTqdm(range(*a))
    except ImportError: pass
    try:
        import tqdm.std as _tqdm_std
        _tqdm_std.tqdm = _NoOpTqdm
    except ImportError: pass
    try:
        import tqdm.notebook as _tqdm_nb
        _tqdm_nb.tqdm = _NoOpTqdm
    except ImportError: pass
except ImportError:
    pass

# ── Single-instance lockfile ──────────────────────────────────────────────
# Data home — migrate a pre-existing ~/.gemma-tui (old project name) once.
_THMES_HOME = Path.home() / ".thmes"
_LEGACY_HOME = Path.home() / ".gemma-tui"
if _LEGACY_HOME.exists() and not _THMES_HOME.exists():
    try:
        _LEGACY_HOME.rename(_THMES_HOME)
    except Exception:
        _THMES_HOME = _LEGACY_HOME
_LOCK_PATH = _THMES_HOME / "data" / "thmes-pro.pid"

def _acquire_lock() -> bool:
    """Returns True if this process owns the lock, False if another instance is alive."""
    _LOCK_PATH.parent.mkdir(parents=True, exist_ok=True)
    if _LOCK_PATH.exists():
        try:
            old_pid = int(_LOCK_PATH.read_text().strip())
            # Check if PID is alive
            try:
                os.kill(old_pid, 0)
                # Process exists
                return False
            except ProcessLookupError:
                pass  # stale lock — overwrite
        except (ValueError, OSError):
            pass
    _LOCK_PATH.write_text(str(os.getpid()))
    return True

def _release_lock():
    try:
        if _LOCK_PATH.exists() and _LOCK_PATH.read_text().strip() == str(os.getpid()):
            _LOCK_PATH.unlink()
    except Exception: pass

if not _acquire_lock():
    other_pid = _LOCK_PATH.read_text().strip()
    print(f"\033[1;31mAnother thmes-pro is already running (PID {other_pid}).\033[0m")
    print(f"  • Switch to that terminal, or")
    print(f"  • If it's stale: rm {_LOCK_PATH} && thmes-pro")
    sys.exit(1)

# Clear screen scrollback before app starts (kills leftover artifacts)
sys.stdout.write("\033[2J\033[H\033[3J")  # clear screen + home cursor + clear scrollback
sys.stdout.flush()

import atexit
import signal

def _emergency_cleanup(*_):
    """Restore terminal to sane state on any abnormal exit."""
    # Exit alternate screen buffer + show cursor + reset attributes
    sys.stdout.write("\033[?1049l\033[?25h\033[0m")
    sys.stdout.flush()
    _release_lock()
    sys.exit(1)

atexit.register(_release_lock)
# Catch common termination signals to avoid leaving terminal in alt-buffer
for _sig in (signal.SIGTERM, signal.SIGHUP, signal.SIGINT):
    try: signal.signal(_sig, _emergency_cleanup)
    except (OSError, ValueError): pass

